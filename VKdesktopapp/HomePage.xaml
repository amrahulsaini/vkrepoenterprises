<Page
    x:Class="VRASDesktopApp.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:VRASDesktopApp"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Background="{StaticResource Gray100}"
    FontFamily="Segoe UI"
    Loaded="Page_Loaded">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="370" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ── LEFT PANEL ──────────────────────────────────────────────── -->
        <Border Grid.Column="0"
                Background="White"
                BorderBrush="{StaticResource Gray200}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- HOME header -->
                <Border Grid.Row="0"
                        Background="{StaticResource Gray900}"
                        Padding="20,18">
                    <StackPanel>
                        <TextBlock Text="HOME"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="White" />
                        <TextBlock Text="{x:Static local:App.ApiBaseUrl}"
                                   FontSize="10"
                                   Foreground="{StaticResource Gray500}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Stats sections -->
                <StackPanel Grid.Row="1" Margin="16,14,16,10">

                    <!-- RECORDS AND FINANCES -->
                    <Border Background="{StaticResource Gray100}"
                            CornerRadius="4" Padding="8,5" Margin="0,0,0,10">
                        <TextBlock Text="RECORDS AND FINANCES"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource Gray600}" />
                    </Border>

                    <UniformGrid Columns="3" Margin="0,0,0,14">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Name="lblRecords" Text="—"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource Gray900}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Records"
                                       FontSize="11"
                                       Foreground="{StaticResource Gray500}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Name="lblFinances" Text="—"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource Gray900}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Finances"
                                       FontSize="11"
                                       Foreground="{StaticResource Gray500}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Name="lblBranches" Text="—"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource Gray900}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Branches"
                                       FontSize="11"
                                       Foreground="{StaticResource Gray500}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </UniformGrid>

                    <!-- APP USERS -->
                    <Border Background="{StaticResource Gray100}"
                            CornerRadius="4" Padding="8,5" Margin="0,0,0,10">
                        <TextBlock Text="APP USERS"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource Gray600}" />
                    </Border>

                    <UniformGrid Columns="3">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Name="lblSeizers" Text="—"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource Orange600}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Seizers"
                                       FontSize="11"
                                       Foreground="{StaticResource Gray500}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Name="lblActiveUsers" Text="—"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource Green500}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Active"
                                       FontSize="11"
                                       Foreground="{StaticResource Gray500}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Name="lblAdmins" Text="—"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource Gray700}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Admins"
                                       FontSize="11"
                                       Foreground="{StaticResource Gray500}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>

                <!-- DEVICE CHANGED NOTIFICATIONS -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Section header -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource Gray200}"
                            BorderThickness="0,1,0,1"
                            Padding="16,10">
                        <Grid>
                            <TextBlock Text="DEVICE CHANGED NOTIFICATIONS"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource Gray600}"
                                       VerticalAlignment="Center" />
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Background="{StaticResource Orange600}"
                                    CornerRadius="10" Padding="7,2">
                                <TextBlock Name="lblDeviceReqCount"
                                           Text="0"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="White" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- List + empty state -->
                    <Grid Grid.Row="1">
                        <ListView Name="lvDeviceRequests"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource Gray100}"
                                            BorderThickness="0,0,0,1"
                                            Padding="12,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Avatar circle -->
                                            <Border Grid.Column="0"
                                                    Width="42" Height="42"
                                                    CornerRadius="21"
                                                    Background="{StaticResource Gray200}"
                                                    Margin="0,0,10,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Initials}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontWeight="Bold" FontSize="14"
                                                           Foreground="{StaticResource Gray700}" />
                                            </Border>

                                            <!-- Info column -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding UserName}"
                                                           FontWeight="SemiBold" FontSize="13" />
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="📱 " FontSize="11" />
                                                    <TextBlock Text="{Binding UserMobile}"
                                                               Style="{StaticResource Caption}" />
                                                </StackPanel>
                                                <Border Background="{StaticResource Primary50}"
                                                        CornerRadius="3" Padding="4,2"
                                                        HorizontalAlignment="Left"
                                                        Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding ReqLabel}"
                                                               FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{StaticResource Orange700}" />
                                                </Border>
                                            </StackPanel>

                                            <!-- Accept / Deny buttons -->
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="8,0,0,0">
                                                <Button Width="32" Height="32"
                                                        Content="✓"
                                                        Tag="{Binding}"
                                                        Click="AcceptDevice_Click"
                                                        Margin="0,0,6,0"
                                                        FontSize="14" FontWeight="Bold"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        Cursor="Hand">
                                                    <Button.Background>
                                                        <SolidColorBrush Color="{StaticResource cGreen500}" />
                                                    </Button.Background>
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Name="bd"
                                                                    Background="{TemplateBinding Background}"
                                                                    CornerRadius="16">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bd" Property="Opacity" Value="0.8" />
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter TargetName="bd" Property="Opacity" Value="0.5" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Width="32" Height="32"
                                                        Content="✕"
                                                        Tag="{Binding}"
                                                        Click="DenyDevice_Click"
                                                        FontSize="12" FontWeight="Bold"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        Cursor="Hand">
                                                    <Button.Background>
                                                        <SolidColorBrush Color="{StaticResource cRed500}" />
                                                    </Button.Background>
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Name="bd"
                                                                    Background="{TemplateBinding Background}"
                                                                    CornerRadius="16">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bd" Property="Opacity" Value="0.8" />
                                                                </Trigger>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter TargetName="bd" Property="Opacity" Value="0.5" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBlock Name="txtNoRequests"
                                   Text="No pending device change requests"
                                   Style="{StaticResource Caption}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed" />
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- ── RIGHT PANEL: LIVE USERS + MAP ──────────────────────────── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- LIVE USERS header -->
            <Border Grid.Row="0"
                    Background="{StaticResource Gray900}"
                    Padding="20,18">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="LIVE USERS"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="White" />
                        <TextBlock Name="lblLiveCount"
                                   Text="0 online in last 15 min"
                                   FontSize="11"
                                   Foreground="{StaticResource Gray500}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <Ellipse Width="8" Height="8"
                                 Fill="LimeGreen"
                                 VerticalAlignment="Center"
                                 Margin="0,0,5,0" />
                        <TextBlock Text="Live"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="LimeGreen"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Filter / refresh bar -->
            <Border Grid.Row="1"
                    Background="White"
                    BorderBrush="{StaticResource Gray200}"
                    BorderThickness="0,0,0,1"
                    Padding="16,10">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="From today  "
                                   FontSize="12"
                                   Foreground="{StaticResource Gray600}"
                                   VerticalAlignment="Center" />
                        <ComboBox Name="cmbHour"
                                  Width="52" Height="28"
                                  FontSize="13" FontWeight="SemiBold"
                                  VerticalContentAlignment="Center"
                                  Margin="0,0,2,0" />
                        <TextBlock Text=":"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource Gray600}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,2,0" />
                        <ComboBox Name="cmbMinute"
                                  Width="52" Height="28"
                                  FontSize="13" FontWeight="SemiBold"
                                  VerticalContentAlignment="Center"
                                  Margin="0,0,6,0" />
                        <ComboBox Name="cmbAmPm"
                                  Width="52" Height="28"
                                  FontSize="13" FontWeight="SemiBold"
                                  VerticalContentAlignment="Center" />
                    </StackPanel>
                    <Button Content="↻  Apply"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="RefreshBtn_Click"
                            Style="{StaticResource SecondaryButton}"
                            Height="32" Padding="14,0"
                            FontSize="12" />
                </Grid>
            </Border>

            <!-- Leaflet map via WebView2 -->
            <wv2:WebView2 Name="mapView" Grid.Row="2" />
        </Grid>
    </Grid>
</Page>
