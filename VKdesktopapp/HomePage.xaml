<Page
    x:Class="VRASDesktopApp.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:VRASDesktopApp"
    Background="{StaticResource Gray50}"
    FontFamily="Segoe UI"
    Loaded="Page_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource Gray900}"
                BorderBrush="{StaticResource Gray900}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="OPERATIONS HOME"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock Text="Live dashboard — auto-refreshes every 30 s"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource Gray300}" />
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#26FFFFFF"
                        CornerRadius="8"
                        Padding="14,10">
                    <StackPanel>
                        <TextBlock Text="API ENDPOINT"
                                   Style="{StaticResource FormHeading}"
                                   Foreground="{StaticResource Gray300}" />
                        <TextBlock Text="{x:Static local:App.ApiBaseUrl}"
                                   Foreground="White"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Row 1: Records / Finances / Branches -->
        <UniformGrid Grid.Row="1"
                     Columns="3"
                     Margin="0,18,0,0">
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                        <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource Primary500}" Margin="0,0,8,0">
                            <TextBlock Text="R" Foreground="{StaticResource WhiteBrush}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="RECORDS" Style="{StaticResource FormHeading}" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Name="lblRecords" Style="{StaticResource StatValue}" Text="—" />
                    <TextBlock Text="Total vehicle records in DB" Style="{StaticResource Caption}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                        <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource Orange600}" Margin="0,0,8,0">
                            <TextBlock Text="F" Foreground="{StaticResource WhiteBrush}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="FINANCES" Style="{StaticResource FormHeading}" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Name="lblFinances" Style="{StaticResource StatValue}" Text="—" />
                    <TextBlock Text="Finance companies" Style="{StaticResource Caption}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                        <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource Primary700}" Margin="0,0,8,0">
                            <TextBlock Text="BR" Foreground="{StaticResource WhiteBrush}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="BRANCHES" Style="{StaticResource FormHeading}" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Name="lblBranches" Style="{StaticResource StatValue}" Text="—" />
                    <TextBlock Text="Active branches" Style="{StaticResource Caption}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Row 2: App Users stats -->
        <UniformGrid Grid.Row="2"
                     Columns="3"
                     Margin="0,12,0,12">
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                        <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource Orange700}" Margin="0,0,8,0">
                            <TextBlock Text="S" Foreground="{StaticResource WhiteBrush}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="SEIZERS" Style="{StaticResource FormHeading}" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Name="lblSeizers" Style="{StaticResource StatValue}" Text="—" />
                    <TextBlock Text="Non-admin app users" Style="{StaticResource Caption}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                        <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource Primary600}" Margin="0,0,8,0">
                            <TextBlock Text="A" Foreground="{StaticResource WhiteBrush}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="ACTIVE" Style="{StaticResource FormHeading}" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Name="lblActiveUsers" Style="{StaticResource StatValue}" Text="—" />
                    <TextBlock Text="Approved &amp; active members" Style="{StaticResource Caption}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                        <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource Orange600}" Margin="0,0,8,0">
                            <TextBlock Text="AD" Foreground="{StaticResource WhiteBrush}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="ADMINS" Style="{StaticResource FormHeading}" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Name="lblAdmins" Style="{StaticResource StatValue}" Text="—" />
                    <TextBlock Text="Admin accounts" Style="{StaticResource Caption}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Row 3: Device Requests | Live Users -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Device Change Requests -->
            <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="DEVICE CHANGE REQUESTS"
                                       Style="{StaticResource Heading5}" />
                            <TextBlock Name="lblDeviceReqCount"
                                       Text="0 pending"
                                       Style="{StaticResource Caption}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                Background="{StaticResource Orange600}"
                                CornerRadius="4"
                                Padding="6,3"
                                VerticalAlignment="Center">
                            <TextBlock Text="Approve or Deny"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="White" />
                        </Border>
                    </Grid>

                    <ListView Name="lvDeviceRequests"
                              Grid.Row="1"
                              BorderThickness="0"
                              Background="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource Gray200}"
                                        BorderThickness="0,0,0,1"
                                        Padding="4,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding UserName}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13" />
                                            <TextBlock Text="{Binding UserMobile}"
                                                       Style="{StaticResource Caption}" />
                                            <TextBlock Text="{Binding RequestedAt}"
                                                       Style="{StaticResource Caption}"
                                                       Foreground="{StaticResource Gray400}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="8,0,0,0">
                                            <Button Content="Accept"
                                                    Tag="{Binding}"
                                                    Click="AcceptDevice_Click"
                                                    Margin="0,0,6,0"
                                                    Padding="10,4"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Background="{StaticResource Primary500}"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    Cursor="Hand" />
                                            <Button Content="Deny"
                                                    Tag="{Binding}"
                                                    Click="DenyDevice_Click"
                                                    Padding="10,4"
                                                    FontSize="11"
                                                    FontWeight="SemiBold"
                                                    Background="{StaticResource Orange600}"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    Cursor="Hand" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Empty state -->
                    <TextBlock Name="txtNoRequests"
                               Grid.Row="1"
                               Text="No pending device change requests"
                               Style="{StaticResource Caption}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </Grid>
            </Border>

            <!-- Live Users -->
            <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="LIVE USERS"
                                       Style="{StaticResource Heading5}" />
                            <TextBlock Name="lblLiveCount"
                                       Text="0 online in last 15 min"
                                       Style="{StaticResource Caption}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                Background="{StaticResource Primary500}"
                                CornerRadius="4"
                                Padding="6,3"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6"
                                         Fill="LimeGreen"
                                         VerticalAlignment="Center"
                                         Margin="0,0,4,0" />
                                <TextBlock Text="Live"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="White" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <ListView Name="lvLiveUsers"
                              Grid.Row="1"
                              BorderThickness="0"
                              Background="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource Gray200}"
                                        BorderThickness="0,0,0,1"
                                        Padding="4,9">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0"
                                                 Width="8" Height="8"
                                                 Fill="LimeGreen"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13" />
                                            <TextBlock Text="{Binding Mobile}"
                                                       Style="{StaticResource Caption}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding LastSeen}"
                                                       Style="{StaticResource Caption}"
                                                       TextAlignment="Right" />
                                            <TextBlock Text="{Binding GpsStatus}"
                                                       Style="{StaticResource Caption}"
                                                       Foreground="{StaticResource Gray400}"
                                                       TextAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Empty state -->
                    <TextBlock Name="txtNoLiveUsers"
                               Grid.Row="1"
                               Text="No users online in the last 15 minutes"
                               Style="{StaticResource Caption}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
