<Window x:Class="CRMRSDesktopApp.Billing.CertPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Signing Certificate" Height="430" Width="760"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="#F5F5F5">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Choose the certificate used to sign bills"
                       FontSize="15" FontWeight="Bold" Foreground="{StaticResource Accent}" />
            <TextBlock Text="Plug in your DSC USB token first — its certificate appears here automatically."
                       Foreground="#666" FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <ListView Grid.Row="1" Name="lst" SelectionMode="Single"
                  MouseDoubleClick="lst_MouseDoubleClick" BorderBrush="#E0E0E0">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Signer" Width="230" DisplayMemberBinding="{Binding Name}" />
                    <GridViewColumn Header="Issued by" Width="230" DisplayMemberBinding="{Binding Issuer}" />
                    <GridViewColumn Header="Valid till" Width="110" DisplayMemberBinding="{Binding Expiry}" />
                    <GridViewColumn Header="Status" Width="110" DisplayMemberBinding="{Binding Status}" />
                </GridView>
            </ListView.View>
        </ListView>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <Button DockPanel.Dock="Right" Name="btnOk" Content="Use this certificate"
                    Width="160" Height="32" FontWeight="Bold" Margin="8,0,0,0"
                    Background="{StaticResource Accent}" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="btnOk_Click" />
            <Button DockPanel.Dock="Right" Name="btnClear" Content="Turn signing off"
                    Width="120" Height="32" Margin="8,0,0,0" Cursor="Hand" Click="btnClear_Click" />
            <Button DockPanel.Dock="Right" Name="btnRefresh" Content="Refresh"
                    Width="90" Height="32" Cursor="Hand" Click="btnRefresh_Click" />
            <TextBlock Name="txtHint" VerticalAlignment="Center" Foreground="#888" FontSize="12" TextWrapping="Wrap" />
        </DockPanel>
    </Grid>
</Window>
