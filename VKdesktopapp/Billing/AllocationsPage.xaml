<Page x:Class="CRMRSDesktopApp.Billing.AllocationsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F5F5">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <Button Content="&#8592; Back" Width="80" Height="30" Click="btnBack_Click" HorizontalAlignment="Left" />
            <TextBlock Text="Allocations — Billing Members" FontSize="18" FontWeight="Bold"
                       Foreground="#00897B" Margin="14,0,0,0" VerticalAlignment="Center" />
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="12" Margin="0,0,14,0"
                    BorderBrush="#E0E0E0" BorderThickness="1">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="Members" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" />
                        <Button DockPanel.Dock="Right" Content="+ New" Width="70" Height="28" Click="btnNew_Click" />
                    </DockPanel>
                    <TextBlock DockPanel.Dock="Bottom" Name="txtListStatus" FontSize="11" Foreground="#888" Margin="0,6,0,0" />
                    <ListView Name="lstMembers" SelectionChanged="lstMembers_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="130" DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Header="Username" Width="110" DisplayMemberBinding="{Binding Username}" />
                                <GridViewColumn Header="Finances" Width="70" DisplayMemberBinding="{Binding FinanceCount}" />
                                <GridViewColumn Header="Active" Width="55" DisplayMemberBinding="{Binding ActiveText}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18,14">
                    <StackPanel>
                        <TextBlock Name="txtFormTitle" Text="New Member" FontWeight="Bold" FontSize="15" Foreground="#00897B" Margin="0,0,0,10" />
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Member Name" Foreground="#666" FontSize="12" /><TextBox Name="txtName" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Mobile Number" Foreground="#666" FontSize="12" /><TextBox Name="txtMobile" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Email" Foreground="#666" FontSize="12" /><TextBox Name="txtEmail" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><CheckBox Name="chkActive" Content="Active" IsChecked="True" Margin="0,20,0,0" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Username" Foreground="#666" FontSize="12" /><TextBox Name="txtUsername" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Password" Foreground="#666" FontSize="12" /><TextBox Name="txtPassword" Height="30" /></StackPanel>
                        </UniformGrid>

                        <TextBlock Text="Allocated Finances / Head Offices" FontWeight="Bold" Foreground="#00897B" Margin="0,12,0,6" />
                        <TextBlock Text="Members can only see and bill for the finances checked here." FontSize="11" Foreground="#888" Margin="0,0,0,6" />
                        <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Height="240">
                            <ListBox Name="lstFinances" BorderThickness="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsChecked, Mode=TwoWay}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                            <Button Name="btnSave" Content="Save Member" Height="36" Width="150" FontWeight="Bold"
                                    Background="#00897B" Foreground="White" BorderThickness="0" Cursor="Hand" Click="btnSave_Click" />
                            <Button Name="btnDelete" Content="Delete" Height="36" Width="100" Margin="10,0,0,0"
                                    Background="#C62828" Foreground="White" BorderThickness="0" Cursor="Hand" Click="btnDelete_Click" />
                            <TextBlock Name="txtFormStatus" VerticalAlignment="Center" Margin="14,0,0,0" Foreground="#2E7D32" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
