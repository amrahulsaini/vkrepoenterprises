<Window x:Class="CRMRSDesktopApp.Billing.ViewAllDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Repo Submissions — All Details" Height="640" Width="1180"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="True" Background="#F5F5F5">
    <Window.Resources>
        <Style x:Key="CellText" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8,0,8,0" />
            <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="ToolTip" Value="{x:Null}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="GridHeader" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#1565C0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,8,8,8" />
            <Setter Property="BorderBrush" Value="#0D47A1" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
    </Window.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Vehicles submitted OK-for-Repo from the app (your allocated finances only)"
                   FontSize="15" FontWeight="Bold" Foreground="{StaticResource Accent}" Margin="0,0,0,10" />

        <WrapPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="From" VerticalAlignment="Center" Foreground="#666" Margin="0,0,6,0" />
            <DatePicker Name="dpFrom" Width="130" Margin="0,0,14,0" />
            <TextBlock Text="To" VerticalAlignment="Center" Foreground="#666" Margin="0,0,6,0" />
            <DatePicker Name="dpTo" Width="130" Margin="0,0,14,0" />
            <TextBlock Text="Billing" VerticalAlignment="Center" Foreground="#666" Margin="0,0,6,0" />
            <ComboBox Name="cmbAction" Width="140" Margin="0,0,14,0" SelectedIndex="0">
                <ComboBoxItem Content="All" />
                <ComboBoxItem Content="Bill immediately" />
                <ComboBoxItem Content="Hold for billing" />
                <ComboBoxItem Content="Cancel" />
            </ComboBox>
            <TextBlock Text="Status" VerticalAlignment="Center" Foreground="#666" Margin="0,0,6,0" />
            <ComboBox Name="cmbStatus" Width="120" Margin="0,0,14,0" SelectedIndex="0">
                <ComboBoxItem Content="All" />
                <ComboBoxItem Content="Pending" />
                <ComboBoxItem Content="Billed" />
            </ComboBox>
            <Button Name="btnLoad" Content="Load" Width="90" Height="30" FontWeight="Bold"
                    Background="#1565C0" Foreground="White" BorderThickness="0" Cursor="Hand" Click="btnLoad_Click" />
            <TextBlock Name="txtStatus" VerticalAlignment="Center" Foreground="#888" FontSize="12" Margin="14,0,0,0" />
        </WrapPanel>

        <DataGrid Grid.Row="2" Name="grid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="All"
                  RowHeaderWidth="0" SelectionMode="Single" SelectionUnit="CellOrRowHeader"
                  Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                  CanUserResizeColumns="True" CanUserReorderColumns="True" CanUserSortColumns="True"
                  ColumnHeaderStyle="{StaticResource GridHeader}"
                  RowBackground="White" AlternatingRowBackground="#F3F7FB"
                  HorizontalGridLinesBrush="#ECECEC" VerticalGridLinesBrush="#ECECEC"
                  FontSize="12.5" RowHeight="34"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.CanContentScroll="True" EnableRowVirtualization="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding CreatedAt}" Width="120" MinWidth="90" ElementStyle="{StaticResource CellText}" />
                <DataGridTextColumn Header="Vehicle No" Binding="{Binding VehicleNo}" Width="110" MinWidth="80" ElementStyle="{StaticResource CellText}" />
                <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="160" MinWidth="90" ElementStyle="{StaticResource CellText}" />
                <DataGridTextColumn Header="Finance" Binding="{Binding FinanceName}" Width="140" MinWidth="90" ElementStyle="{StaticResource CellText}" />
                <DataGridTextColumn Header="Branch" Binding="{Binding BranchName}" Width="120" MinWidth="80" ElementStyle="{StaticResource CellText}" />
                <DataGridTextColumn Header="Loan No" Binding="{Binding LoanNo}" Width="120" MinWidth="80" ElementStyle="{StaticResource CellText}" />
                <DataGridTextColumn Header="Agent" Binding="{Binding AgentName}" Width="120" MinWidth="80" ElementStyle="{StaticResource CellText}" />
                <DataGridTextColumn Header="Parking Yard" Binding="{Binding ParkingYardName}" Width="130" MinWidth="90" ElementStyle="{StaticResource CellText}" />
                <DataGridTextColumn Header="Addl Amt" Binding="{Binding AddlChargesAmount}" Width="90" MinWidth="70" ElementStyle="{StaticResource CellText}" />
                <DataGridTextColumn Header="Collection Update" Binding="{Binding CollectionUpdate}" Width="160" MinWidth="100" ElementStyle="{StaticResource CellText}" />
                <DataGridTextColumn Header="Remark" Binding="{Binding Remark}" Width="160" MinWidth="100" ElementStyle="{StaticResource CellText}" />
                <DataGridTextColumn Header="Billing" Binding="{Binding ActionText}" Width="130" MinWidth="90" ElementStyle="{StaticResource CellText}" />
                <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="90" MinWidth="70" ElementStyle="{StaticResource CellText}" />
                <DataGridTemplateColumn Header="Action" Width="130" MinWidth="120" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Generate Bill" Height="26" Margin="4,2,4,2" Cursor="Hand"
                                    Background="{StaticResource Accent}" Foreground="White" BorderThickness="0"
                                    Click="btnGenerate_Click" Tag="{Binding Id}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
