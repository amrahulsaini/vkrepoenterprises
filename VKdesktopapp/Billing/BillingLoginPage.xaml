<Page x:Class="CRMRSDesktopApp.Billing.BillingLoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F5F5">
    <Grid>
        <Button Content="&#8592; Back" Width="80" Height="30" Click="btnBack_Click"
                HorizontalAlignment="Left" VerticalAlignment="Top" Margin="18" />
        <Border Background="White" CornerRadius="10" BorderBrush="#E0E0E0" BorderThickness="1"
                Width="380" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Billing Login" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Accent}"
                           HorizontalAlignment="Center" Margin="0,0,0,4" />
                <TextBlock Text="Sign in with the credentials your admin gave you." FontSize="12"
                           Foreground="#888" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,20" />
                <TextBlock Text="Username" Foreground="#666" FontSize="12" Margin="0,0,0,3" />
                <TextBox Name="txtUsername" Height="34" Margin="0,0,0,12" VerticalContentAlignment="Center" />
                <TextBlock Text="Password" Foreground="#666" FontSize="12" Margin="0,0,0,3" />
                <PasswordBox Name="txtPassword" Height="34" Margin="0,0,0,16" VerticalContentAlignment="Center" />
                <Button Name="btnLogin" Content="Log In" Height="40" FontWeight="Bold"
                        Background="{StaticResource Accent}" Foreground="White" BorderThickness="0" Cursor="Hand" Click="btnLogin_Click" />
                <TextBlock Name="txtStatus" Foreground="#C62828" FontSize="12" TextWrapping="Wrap"
                           HorizontalAlignment="Center" Margin="0,12,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
