<Window x:Class="CRMRSDesktopApp.Billing.BillingActionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        FontFamily="{StaticResource FontBody}"
        Title="Change Billing" Height="270" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="ToolWindow" ShowInTaskbar="False" Background="#F5F5F5">
    <StackPanel Margin="22">
        <TextBlock Name="lblWhich" Text="" FontSize="13" Foreground="#666"
                   TextWrapping="Wrap" Margin="0,0,0,14" />

        <RadioButton Name="rbImmediate" Content="OK for billing" GroupName="act"
                     FontSize="14" Margin="0,0,0,10" VerticalContentAlignment="Center" />
        <RadioButton Name="rbHold" Content="Hold for collection" GroupName="act"
                     FontSize="14" Margin="0,0,0,10" VerticalContentAlignment="Center" />
        <RadioButton Name="rbCancel" Content="Cancel" GroupName="act"
                     FontSize="14" Margin="0,0,0,10" VerticalContentAlignment="Center" />

        <TextBlock Name="txtErr" Foreground="#C62828" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" Width="90" Height="34" Margin="0,0,10,0" Click="btnCancel_Click" />
            <Button Name="btnSave" Content="Save" Width="100" Height="34" FontWeight="Bold"
                    Background="{StaticResource Accent}" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="btnSave_Click" IsDefault="True" />
        </StackPanel>
    </StackPanel>
</Window>
