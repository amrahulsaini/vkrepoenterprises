<Window x:Class="CRMRSDesktopApp.Billing.PasswordPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Allocation Password" Height="210" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="ToolWindow" ShowInTaskbar="False" Background="#F5F5F5">
    <StackPanel Margin="24">
        <TextBlock Name="lblTitle" Text="Enter Allocation Password" FontSize="16" FontWeight="Bold"
                   Foreground="{StaticResource Accent}" Margin="0,0,0,4" />
        <TextBlock Name="lblHint" Text="This screen is protected. Enter the allocation password to continue."
                   FontSize="12" Foreground="#888" TextWrapping="Wrap" Margin="0,0,0,14" />
        <PasswordBox Name="pwd" Height="36" FontSize="14" FontWeight="Bold"
                     VerticalContentAlignment="Center" Padding="8,0"
                     BorderBrush="#E0E0E0" BorderThickness="1" Background="White" />
        <TextBlock Name="txtErr" Foreground="#C62828" FontSize="12" Margin="0,6,0,0" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" Width="90" Height="34" Margin="0,0,10,0" Click="btnCancel_Click" />
            <Button Name="btnOk" Content="Open" Width="90" Height="34" FontWeight="Bold"
                    Background="{StaticResource Accent}" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="btnOk_Click" IsDefault="True" />
        </StackPanel>
    </StackPanel>
</Window>
