<Page x:Class="CRMRSDesktopApp.Billing.BillingGatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F5F5">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="640">
            <TextBlock Text="Billing" FontSize="26" FontWeight="Bold" Foreground="#00897B"
                       HorizontalAlignment="Center" Margin="0,0,0,6" />
            <TextBlock Text="Choose what you want to do." FontSize="14" Foreground="#666"
                       HorizontalAlignment="Center" Margin="0,0,0,28" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Name="btnAllocations" Width="290" Height="180" Margin="0,0,20,0"
                        Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Cursor="Hand"
                        Click="btnAllocations_Click">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="&#128101;" FontSize="46" HorizontalAlignment="Center" Margin="0,0,0,10" />
                        <TextBlock Text="Allocations" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#212121" />
                        <TextBlock Text="Create billing members and assign finances (admin)"
                                   FontSize="12" Foreground="#888" TextWrapping="Wrap" TextAlignment="Center" Margin="18,8,18,0" />
                    </StackPanel>
                </Button>
                <Button Name="btnBilling" Width="290" Height="180"
                        Background="White" BorderBrush="#E0E0E0" BorderThickness="1" Cursor="Hand"
                        Click="btnBilling_Click">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="&#129534;" FontSize="46" HorizontalAlignment="Center" Margin="0,0,0,10" />
                        <TextBlock Text="Billing" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#212121" />
                        <TextBlock Text="Log in as a member and generate repossession bills"
                                   FontSize="12" Foreground="#888" TextWrapping="Wrap" TextAlignment="Center" Margin="18,8,18,0" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
