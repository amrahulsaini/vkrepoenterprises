<Page x:Class="CRMRSDesktopApp.Billing.BillingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F5F5">
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="14" Margin="0,0,14,0"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Repossession Bill" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />

                <TextBlock DockPanel.Dock="Top" Text="Head Office (To)" FontSize="12" Foreground="#666" Margin="0,0,0,4" />
                <ComboBox DockPanel.Dock="Top" Name="cmbFinance" Height="30" Margin="0,0,0,12"
                          DisplayMemberPath="Name" SelectionChanged="cmbFinance_SelectionChanged" />

                <TextBlock DockPanel.Dock="Top" Text="Find Vehicle" FontSize="12" Foreground="#666" Margin="0,0,0,4" />
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <RadioButton Name="rbRc" Content="RC (last 4)" IsChecked="True" GroupName="mode" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <RadioButton Name="rbChassis" Content="Chassis (last 5)" GroupName="mode" VerticalAlignment="Center" />
                </StackPanel>
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Button DockPanel.Dock="Right" Name="btnSearch" Content="Search" Width="72" Height="30"
                            Margin="8,0,0,0" Click="btnSearch_Click" />
                    <TextBox Name="txtVehSearch" Height="30" VerticalContentAlignment="Center"
                             KeyDown="txtVehSearch_KeyDown" />
                </DockPanel>

                <TextBlock DockPanel.Dock="Bottom" Name="txtSearchStatus" FontSize="11" Foreground="#888" Margin="0,6,0,0" />
                <ListBox Name="lstResults" SelectionChanged="lstResults_SelectionChanged"
                         DisplayMemberPath="VehicleNo" />
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
            <DockPanel>
                <Border DockPanel.Dock="Bottom" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="14,10">
                    <DockPanel>
                        <TextBlock Name="txtGenStatus" VerticalAlignment="Center" Foreground="#2E7D32" FontSize="12" />
                        <Button DockPanel.Dock="Right" Name="btnGenerate" Content="Generate Bill (PDF)"
                                Height="38" Width="180" FontWeight="Bold" Background="#00897B" Foreground="White"
                                BorderThickness="0" Cursor="Hand" Click="btnGenerate_Click" />
                    </DockPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="INVOICE" FontWeight="Bold" Foreground="#00897B" Margin="0,0,0,6" />
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Invoice Date" Foreground="#666" FontSize="12" /><TextBox Name="txtInvoiceDate" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Invoice No" Foreground="#666" FontSize="12" /><TextBox Name="txtInvoiceNo" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Branch" Foreground="#666" FontSize="12" /><TextBox Name="txtBranch" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Confirmation By" Foreground="#666" FontSize="12" /><TextBox Name="txtConfirmationBy" Height="30" /></StackPanel>
                        </UniformGrid>

                        <TextBlock Text="VEHICLE (auto-filled)" FontWeight="Bold" Foreground="#00897B" Margin="0,10,0,6" />
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Agri-Loan No" Foreground="#666" FontSize="12" /><TextBox Name="txtAgriLoan" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Name of Customer" Foreground="#666" FontSize="12" /><TextBox Name="txtCustomer" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Make-Model" Foreground="#666" FontSize="12" /><TextBox Name="txtMakeModel" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="RC No" Foreground="#666" FontSize="12" /><TextBox Name="txtRcNo" Height="30" /></StackPanel>
                        </UniformGrid>

                        <TextBlock Text="REPOSSESSION" FontWeight="Bold" Foreground="#00897B" Margin="0,10,0,6" />
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Date of Repossession" Foreground="#666" FontSize="12" /><TextBox Name="txtDateRepo" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Parking Yard Name" Foreground="#666" FontSize="12" /><TextBox Name="txtParkingYard" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Enclosed" Foreground="#666" FontSize="12" /><TextBox Name="txtEnclosed" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Qty" Foreground="#666" FontSize="12" /><TextBox Name="txtQty" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Repo Charges (in words)" Foreground="#666" FontSize="12" /><TextBox Name="txtRepoWords" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Repo Charges (amount)" Foreground="#666" FontSize="12" /><TextBox Name="txtRepoAmount" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Additional Charges" Foreground="#666" FontSize="12" /><TextBox Name="txtAddlCharges" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8" />
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Total Gross (in words)" Foreground="#666" FontSize="12" /><TextBox Name="txtTotalWords" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Total Gross (amount)" Foreground="#666" FontSize="12" /><TextBox Name="txtTotalAmount" Height="30" /></StackPanel>
                        </UniformGrid>

                        <TextBlock Text="AGENCY &amp; BANK (saved)" FontWeight="Bold" Foreground="#00897B" Margin="0,10,0,6" />
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Agency Name" Foreground="#666" FontSize="12" /><TextBox Name="txtAgencyName" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Header Address" Foreground="#666" FontSize="12" /><TextBox Name="txtHeaderAddress" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Header Contact" Foreground="#666" FontSize="12" /><TextBox Name="txtHeaderContact" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Header Email" Foreground="#666" FontSize="12" /><TextBox Name="txtHeaderEmail" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="PAN No" Foreground="#666" FontSize="12" /><TextBox Name="txtPan" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="GST State" Foreground="#666" FontSize="12" /><TextBox Name="txtGst" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Bank Account Name" Foreground="#666" FontSize="12" /><TextBox Name="txtBankAcName" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Account No" Foreground="#666" FontSize="12" /><TextBox Name="txtAccountNo" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="IFSC Code" Foreground="#666" FontSize="12" /><TextBox Name="txtIfsc" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Bank Branch" Foreground="#666" FontSize="12" /><TextBox Name="txtBankBranch" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Pay In The Name Of" Foreground="#666" FontSize="12" /><TextBox Name="txtPaymentName" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Footer Line" Foreground="#666" FontSize="12" /><TextBox Name="txtFooter" Height="30" /></StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Page>
