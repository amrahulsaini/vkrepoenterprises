<Page x:Class="CRMRSDesktopApp.Billing.BillingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F5F5">
    <Page.Resources>
        <Style TargetType="TextBox">
            <Setter Property="CharacterCasing" Value="Upper" />
        </Style>
    </Page.Resources>
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="14" Margin="0,0,14,0"
                BorderBrush="#E0E0E0" BorderThickness="1">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <Button DockPanel.Dock="Right" Name="btnViewAll" Content="View All Details"
                            Height="30" Padding="12,0" FontWeight="Bold"
                            Background="#1565C0" Foreground="White" BorderThickness="0" Cursor="Hand" Click="btnViewAll_Click" />
                    <TextBlock Text="Repossession Bill" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                </DockPanel>

                <TextBlock DockPanel.Dock="Top" Text="Finance / Bank Name (To)" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Accent}" Margin="0,0,0,4" />
                <ComboBox DockPanel.Dock="Top" Name="cmbFinance" Height="32" Margin="0,0,0,12"
                          DisplayMemberPath="Name" SelectionChanged="cmbFinance_SelectionChanged" />

                <TextBlock DockPanel.Dock="Top" Text="Letterhead Image (for this finance)" FontSize="12" Foreground="#666" Margin="0,0,0,4" />
                <Border DockPanel.Dock="Top" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Height="56" Margin="0,0,0,4">
                    <Image Name="imgLetterhead" Stretch="Uniform" Margin="3" />
                </Border>
                <Button DockPanel.Dock="Top" Name="btnLetterhead" Content="Upload Letterhead" Height="28" Margin="0,0,0,10" Click="btnLetterhead_Click" />

                <TextBlock DockPanel.Dock="Top" Text="Background / Template Image (for this finance)" FontSize="12" Foreground="#666" Margin="0,0,0,4" />
                <Border DockPanel.Dock="Top" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Height="56" Margin="0,0,0,4">
                    <Image Name="imgBackground" Stretch="Uniform" Margin="3" />
                </Border>
                <Button DockPanel.Dock="Top" Name="btnBackground" Content="Upload Background" Height="28" Margin="0,0,0,12" Click="btnBackground_Click" />

                <TextBlock DockPanel.Dock="Top" Text="Digital Signature (DSC token)" FontSize="12" Foreground="#666" Margin="0,0,0,4" />
                <CheckBox DockPanel.Dock="Top" Name="chkSign" Content="Also make a signed PDF" Margin="0,0,0,6"
                          VerticalContentAlignment="Center" Checked="chkSign_Changed" Unchecked="chkSign_Changed" />
                <Button DockPanel.Dock="Top" Name="btnSignCert" Content="Select Certificate" Height="28" Margin="0,0,0,4" Click="btnSignCert_Click" />
                <TextBlock DockPanel.Dock="Top" Name="txtCertStatus" FontSize="11" Foreground="#888" TextWrapping="Wrap" Margin="0,0,0,6" />

                <TextBlock DockPanel.Dock="Top" Name="txtSigPosHint" Text="Signature box in points, from the bottom-left of the page"
                           FontSize="11" Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,3" />
                <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition /><ColumnDefinition /><ColumnDefinition /><ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                        <TextBlock Text="X (from left)" FontSize="10" Foreground="#888" /><TextBox Name="txtSigX" Height="26" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,4,0">
                        <TextBlock Text="Y (from bottom)" FontSize="10" Foreground="#888" /><TextBox Name="txtSigY" Height="26" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,4,0">
                        <TextBlock Text="Width" FontSize="10" Foreground="#888" /><TextBox Name="txtSigW" Height="26" />
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Height" FontSize="10" Foreground="#888" /><TextBox Name="txtSigH" Height="26" />
                    </StackPanel>
                </Grid>
                <Button DockPanel.Dock="Top" Name="btnSigReset" Content="Reset to bottom-right" Height="24" FontSize="11" Margin="0,0,0,12" Click="btnSigReset_Click" />

                <TextBlock DockPanel.Dock="Top" Text="Find Vehicle (in this finance)" FontSize="12" Foreground="#666" Margin="0,0,0,4" />
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                    <RadioButton Name="rbRc" Content="RC (last 4)" IsChecked="True" GroupName="mode" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <RadioButton Name="rbChassis" Content="Chassis (last 5)" GroupName="mode" VerticalAlignment="Center" />
                </StackPanel>
                <TextBox DockPanel.Dock="Top" Name="txtVehSearch" Height="32" Margin="0,0,0,6"
                         VerticalContentAlignment="Center" FontWeight="Bold"
                         TextChanged="txtVehSearch_TextChanged" KeyDown="txtVehSearch_KeyDown" />

                <TextBlock DockPanel.Dock="Bottom" Name="txtSearchStatus" FontSize="11" Foreground="#888" Margin="0,6,0,0" />
                <ListView Name="lstResults" SelectionChanged="lstResults_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Vehicle No" Width="110" DisplayMemberBinding="{Binding VehicleNo}" />
                            <GridViewColumn Header="Model" Width="100" DisplayMemberBinding="{Binding Model}" />
                            <GridViewColumn Header="Branch" Width="110" DisplayMemberBinding="{Binding BranchName}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1">
            <DockPanel>
                <Border DockPanel.Dock="Bottom" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="14,10">
                    <DockPanel>
                        <Button DockPanel.Dock="Left" Name="btnBack" Content="&#8592; Back" Height="38" Width="80"
                                Margin="0,0,10,0" Click="btnBack_Click" />
                        <TextBlock Name="txtGenStatus" VerticalAlignment="Center" Foreground="#2E7D32" FontSize="12" />
                        <Button DockPanel.Dock="Right" Name="btnGenerate" Content="Generate Bill (DOCX)"
                                Height="38" Width="190" FontWeight="Bold" Background="{StaticResource Accent}" Foreground="White"
                                BorderThickness="0" Cursor="Hand" Click="btnGenerate_Click" />
                    </DockPanel>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="INVOICE" FontWeight="Bold" Foreground="{StaticResource Accent}" Margin="0,0,0,6" />
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="To (Bank / Head Office)" Foreground="#666" FontSize="12" /><TextBox Name="txtBankTo" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Invoice Date" Foreground="#666" FontSize="12" /><TextBox Name="txtInvoiceDate" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Invoice No (auto)" Foreground="#666" FontSize="12" /><TextBox Name="txtInvoiceNo" Height="30" IsReadOnly="True" Background="#F3F3F3" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Branch" Foreground="#666" FontSize="12" /><TextBox Name="txtBranch" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Confirmation By" Foreground="#666" FontSize="12" /><TextBox Name="txtConfirmationBy" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8" />
                        </UniformGrid>

                        <TextBlock Text="VEHICLE (auto-filled)" FontWeight="Bold" Foreground="{StaticResource Accent}" Margin="0,10,0,6" />
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Agri-Loan No" Foreground="#666" FontSize="12" /><TextBox Name="txtAgriLoan" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Name of Customer" Foreground="#666" FontSize="12" /><TextBox Name="txtCustomer" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Make-Model" Foreground="#666" FontSize="12" /><TextBox Name="txtMakeModel" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="RC No" Foreground="#666" FontSize="12" /><TextBox Name="txtRcNo" Height="30" /></StackPanel>
                        </UniformGrid>

                        <TextBlock Text="REPOSSESSION" FontWeight="Bold" Foreground="{StaticResource Accent}" Margin="0,10,0,6" />
                        <UniformGrid Columns="3">
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Date of Repossession" Foreground="#666" FontSize="12" /><TextBox Name="txtDateRepo" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Parking Yard Name" Foreground="#666" FontSize="12" /><TextBox Name="txtParkingYard" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Enclosed" Foreground="#666" FontSize="12" /><TextBox Name="txtEnclosed" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Qty" Foreground="#666" FontSize="12" /><TextBox Name="txtQty" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Additional Charges Notes" Foreground="#666" FontSize="12" /><TextBox Name="txtAddlCharges" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Additional Charges Amount" Foreground="#666" FontSize="12" /><TextBox Name="txtAddlAmount" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Repo Charges (in words)" Foreground="#666" FontSize="12" /><TextBox Name="txtRepoWords" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Repo Charges (amount)" Foreground="#666" FontSize="12" /><TextBox Name="txtRepoAmount" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8" />
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Total Gross (in words)" Foreground="#666" FontSize="12" /><TextBox Name="txtTotalWords" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Total Gross (amount)" Foreground="#666" FontSize="12" /><TextBox Name="txtTotalAmount" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8" />
                        </UniformGrid>

                        <TextBlock Text="REPO SUBMISSION DETAILS" FontWeight="Bold" Foreground="{StaticResource Accent}" Margin="0,10,0,6" />
                        <UniformGrid Columns="3">
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Agent Name" Foreground="#666" FontSize="12" /><TextBox Name="txtAgentName" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Parking Yard Mobile" Foreground="#666" FontSize="12" /><TextBox Name="txtParkingYardMobile" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Load Details" Foreground="#666" FontSize="12" /><TextBox Name="txtLoadDetails" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Confirmation By (Mobile)" Foreground="#666" FontSize="12" /><TextBox Name="txtConfirmationByMobile" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Executive Name" Foreground="#666" FontSize="12" /><TextBox Name="txtExecutiveName" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Collection Update" Foreground="#666" FontSize="12" /><TextBox Name="txtCollectionUpdate" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Remark" Foreground="#666" FontSize="12" /><TextBox Name="txtRemark" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8" />
                            <StackPanel Margin="0,0,0,8" />
                        </UniformGrid>

                        <TextBlock Text="AGENCY &amp; BANK" FontWeight="Bold" Foreground="{StaticResource Accent}" Margin="0,10,0,6" />
                        <UniformGrid Columns="3">
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Name of Agency" Foreground="#666" FontSize="12" /><TextBox Name="txtAgencyRealName" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Vendor Code" Foreground="#666" FontSize="12" /><TextBox Name="txtAgencyName" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="PAN No" Foreground="#666" FontSize="12" /><TextBox Name="txtPan" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="GST State" Foreground="#666" FontSize="12" /><TextBox Name="txtGst" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Bank Account Name" Foreground="#666" FontSize="12" /><TextBox Name="txtAcHolder" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Account No" Foreground="#666" FontSize="12" /><TextBox Name="txtAccountNo" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="IFSC Code" Foreground="#666" FontSize="12" /><TextBox Name="txtIfsc" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Bank Branch" Foreground="#666" FontSize="12" /><TextBox Name="txtBankBranch" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,8,8"><TextBlock Text="Pay In The Name Of" Foreground="#666" FontSize="12" /><TextBox Name="txtPaymentName" Height="30" /></StackPanel>
                            <StackPanel Margin="0,0,0,8"><TextBlock Text="Footer Line" Foreground="#666" FontSize="12" /><TextBox Name="txtFooter" Height="30" /></StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Page>
