<Window x:Class="VRASDesktopApp.Finances.NewFinanceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Finance"
        Height="230" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource ChromeWindow}"
        Background="{StaticResource Gray50}"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource Gray100}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="20,0">
                <Button DockPanel.Dock="Right"
                        Content="&#xE8BB;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="13"
                        Width="32" Height="32"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource Gray400}"
                        Cursor="Hand"
                        Click="btnCancel_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True" />
                <TextBlock Text="New Finance / Head Office"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource Gray900}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Form -->
        <Grid Grid.Row="1" Margin="20,18,20,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="FINANCE NAME"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource Gray500}" />

            <Border Grid.Row="2"
                    BorderBrush="{StaticResource Gray300}"
                    BorderThickness="1"
                    CornerRadius="7"
                    Background="White">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Orange500}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBox x:Name="txtName"
                         Padding="12,11"
                         FontSize="15"
                         BorderThickness="0"
                         Background="Transparent"
                         VerticalAlignment="Center"
                         KeyDown="txtName_KeyDown">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="Transparent">
                                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="{StaticResource Gray100}"
                BorderThickness="0,1,0,0"
                Padding="20,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnCancel"
                        Content="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Width="90" Height="36"
                        Margin="0,0,10,0"
                        Click="btnCancel_Click" />
                <Button x:Name="btnSave"
                        Content="Create"
                        Style="{StaticResource PrimaryButton}"
                        Width="110" Height="36"
                        Click="btnSave_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
