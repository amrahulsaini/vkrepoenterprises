<Window
    x:Class="VRASDesktopApp.Finances.BranchDialogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="clr-namespace:VRASDesktopApp.Material"
    FontFamily="Segoe UI"
    Style="{StaticResource ChromeWindow}"
    Title="Branches"
    Height="640"
    Width="480"
    WindowStartupLocation="CenterOwner"
    Loaded="Window_Loaded"
    PreviewKeyDown="Window_PreviewKeyDown">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Margin="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Text="SELECT BRANCH"
                Style="{StaticResource Heading5}"
                VerticalAlignment="Center"
                Padding="16,0,16,0" />
            <Button
                Click="btnClose_Click"
                Grid.Column="1"
                Height="36"
                Width="36"
                Background="#FFD3D3D3"
                BorderBrush="#FFD3D3D3"
                Foreground="#FF000000"
                FontFamily="Segoe UI"
                FontSize="16"
                FontWeight="Bold"
                Content="✕"
                Padding="0"
                WindowChrome.IsHitTestVisibleInChrome="True" />
        </Grid>
        <Grid Grid.Row="2" Margin="16,8">
            <TextBlock
                x:Name="lblTerm_Placeholder"
                Text="Find branch"
                VerticalAlignment="Center"
                Padding="8,0"
                Opacity="0.67"
                FontSize="14" />
            <TextBox
                x:Name="txtTerm"
                Background="#00FFFFFF"
                TextChanged="txtTerm_TextChanged" />
        </Grid>
        <DataGrid
            x:Name="dgList"
            Grid.Row="3"
            Background="#FFF"
            BorderBrush="#00FFFFFF"
            CanUserAddRows="False"
            AutoGenerateColumns="False"
            HeadersVisibility="None"
            IsReadOnly="True"
            SelectionMode="Single"
            GridLinesVisibility="Horizontal"
            HorizontalGridLinesBrush="{StaticResource Gray200}">
            <DataGrid.CellStyle>
                <Style TargetType="{x:Type DataGridCell}">
                    <Setter Property="Height" Value="32" />
                    <Setter Property="Foreground" Value="#FF000000" />
                    <Setter Property="Background" Value="#FFFFFFFF" />
                    <Style.Triggers>
                        <Trigger Property="DataGridCell.IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource HighlightBackgroundBrush}" />
                            <Setter Property="Foreground" Value="#FF000000" />
                            <Setter Property="BorderBrush" Value="{StaticResource HighlightBackgroundBrush}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.Columns>
                    <DataGridTextColumn Width="*" Header="Branch name" Binding="{Binding BranchName}">
                    <DataGridBoundColumn.ElementStyle>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="TextBlock.Padding" Value="16,0,8,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="FontWeight" Value="Medium" />
                            <Setter Property="FontSize" Value="15" />
                            <Setter Property="TextWrapping" Value="Wrap" />
                        </Style>
                    </DataGridBoundColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
