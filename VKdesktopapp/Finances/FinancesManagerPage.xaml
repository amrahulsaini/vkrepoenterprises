<Page
    x:Class="VRASDesktopApp.Finances.FinancesManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource Gray50}"
    FontFamily="Segoe UI"
    Loaded="Page_Loaded">

    <Page.Resources>

        <!-- Orange "+" circle button -->
        <Style x:Key="PlusIconButton" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="brd"
                                Background="{StaticResource Orange500}"
                                CornerRadius="16"
                                Width="32" Height="32">
                            <TextBlock Text="+"
                                       FontSize="22" FontWeight="Light"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,-2,0,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="{StaticResource Orange600}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="{StaticResource Orange700}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Row: no hover color, subtle selected highlight -->
        <Style x:Key="GridRowStyle" TargetType="DataGridRow">
            <Setter Property="Height" Value="46" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource Primary100}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Cell: fully transparent — row background shows through, no fading -->
        <Style x:Key="GridCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="Transparent"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource Gray900}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Column header -->
        <Style x:Key="ColHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Height" Value="42" />
            <Setter Property="Background" Value="{StaticResource Gray50}" />
            <Setter Property="Foreground" Value="{StaticResource Gray600}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,0,6,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource Gray200}"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search TextBox -->
        <Style x:Key="InlineTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="0,8" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="Transparent">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Shared row cell text style -->
        <Style x:Key="CellText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource Gray800}" />
        </Style>

        <!-- Muted secondary cell text -->
        <Style x:Key="CellTextMuted" TargetType="TextBlock" BasedOn="{StaticResource CellText}">
            <Setter Property="Foreground" Value="{StaticResource Gray500}" />
        </Style>

        <!-- Outline button used for View All -->
        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource Orange500}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource Orange500}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="brd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#1AFF9800" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="brd" Property="Background" Value="#30FF9800" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid Margin="24,20,24,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="HEAD OFFICES" Style="{StaticResource Heading4}" FontWeight="Bold" />
            <TextBlock Text="Manage head offices and their finances"
                       Style="{StaticResource Caption}" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Two-column layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT — Finance list -->
            <Border Grid.Column="0" Style="{StaticResource DashboardCard}" Padding="0">
                <DockPanel LastChildFill="True">

                    <Border DockPanel.Dock="Top"
                            Background="White"
                            BorderBrush="{StaticResource Gray100}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="8,8,0,0"
                            Padding="16,14">
                        <DockPanel LastChildFill="True">
                            <Button Name="btnAddFinance"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource PlusIconButton}"
                                    ToolTip="New Finance"
                                    Click="btnAddFinance_Click" />
                            <Button Name="btnViewAll"
                                    DockPanel.Dock="Right"
                                    Margin="0,0,10,0"
                                    Content="View All"
                                    Style="{StaticResource OutlineButton}"
                                    ToolTip="Show all branches across all finances"
                                    Click="btnViewAll_Click" />
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="HEAD OFFICES"
                                           Style="{StaticResource Heading6}"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center" />
                                <Grid x:Name="financeSpinner"
                                      Visibility="Collapsed"
                                      Width="16" Height="16"
                                      Margin="8,0,0,0"
                                      VerticalAlignment="Center">
                                    <Ellipse Stroke="{StaticResource Gray200}" StrokeThickness="2.5" />
                                    <Ellipse Stroke="{StaticResource Orange500}"
                                             StrokeThickness="2.5"
                                             StrokeDashArray="4 13"
                                             RenderTransformOrigin="0.5,0.5">
                                        <Ellipse.RenderTransform>
                                            <RotateTransform x:Name="financeSpinnerRt" />
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                </Grid>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Search box -->
                    <Border DockPanel.Dock="Top"
                            Margin="14,12,14,4"
                            Background="White"
                            BorderBrush="{StaticResource Gray200}"
                            BorderThickness="1"
                            CornerRadius="7">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Foreground="{StaticResource Gray400}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,6,0" />
                            <Grid Grid.Column="1">
                                <TextBox Name="txtSearch"
                                         Style="{StaticResource InlineTextBox}"
                                         TextChanged="txtSearch_TextChanged" />
                                <TextBlock Text="Search finances..."
                                           FontSize="14"
                                           Foreground="{StaticResource Gray400}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- DataGrid -->
                    <Grid Margin="14,6,14,14">
                        <DataGrid Name="dgFinances"
                                  Style="{StaticResource MaterialDataGrid}"
                                  AutoGenerateColumns="False"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  IsReadOnly="True"
                                  RowStyle="{StaticResource GridRowStyle}"
                                  CellStyle="{StaticResource GridCellStyle}"
                                  ColumnHeaderStyle="{StaticResource ColHeaderStyle}"
                                  SelectionChanged="dgFinances_SelectionChanged"
                                  ContextMenuOpening="dgFinances_ContextMenuOpening"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  EnableRowVirtualization="True"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{StaticResource Gray100}">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Edit Finance" Click="FinanceEdit_Click" />
                                    <MenuItem Header="Download All Records" Click="FinanceDownloadAll_Click" />
                                    <Separator />
                                    <MenuItem Header="Delete Finance" Foreground="#C0392B" Click="FinanceDelete_Click" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Head Office Name"
                                                    Binding="{Binding Name}"
                                                    Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CellText}">
                                            <Setter Property="FontWeight" Value="Bold" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Finances"
                                                    Binding="{Binding BranchCount}"
                                                    Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CellTextMuted}" />
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                    </Grid>
                </DockPanel>
            </Border>

            <!-- RIGHT — Branch list -->
            <Border Grid.Column="2" Style="{StaticResource DashboardCard}" Padding="0">
                <DockPanel LastChildFill="True">

                    <Border DockPanel.Dock="Top"
                            Background="White"
                            BorderBrush="{StaticResource Gray100}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="8,8,0,0"
                            Padding="16,14">
                        <DockPanel LastChildFill="True">
                            <Button Name="btnAddBranch"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource PlusIconButton}"
                                    ToolTip="New Branch"
                                    Click="btnAddBranch_Click" />
                            <StackPanel VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="FINANCES"
                                               Style="{StaticResource Heading6}"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                    <Grid x:Name="branchSpinner"
                                          Visibility="Collapsed"
                                          Width="16" Height="16"
                                          Margin="8,0,0,0"
                                          VerticalAlignment="Center">
                                        <Ellipse Stroke="{StaticResource Gray200}" StrokeThickness="2.5" />
                                        <Ellipse Stroke="{StaticResource Orange500}"
                                                 StrokeThickness="2.5"
                                                 StrokeDashArray="4 13"
                                                 RenderTransformOrigin="0.5,0.5">
                                            <Ellipse.RenderTransform>
                                                <RotateTransform x:Name="branchSpinnerRt" />
                                            </Ellipse.RenderTransform>
                                        </Ellipse>
                                    </Grid>
                                </StackPanel>
                                <TextBlock Name="txtBranchSubtitle"
                                           Text="Select a head office to view finances"
                                           Style="{StaticResource Caption}"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Branch search box -->
                    <Border DockPanel.Dock="Top"
                            Margin="14,12,14,4"
                            Background="White"
                            BorderBrush="{StaticResource Gray200}"
                            BorderThickness="1"
                            CornerRadius="7">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="&#xE721;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Foreground="{StaticResource Gray400}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,6,0" />
                            <Grid Grid.Column="1">
                                <TextBox Name="txtBranchSearch"
                                         Style="{StaticResource InlineTextBox}"
                                         TextChanged="txtBranchSearch_TextChanged" />
                                <TextBlock Text="Search branches..."
                                           FontSize="14"
                                           Foreground="{StaticResource Gray400}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=txtBranchSearch}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Margin="14,6,14,14">
                        <DataGrid Name="dgBranches"
                                  Style="{StaticResource MaterialDataGrid}"
                                  AutoGenerateColumns="False"
                                  SelectionUnit="FullRow"
                                  IsReadOnly="True"
                                  RowStyle="{StaticResource GridRowStyle}"
                                  CellStyle="{StaticResource GridCellStyle}"
                                  ColumnHeaderStyle="{StaticResource ColHeaderStyle}"
                                  ContextMenuOpening="dgBranches_ContextMenuOpening"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  EnableRowVirtualization="True"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{StaticResource Gray100}">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Edit Branch" Click="BranchEdit_Click" />
                                    <MenuItem Header="Download Records" Click="BranchDownload_Click" />
                                    <MenuItem Header="Clear All Records" Foreground="#E67E22" Click="BranchClearRecords_Click" />
                                    <Separator />
                                    <MenuItem Header="Delete Branch" Foreground="#C0392B" Click="BranchDelete_Click" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Finance Name"
                                                    Binding="{Binding BranchName}"
                                                    Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CellText}">
                                            <Setter Property="FontWeight" Value="Bold" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Uploaded"
                                                    Binding="{Binding UpdatedOn}"
                                                    Width="145">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CellTextMuted}" />
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Records"
                                                    Binding="{Binding Records}"
                                                    Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource CellTextMuted}" />
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                    </Grid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
