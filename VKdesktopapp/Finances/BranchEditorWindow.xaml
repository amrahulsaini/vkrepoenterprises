<Window x:Class="VRASDesktopApp.Finances.BranchEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Branch" Height="490" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource ChromeWindow}"
        Background="{StaticResource Gray50}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Focusable input border -->
        <Style x:Key="InputBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource Gray300}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Background" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Orange500}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Clean TextBox inside InputBorder -->
        <Style x:Key="CleanTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="Transparent">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ReadOnly variant -->
        <Style x:Key="CleanTextBoxReadOnly" TargetType="TextBox" BasedOn="{StaticResource CleanTextBox}">
            <Setter Property="Foreground" Value="{StaticResource Gray500}" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- Field label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Gray500}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource Gray100}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="20,0">
                <Button DockPanel.Dock="Right"
                        Content="&#xE8BB;"
                        FontFamily="Segoe MDL2 Assets"
                        FontSize="14"
                        Width="32" Height="32"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource Gray400}"
                        Cursor="Hand"
                        Click="btnCancel_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True" />
                <TextBlock x:Name="txtTitle"
                           Text="Add Branch"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource Gray900}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Form body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,12">

                <!-- Branch name first (top) -->
                <TextBlock Text="FINANCE NAME *" Style="{StaticResource FieldLabel}" />
                <Border Style="{StaticResource InputBorder}" Margin="0,0,0,16">
                    <TextBox x:Name="txtBranchName"
                             Style="{StaticResource CleanTextBox}"
                             FontWeight="Bold"
                             CharacterCasing="Upper" />
                </Border>

                <!-- Head Office (read-only) — moved below branch name -->
                <TextBlock Text="HEAD OFFICE" Style="{StaticResource FieldLabel}" />
                <Border Style="{StaticResource InputBorder}" Margin="0,0,0,16"
                        Background="{StaticResource Gray50}">
                    <TextBox x:Name="txtFinanceName"
                             Style="{StaticResource CleanTextBoxReadOnly}"
                             FontWeight="Bold"
                             IsReadOnly="True" />
                </Border>

                <!-- Contacts row -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CONTACT 1" Style="{StaticResource FieldLabel}" />
                        <Border Style="{StaticResource InputBorder}">
                            <TextBox x:Name="txtContact1" Style="{StaticResource CleanTextBox}" />
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="CONTACT 2" Style="{StaticResource FieldLabel}" />
                        <Border Style="{StaticResource InputBorder}">
                            <TextBox x:Name="txtContact2" Style="{StaticResource CleanTextBox}" />
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="CONTACT 3" Style="{StaticResource FieldLabel}" />
                        <Border Style="{StaticResource InputBorder}">
                            <TextBox x:Name="txtContact3" Style="{StaticResource CleanTextBox}" />
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Branch code -->
                <TextBlock Text="BRANCH CODE" Style="{StaticResource FieldLabel}" />
                <Border Style="{StaticResource InputBorder}" Margin="0,0,0,16">
                    <TextBox x:Name="txtBranchCode" Style="{StaticResource CleanTextBox}" />
                </Border>

                <!-- Address -->
                <TextBlock Text="ADDRESS / NOTES" Style="{StaticResource FieldLabel}" />
                <Border Style="{StaticResource InputBorder}" Margin="0,0,0,4">
                    <TextBox x:Name="txtAddress"
                             Style="{StaticResource CleanTextBox}"
                             Height="72"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top" />
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="{StaticResource Gray100}"
                BorderThickness="0,1,0,0"
                Padding="20,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnCancel"
                        Content="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Width="100" Height="38"
                        Margin="0,0,10,0"
                        Click="btnCancel_Click" />
                <Button x:Name="btnSave"
                        Content="Save Branch"
                        Style="{StaticResource PrimaryButton}"
                        Width="130" Height="38"
                        Click="btnSave_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
