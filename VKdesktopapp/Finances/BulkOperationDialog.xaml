<Window x:Class="VRASDesktopApp.Finances.BulkOperationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Processing"
        Height="190" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Style="{StaticResource ChromeWindow}"
        Background="{StaticResource Gray50}"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource Gray100}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="20,0">
                <TextBlock Text="Processing"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource Gray900}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="20,18,20,14" VerticalAlignment="Center">
            <TextBlock x:Name="txtStatus"
                       FontSize="13"
                       Foreground="{StaticResource Gray700}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,14"/>
            <ProgressBar IsIndeterminate="True"
                         Height="5"
                         Background="{StaticResource Gray100}"
                         Foreground="{StaticResource Orange500}"
                         BorderThickness="0"/>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="{StaticResource Gray100}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <Button x:Name="btnBackground"
                    Content="Run in Background"
                    Style="{StaticResource SecondaryButton}"
                    Height="34"
                    HorizontalAlignment="Right"
                    Padding="16,0"
                    Click="btnBackground_Click" />
        </Border>
    </Grid>
</Window>
