<Page
    x:Class="VRASDesktopApp.Utilities.OtpManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource Gray50}"
    FontFamily="Segoe UI"
    Loaded="Page_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{StaticResource DashboardCard}">
            <StackPanel>
                <TextBlock Text="OTP RECORDS" Style="{StaticResource Heading4}" />
                <TextBlock Text="Recent OTP activity visible from the live MongoDB user collections."
                           Margin="0,6,0,0"
                           Style="{StaticResource Caption}" />
            </StackPanel>
        </Border>
        <UniformGrid Grid.Row="1" Columns="3" Margin="0,18,0,18">
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="TOTAL OTPS" Style="{StaticResource FormHeading}" /><TextBlock Name="lblOtps" Style="{StaticResource StatValue}" Text="0" /></StackPanel></Border>
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="USERS" Style="{StaticResource FormHeading}" /><TextBlock Name="lblUsers" Style="{StaticResource StatValue}" Text="0" /></StackPanel></Border>
            <Border Style="{StaticResource DashboardCard}"><StackPanel><TextBlock Text="LAST 24H" Style="{StaticResource FormHeading}" /><TextBlock Name="lblRecent" Style="{StaticResource StatValue}" Text="0" /></StackPanel></Border>
        </UniformGrid>
        <Border Grid.Row="2" Style="{StaticResource DashboardCard}">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <TextBlock Text="OTP TIMELINE" Style="{StaticResource Heading5}" Margin="0,0,0,12" />
                <DataGrid Name="dgOtps" Grid.Row="1" Style="{StaticResource MaterialDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="User" Binding="{Binding UserName}" Width="*" />
                        <DataGridTextColumn Header="Mobile" Binding="{Binding UserMobile}" Width="120" />
                        <DataGridTextColumn Header="OTP" Binding="{Binding Otp}" Width="80" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                        <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedOn}" Width="140" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
