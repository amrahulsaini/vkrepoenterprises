<Window x:Class="CRMRSDesktopApp.ModeChooserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        FontFamily="{StaticResource FontBody}"
        Title="Choose Mode" Height="470" Width="760"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    <Window.Resources>
        <Style x:Key="ModeTile" TargetType="Button">
            <Setter Property="Width" Value="210" />
            <Setter Property="Height" Value="130" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Name="b" Background="White" CornerRadius="10"
                                BorderBrush="{StaticResource Gray300}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Gray100}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource Orange500}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource Gray200}" BorderBrush="{StaticResource Gray400}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource Gray900}" MouseLeftButtonDown="TitleBar_MouseDown" />
            <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Image Source="public/crmrs-logo.png" Width="20" Height="20" Margin="0,0,8,0"
                           VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="CRMRS" Foreground="White" FontSize="14" FontWeight="Bold"
                               VerticalAlignment="Center" />
                </StackPanel>
                <Button HorizontalAlignment="Right" Width="44" Height="44" Content="&#x2715;"
                        Background="Transparent" BorderThickness="0" FontSize="14"
                        Foreground="{StaticResource Gray400}" Cursor="Hand" Click="btnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Name="b" Background="Transparent">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#E53935" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource Gray200}"
                    BorderThickness="0,0,0,1" Padding="24,14">
                <DockPanel>
                    <Border DockPanel.Dock="Left" Width="52" Height="52" CornerRadius="26"
                            Background="{StaticResource Gray100}" Margin="0,0,14,0">
                        <Image Name="imgAgencyLogo" Stretch="UniformToFill" Margin="4"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Name="lblAgencyName" Text="Agency" FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource Gray900}" TextTrimming="CharacterEllipsis" />
                        <TextBlock Name="lblAgencyAddress" Text="" FontSize="12" Foreground="{StaticResource Gray600}"
                                   TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <StackPanel Grid.Row="2" VerticalAlignment="Center" Margin="30,0">
                <TextBlock Text="What do you want to open?" FontSize="14" Foreground="{StaticResource Gray600}"
                           HorizontalAlignment="Center" Margin="0,0,0,18" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Name="btnSuperAdmin" Style="{StaticResource ModeTile}" Margin="0,0,16,0" Click="btnSuperAdmin_Click">
                        <StackPanel>
                            <TextBlock Text="&#x1F6E1;" FontSize="34" HorizontalAlignment="Center" />
                            <TextBlock Text="Super Admin" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Gray900}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2" />
                            <TextBlock Text="All features" FontSize="11" Foreground="{StaticResource Gray600}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Name="btnBilling" Style="{StaticResource ModeTile}" Margin="0,0,16,0" Click="btnBilling_Click">
                        <StackPanel>
                            <TextBlock Text="&#x1F9FE;" FontSize="34" HorizontalAlignment="Center" />
                            <TextBlock Text="Billing" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Gray900}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2" />
                            <TextBlock Text="Billing only" FontSize="11" Foreground="{StaticResource Gray600}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Name="btnCourier" Style="{StaticResource ModeTile}" Click="btnCourier_Click">
                        <StackPanel>
                            <TextBlock Text="&#x1F4E6;" FontSize="34" HorizontalAlignment="Center" />
                            <TextBlock Text="Couriers" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Gray900}"
                                       HorizontalAlignment="Center" Margin="0,8,0,2" />
                            <TextBlock Text="Courier updates" FontSize="11" Foreground="{StaticResource Gray600}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="3" Background="{StaticResource Gray50}"
                    BorderBrush="{StaticResource Gray200}" BorderThickness="0,1,0,0" Padding="18,12">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Name="btnChangeAgency" Content="Change agency"
                            Height="32" Padding="16,0" Cursor="Hand" Click="btnChangeAgency_Click" />
                    <TextBlock Name="lblSignedIn" Text="" FontSize="12.5" Foreground="{StaticResource Gray600}"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
