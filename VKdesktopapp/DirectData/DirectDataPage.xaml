<Page
    x:Class="VRASDesktopApp.DirectData.DirectDataPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource Gray200}"
    Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource Gray200}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📥" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBlock Text="Direct Data" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource Gray900}" VerticalAlignment="Center" />
                    <TextBlock Name="lblTab" Text="  —  Files" FontSize="14"
                               Foreground="{StaticResource Gray500}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Name="btnShowFiles" Content="Files" Click="btnShowFiles_Click"
                            Width="80" Height="32" Margin="4,0" Cursor="Hand"
                            Style="{StaticResource PrimaryButton}" />
                    <Button Name="btnShowCreds" Content="Credentials" Click="btnShowCreds_Click"
                            Width="100" Height="32" Margin="4,0" Cursor="Hand"
                            Style="{StaticResource SecondaryButton}" />
                    <Button Name="btnRefresh" Content="↻ Refresh" Click="btnRefresh_Click"
                            Width="90" Height="32" Margin="4,0" Cursor="Hand"
                            Style="{StaticResource SecondaryButton}" />
                    <Button Name="btnAddCred" Content="+ Add Credential" Click="btnAddCred_Click"
                            Width="130" Height="32" Margin="4,0" Cursor="Hand"
                            Visibility="Collapsed"
                            Style="{StaticResource PrimaryButton}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filter bar -->
        <Border Grid.Row="1" Background="White" Padding="20,10"
                BorderBrush="{StaticResource Gray200}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Bank:" VerticalAlignment="Center" Margin="0,0,8,0"
                           FontSize="13" Foreground="{StaticResource Gray700}" />
                <ComboBox Name="cmbBank" Width="200" Height="30" Margin="0,0,16,0"
                          SelectionChanged="cmbBank_SelectionChanged" />
                <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,8,0"
                           FontSize="13" Foreground="{StaticResource Gray700}" />
                <TextBox Name="txtSearch" Width="220" Height="30"
                         TextChanged="txtSearch_TextChanged" Padding="6,4" />
            </StackPanel>
        </Border>

        <!-- Files DataGrid -->
        <Border Grid.Row="2" Name="panelFiles" Margin="16" Background="White" CornerRadius="6">
            <DataGrid Name="dgFiles"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      AlternatingRowBackground="#FFF9F9F9"
                      RowHeight="36"
                      FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#"            Binding="{Binding Id}"           Width="50" />
                    <DataGridTextColumn Header="Bank"         Binding="{Binding BankName}"      Width="160" />
                    <DataGridTextColumn Header="File Name"    Binding="{Binding FileName}"      Width="220" />
                    <DataGridTextColumn Header="Vehicle Type" Binding="{Binding VehicleType}"   Width="110" />
                    <DataGridTextColumn Header="Uploaded By"  Binding="{Binding UploadedBy}"    Width="130" />
                    <DataGridTextColumn Header="Upload Date"  Binding="{Binding UploadedDate}"  Width="110" />
                    <DataGridTextColumn Header="Records"      Binding="{Binding TotalRecords}"  Width="80" />
                    <DataGridTextColumn Header="Received At"  Binding="{Binding ReceivedAt}"    Width="160" />
                    <DataGridTemplateColumn Header="Download" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="⬇ CSV" Cursor="Hand"
                                        Tag="{Binding Id}"
                                        Click="btnDownload_Click"
                                        Height="26" Padding="8,2"
                                        Background="{StaticResource Orange500}"
                                        Foreground="White" BorderThickness="0" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Credentials DataGrid -->
        <Border Grid.Row="2" Name="panelCreds" Margin="16" Background="White" CornerRadius="6"
                Visibility="Collapsed">
            <DataGrid Name="dgCreds"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      AlternatingRowBackground="#FFF9F9F9"
                      RowHeight="36"
                      FontSize="13">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#"          Binding="{Binding Id}"        Width="60" />
                    <DataGridTextColumn Header="Username"   Binding="{Binding Username}"   Width="250" />
                    <DataGridTextColumn Header="Created"    Binding="{Binding CreatedAt}"  Width="160" />
                    <DataGridTemplateColumn Header="Action" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="🗑 Delete" Cursor="Hand"
                                        Tag="{Binding Id}"
                                        Click="btnDeleteCred_Click"
                                        Height="26" Padding="8,2"
                                        Background="#FFE53935"
                                        Foreground="White" BorderThickness="0" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="{StaticResource Gray900}" Padding="16,0">
            <TextBlock Name="lblStatus" Text="Ready" FontSize="12"
                       Foreground="{StaticResource Gray400}" VerticalAlignment="Center" />
        </Border>
    </Grid>
</Page>
