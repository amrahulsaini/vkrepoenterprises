<Window
    x:Class="VRASDesktopApp.ServerSettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Agency Settings"
    Width="560" Height="680"
    WindowStartupLocation="CenterOwner"
    Background="{StaticResource Gray50}"
    FontFamily="Roboto"
    Style="{StaticResource ChromeWindow}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Custom title bar with drag + close ── -->
        <Grid Grid.Row="0" Background="{StaticResource Gray900}"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="AGENCY SETTINGS"
                       VerticalAlignment="Center" Margin="14,0,0,0"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource Orange500}"
                       IsHitTestVisible="False" />
            <Button Grid.Column="1" Name="btnClose" Click="btnClose_Click"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x2715;" FontFamily="{StaticResource FontBody}" FontSize="14"
                    Foreground="{StaticResource Gray400}" Cursor="Hand"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFE53935" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- ── Scrollable form ── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,18,24,8">
                <TextBlock Text="These details show on the mobile app's Agency panel and update everywhere automatically."
                           Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,14" />

                <TextBlock Text="Agency Name" Style="{StaticResource FormHeading}" />
                <TextBox Name="txtAgencyName" Style="{StaticResource MaterialTextBox}" Margin="0,4,0,12" />

                <TextBlock Text="Address" Style="{StaticResource FormHeading}" />
                <TextBox Name="txtAddress" Style="{StaticResource MaterialTextBox}"
                         Margin="0,4,0,12" TextWrapping="Wrap" AcceptsReturn="True"
                         MinHeight="60" VerticalContentAlignment="Top" />

                <TextBlock Text="Primary Mobile Number" Style="{StaticResource FormHeading}" />
                <TextBox Name="txtMobile1" Style="{StaticResource MaterialTextBox}" Margin="0,4,0,12" />

                <TextBlock Text="Secondary Mobile Number" Style="{StaticResource FormHeading}" />
                <TextBox Name="txtMobile2" Style="{StaticResource MaterialTextBox}" Margin="0,4,0,12" />

                <!-- Extra contacts (up to 20) -->
                <DockPanel Margin="0,4,0,6">
                    <TextBlock Text="Additional Contact Numbers" Style="{StaticResource FormHeading}"
                               VerticalAlignment="Center" DockPanel.Dock="Left" />
                    <Button Name="btnAddExtra" DockPanel.Dock="Right"
                            Content="+ Add number" Click="btnAddExtra_Click"
                            Style="{StaticResource SecondaryButton}"
                            Height="30" Padding="12,0" FontSize="12"
                            HorizontalAlignment="Right" />
                </DockPanel>
                <TextBlock Name="txtExtraHint"
                           Text="Up to 20 extra numbers. All appear on the mobile app's Agency panel."
                           Style="{StaticResource Caption}" Margin="0,0,0,6" />
                <ItemsControl Name="icExtras">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding Number, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialTextBox}" />
                                <Button Grid.Column="1" Content="✕" Width="36" Height="40"
                                        Margin="8,0,0,0" Click="btnRemoveExtra_Click"
                                        Tag="{Binding}" Cursor="Hand"
                                        Background="White"
                                        BorderBrush="{StaticResource Red500}" BorderThickness="1"
                                        Foreground="{StaticResource Red500}" FontSize="14" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator Margin="0,12" />

                <TextBlock Text="Control Panel Password (shared by all users)" Style="{StaticResource FormHeading}" />
                <TextBlock Text="Agents type this to open the Control Panel in the mobile app. One password for the whole agency."
                           Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,4" />
                <PasswordBox Name="pwdControlPass" Margin="0,4,0,12"
                             Height="40" FontSize="14" Padding="10,0"
                             BorderBrush="{StaticResource Gray300}" BorderThickness="1"
                             Background="White" />

                <TextBlock Text="Subscription Management Password (SubsPass)" Style="{StaticResource FormHeading}" />
                <PasswordBox Name="pwdSubsPass" Margin="0,4,0,12"
                             Height="40" FontSize="14" Padding="10,0"
                             BorderBrush="{StaticResource Gray300}" BorderThickness="1"
                             Background="White" />
            </StackPanel>
        </ScrollViewer>

        <!-- ── Action buttons (always pinned, never scroll) ── -->
        <Border Grid.Row="2" Background="{StaticResource Gray50}"
                BorderBrush="{StaticResource Gray200}" BorderThickness="0,1,0,0">
            <StackPanel Margin="24,12,24,12">
                <DockPanel LastChildFill="False">
                    <!-- Left: session actions -->
                    <Button Name="btnLogout" DockPanel.Dock="Left" Click="btnLogout_Click"
                            Content="LOG OUT"
                            Style="{StaticResource SecondaryButton}"
                            Width="110" Margin="0,0,8,0" />
                    <Button Name="btnExitApp" DockPanel.Dock="Left" Click="btnExitApp_Click"
                            Content="EXIT APP"
                            Style="{StaticResource OutlineButton}"
                            Width="110" />
                    <!-- Right: save / cancel -->
                    <Button Name="btnSave" DockPanel.Dock="Right" Click="btnSave_Click"
                            Content="SAVE"
                            Style="{StaticResource PrimaryButton}"
                            Width="110" />
                    <Button Name="btnCancel" DockPanel.Dock="Right" Click="btnCancel_Click"
                            Content="CANCEL"
                            Style="{StaticResource SecondaryButton}"
                            Width="110" Margin="0,0,8,0" />
                </DockPanel>
                <!-- ── Branded footer: "Developed by CRMRS" (→ website) + purchase contact ── -->
                <Border Margin="0,14,0,0" Padding="14,11" CornerRadius="8"
                        Background="White" BorderBrush="{StaticResource Gray200}" BorderThickness="1">
                    <StackPanel>
                        <!-- Logo + "Developed by CRMRS" (clickable → main website) -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Image Source="public/crmrs-logo.png" Width="22" Height="22"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock VerticalAlignment="Center" FontSize="12">
                                <Run Text="Developed by " Foreground="{StaticResource Gray600}" />
                                <Hyperlink NavigateUri="https://crmrecoverysoftware.com/"
                                           RequestNavigate="Link_RequestNavigate"
                                           TextDecorations="None" FontWeight="Bold"
                                           Foreground="{StaticResource Orange600}">CRMRS</Hyperlink>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock HorizontalAlignment="Center" Margin="0,2,0,0" FontSize="11">
                            <Hyperlink NavigateUri="https://crmrecoverysoftware.com/"
                                       RequestNavigate="Link_RequestNavigate"
                                       Foreground="{StaticResource Gray600}">crmrecoverysoftware.com</Hyperlink>
                        </TextBlock>
                        <TextBlock Name="txtVersion" HorizontalAlignment="Center" Margin="0,4,0,0"
                                   FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource Gray500}" Text="Version 1.0.7" />

                        <Border Height="1" Background="{StaticResource Gray200}" Margin="0,9,0,8" />

                        <!-- Purchase / enquiries -->
                        <TextBlock Text="For purchase &amp; enquiries"
                                   HorizontalAlignment="Center" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource Gray700}" Margin="0,0,0,5" />
                        <WrapPanel HorizontalAlignment="Center">
                            <TextBlock FontSize="11" VerticalAlignment="Center">
                                <Hyperlink NavigateUri="mailto:team@crmrecoverysoftware.com"
                                           RequestNavigate="Link_RequestNavigate"
                                           Foreground="{StaticResource Orange600}">team@crmrecoverysoftware.com</Hyperlink>
                            </TextBlock>
                            <TextBlock Text="•" FontSize="11" Foreground="{StaticResource Gray400}" VerticalAlignment="Center" Margin="6,0" />
                            <TextBlock FontSize="11" VerticalAlignment="Center">
                                <Hyperlink NavigateUri="mailto:rahul@loopwar.dev"
                                           RequestNavigate="Link_RequestNavigate"
                                           Foreground="{StaticResource Orange600}">rahul@loopwar.dev</Hyperlink>
                            </TextBlock>
                            <TextBlock Text="•" FontSize="11" Foreground="{StaticResource Gray400}" VerticalAlignment="Center" Margin="6,0" />
                            <TextBlock FontSize="11" VerticalAlignment="Center">
                                <Hyperlink NavigateUri="tel:+916377362603"
                                           RequestNavigate="Link_RequestNavigate"
                                           Foreground="{StaticResource Orange600}">+91 6377362603</Hyperlink>
                            </TextBlock>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
