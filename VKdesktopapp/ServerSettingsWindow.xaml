<Window
    x:Class="VRASDesktopApp.ServerSettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Server Settings"
    Width="500" Height="560"
    WindowStartupLocation="CenterOwner"
    Background="{StaticResource Gray50}"
    FontFamily="Roboto"
    Style="{StaticResource ChromeWindow}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Custom title bar with drag + close ── -->
        <Grid Grid.Row="0" Background="{StaticResource Gray900}"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="SERVER SETTINGS"
                       VerticalAlignment="Center" Margin="14,0,0,0"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource Orange500}"
                       IsHitTestVisible="False" />
            <Button Grid.Column="1" Name="btnClose" Click="btnClose_Click"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x2715;" FontFamily="Segoe UI" FontSize="14"
                    Foreground="{StaticResource Gray400}" Cursor="Hand"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFE53935" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- ── Scrollable form ── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,18,24,8">
                <TextBlock Text="API Base URL" Style="{StaticResource FormHeading}" />
                <TextBox Name="txtApiBaseUrl" Style="{StaticResource MaterialTextBox}" Margin="0,4,0,12" />

                <TextBlock Text="API Key" Style="{StaticResource FormHeading}" />
                <TextBox Name="txtApiKey" Style="{StaticResource MaterialTextBox}" Margin="0,4,0,12" />

                <TextBlock Text="Firm Name" Style="{StaticResource FormHeading}" />
                <TextBox Name="txtFirmName" Style="{StaticResource MaterialTextBox}" Margin="0,4,0,12" />

                <TextBlock Text="Contact Numbers" Style="{StaticResource FormHeading}" />
                <TextBox Name="txtContactNos" Style="{StaticResource MaterialTextBox}" Margin="0,4,0,12" />

                <TextBlock Text="Address" Style="{StaticResource FormHeading}" />
                <TextBox Name="txtAddress" Style="{StaticResource MaterialTextBox}" Margin="0,4,0,12" />

                <TextBlock Text="Subscription Management Password (SubsPass)" Style="{StaticResource FormHeading}" />
                <PasswordBox Name="pwdSubsPass" Margin="0,4,0,12"
                             Height="40" FontSize="14" Padding="10,0"
                             BorderBrush="{StaticResource Gray300}" BorderThickness="1"
                             Background="White" />
            </StackPanel>
        </ScrollViewer>

        <!-- ── Action buttons (always pinned, never scroll) ── -->
        <Border Grid.Row="2" Background="{StaticResource Gray50}"
                BorderBrush="{StaticResource Gray200}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="24,12,24,16">
                <Button Name="btnCancel" Click="btnCancel_Click"
                        Content="CANCEL"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Width="120" />
                <Button Name="btnSave" Click="btnSave_Click"
                        Content="SAVE"
                        Style="{StaticResource PrimaryButton}"
                        Width="120" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
