<Window
    x:Class="VRASDesktopApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:VRASDesktopApp"
    FontFamily="Segoe UI"
    Style="{StaticResource ChromeWindow}"
    Background="{StaticResource Gray200}"
    Title="VK Enterprises"
    Width="1366" Height="768"
    WindowState="Maximized"
    Loaded="Window_Loaded">
    <Grid Margin="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="64" MinWidth="64" MaxWidth="64" />
            <ColumnDefinition Name="clmMenuContainer" Width="300" MinWidth="250" MaxWidth="700" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Custom Title Bar (Black) ── -->
        <Border Grid.ColumnSpan="4" Background="{StaticResource Gray900}" />
        <Grid Grid.ColumnSpan="4" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0"
                        IsHitTestVisible="False">
                <TextBlock Text="VK" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource Orange500}" Margin="0,0,4,0" />
                <TextBlock Text="ENTERPRISES" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource Gray400}" VerticalAlignment="Center" />
            </StackPanel>
            <Button Name="btnMinimize" Click="btnMinimize_Click"
                    Grid.Column="1" Width="40" Height="40"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x2014;" FontFamily="Segoe UI" FontSize="14"
                    Foreground="{StaticResource Gray400}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Name="b" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#FF3A3A3A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Name="btnRestore" Click="btnRestore_Click"
                    Grid.Column="2" Width="40" Height="40"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x2750;" FontFamily="Segoe UI" FontSize="12"
                    Foreground="{StaticResource Gray400}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Name="b" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#FF3A3A3A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Name="btnClose" Click="btnClose_Click"
                    Grid.Column="3" Width="40" Height="40"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x2715;" FontFamily="Segoe UI" FontSize="14"
                    Foreground="{StaticResource Gray400}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Name="b" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#FFE53935" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- ── Left Sidebar (Dark) ── -->
        <Border Grid.Column="0" Grid.Row="1" Background="{StaticResource Gray900}" />
        <Grid Grid.Column="0" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="56" />
                <RowDefinition Height="56" />
                <RowDefinition Height="56" />
                <RowDefinition Height="56" />
                <RowDefinition Height="56" />
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
                <RowDefinition Height="56" />
            </Grid.RowDefinitions>

            <Button Name="btnHome" Click="btnNav_Click"
                    Grid.Row="1" Width="64" Height="56"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x1F3E0;" FontFamily="Segoe UI" FontSize="20"
                    Foreground="{StaticResource Gray400}" Cursor="Hand"
                    Tag="Home" />
            <Button Name="btnSearch" Click="btnNav_Click"
                    Grid.Row="2" Width="64" Height="56"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x1F50D;" FontFamily="Segoe UI" FontSize="20"
                    Foreground="{StaticResource Orange500}" Cursor="Hand"
                    Tag="Search" />
            <Button Name="btnFinances" Click="btnNav_Click"
                    Grid.Row="3" Width="64" Height="56"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x1F4B0;" FontFamily="Segoe UI" FontSize="20"
                    Foreground="{StaticResource Gray400}" Cursor="Hand"
                    Tag="Finances" />
            <Button Name="btnUsers" Click="btnNav_Click"
                    Grid.Row="4" Width="64" Height="56"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x1F465;" FontFamily="Segoe UI" FontSize="20"
                    Foreground="{StaticResource Gray400}" Cursor="Hand"
                    Tag="Users" />
            <Button Name="btnConfirmations" Click="btnNav_Click"
                    Grid.Row="5" Width="64" Height="56"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x2705;" FontFamily="Segoe UI" FontSize="20"
                    Foreground="{StaticResource Gray400}" Cursor="Hand"
                    Tag="Confirmations" />
            <Button Name="btnReports" Click="btnNav_Click"
                    Grid.Row="6" Width="64" Height="56"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x1F4CA;" FontFamily="Segoe UI" FontSize="20"
                    Foreground="{StaticResource Gray400}" Cursor="Hand"
                    Tag="Reports" />
            <Button Name="btnSettings" Click="btnSettings_Click"
                    Grid.Row="8" Width="64" Height="56"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x2699;" FontFamily="Segoe UI" FontSize="22"
                    Foreground="{StaticResource Gray400}" Cursor="Hand" />
        </Grid>

        <!-- ── Slide-out Menu ── -->
        <Border Name="MenuContainer" Grid.Column="1" Grid.Row="1"
            Background="{StaticResource Gray50}" Visibility="Visible"
            BorderBrush="{StaticResource Gray200}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Margin="16" Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="48" Height="48" CornerRadius="24" Background="{StaticResource Gray200}" />
                        <StackPanel Margin="8,0,0,0">
                            <TextBlock x:Name="lblFirmName" Text="VK Enterprises" FontSize="14" FontWeight="Bold" Foreground="{StaticResource Gray900}" />
                            <TextBlock Name="lblFirmMobile" Text="9850637363" FontSize="12" Foreground="{StaticResource Gray600}" />
                            <TextBlock Name="lblFirmAddress" Text="VK Maharashtra" FontSize="11" Foreground="{StaticResource Gray500}" TextWrapping="Wrap" MaxWidth="180" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <ScrollViewer Grid.Row="1" Margin="12" VerticalScrollBarVisibility="Auto">
                    <UniformGrid Margin="8" Columns="1" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                        <Button Tag="Home" Click="TileButton_Click" MinHeight="80" Margin="8" HorizontalAlignment="Stretch" Style="{StaticResource DashboardTileButton}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource Gray100}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="🏠" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Home" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" FontSize="14" />
                                    <TextBlock Text="Dashboard" FontSize="11" Foreground="{StaticResource Gray600}" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Tag="Search" Click="TileButton_Click" MinHeight="80" Margin="8" HorizontalAlignment="Stretch" Style="{StaticResource DashboardTileButton}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource Gray100}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="🔎" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Find Vehicles" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" FontSize="14" />
                                    <TextBlock Text="Search by RC / VIN" FontSize="11" Foreground="{StaticResource Gray600}" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Tag="Users" Click="TileButton_Click" MinHeight="80" Margin="8" HorizontalAlignment="Stretch" Style="{StaticResource DashboardTileButton}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource Gray100}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="👥" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Users" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" FontSize="14" />
                                    <TextBlock Text="Manage accounts" FontSize="11" Foreground="{StaticResource Gray600}" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Tag="Finances" Click="TileButton_Click" MinHeight="80" Margin="8" HorizontalAlignment="Stretch" Style="{StaticResource DashboardTileButton}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource Gray100}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="💰" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Finances" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" FontSize="14" />
                                    <TextBlock Text="Payments &amp; reports" FontSize="11" Foreground="{StaticResource Gray600}" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Tag="UploadRecords" Click="TileButton_Click" MinHeight="80" Margin="8" HorizontalAlignment="Stretch" Style="{StaticResource DashboardTileButton}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource Gray100}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="📤" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Upload Records" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" FontSize="14" />
                                    <TextBlock Text="Excel / Manual" FontSize="11" Foreground="{StaticResource Gray600}" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Tag="DetailsViews" Click="TileButton_Click" MinHeight="80" Margin="8" HorizontalAlignment="Stretch" Style="{StaticResource DashboardTileButton}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource Gray100}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="📋" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Details Views" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" FontSize="14" />
                                    <TextBlock Text="Lookup logs" FontSize="11" Foreground="{StaticResource Gray600}" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Tag="Confirmations" Click="TileButton_Click" MinHeight="80" Margin="8" HorizontalAlignment="Stretch" Style="{StaticResource DashboardTileButton}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource Gray100}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="✅" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Confirmations" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" FontSize="14" />
                                    <TextBlock Text="Pending &amp; approved" FontSize="11" Foreground="{StaticResource Gray600}" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Tag="Reports" Click="TileButton_Click" MinHeight="80" Margin="8" HorizontalAlignment="Stretch" Style="{StaticResource DashboardTileButton}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource Gray100}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="📊" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Reports" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" FontSize="14" />
                                    <TextBlock Text="Analytics" FontSize="11" Foreground="{StaticResource Gray600}" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Tag="CleanFile" Click="TileButton_Click" MinHeight="80" Margin="8" HorizontalAlignment="Stretch" Style="{StaticResource DashboardTileButton}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource Gray100}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="🧹" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Clean File" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" FontSize="14" />
                                    <TextBlock Text="Sanitize data" FontSize="11" Foreground="{StaticResource Gray600}" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Tag="OTPs" Click="TileButton_Click" MinHeight="80" Margin="8" HorizontalAlignment="Stretch" Style="{StaticResource DashboardTileButton}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource Gray100}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="🔐" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="OTPs" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" FontSize="14" />
                                    <TextBlock Text="One-time passwords" FontSize="11" Foreground="{StaticResource Gray600}" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Tag="Blacklist" Click="TileButton_Click" MinHeight="80" Margin="8" HorizontalAlignment="Stretch" Style="{StaticResource DashboardTileButton}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource Gray100}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="⛔" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Blacklist" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" FontSize="14" />
                                    <TextBlock Text="Blocked items" FontSize="11" Foreground="{StaticResource Gray600}" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Tag="Feedbacks" Click="TileButton_Click" MinHeight="80" Margin="8" HorizontalAlignment="Stretch" Style="{StaticResource DashboardTileButton}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource Gray100}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="💬" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Feedbacks" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" FontSize="14" />
                                    <TextBlock Text="User feedback" FontSize="11" Foreground="{StaticResource Gray600}" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Tag="Payments" Click="TileButton_Click" MinHeight="80" Margin="8" HorizontalAlignment="Stretch" Style="{StaticResource DashboardTileButton}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource Gray100}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="💳" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Accept Payment" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" FontSize="14" />
                                    <TextBlock Text="Payment gateway" FontSize="11" Foreground="{StaticResource Gray600}" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Tag="PayBill" Click="TileButton_Click" MinHeight="80" Margin="8" HorizontalAlignment="Stretch" Style="{StaticResource DashboardTileButton}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource Gray100}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="💸" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Pay Bill" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" FontSize="14" />
                                    <TextBlock Text="Vendor payments" FontSize="11" Foreground="{StaticResource Gray600}" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Tag="FirmSettings" Click="TileButton_Click" MinHeight="80" Margin="8" HorizontalAlignment="Stretch" Style="{StaticResource DashboardTileButton}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource Gray100}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="⚙️" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Firm Settings" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" FontSize="14" />
                                    <TextBlock Text="Preferences" FontSize="11" Foreground="{StaticResource Gray600}" />
                                </StackPanel>
                            </Grid>
                        </Button>
                        <Button Tag="MobileControlPin" Click="TileButton_Click" MinHeight="80" Margin="8" HorizontalAlignment="Stretch" Style="{StaticResource DashboardTileButton}">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource Gray100}" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="📱" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Mobile Control Pin" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" FontSize="14" />
                                    <TextBlock Text="Device pin control" FontSize="11" Foreground="{StaticResource Gray600}" />
                                </StackPanel>
                            </Grid>
                        </Button>
                    </UniformGrid>
                </ScrollViewer>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="2" Grid.Row="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                  Background="#FFC0C0C0" ShowsPreview="True" 
                  ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" Cursor="SizeWE" 
                  IsHitTestVisible="True" Panel.ZIndex="50" Margin="0,0,0,0" />
        
        <!-- ── Content Area ── -->
        <Border Grid.Column="3" Grid.Row="1" Background="White">
            <Frame Name="PageContainer" NavigationUIVisibility="Hidden" Background="White" />
        </Border>
        <Border Name="PageContainerWide" Grid.Column="1" Grid.ColumnSpan="3"
                Grid.Row="1" Background="White" Visibility="Collapsed">
            <Frame Name="PageContainerWideFrame" NavigationUIVisibility="Hidden" Background="White" />
        </Border>
    </Grid>
</Window>
