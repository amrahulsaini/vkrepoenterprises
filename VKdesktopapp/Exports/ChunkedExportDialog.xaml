<Window
    x:Class="VRASDesktopApp.Exports.ChunkedExportDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Download Records"
    Width="640" Height="560"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    Background="White"
    FontFamily="{StaticResource FontBody}"
    ShowInTaskbar="False">

    <Window.Resources>
        <SolidColorBrush x:Key="HeaderBg"  Color="#1A1A1A" />
        <SolidColorBrush x:Key="Accent"    Color="#F5A623" />
        <SolidColorBrush x:Key="MutedBg"   Color="#F5F5F5" />
        <SolidColorBrush x:Key="MutedFg"   Color="#666666" />
        <SolidColorBrush x:Key="SuccessFg" Color="#2E7D32" />
        <SolidColorBrush x:Key="ErrorFg"   Color="#C62828" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBg}" Padding="20,14">
            <StackPanel>
                <TextBlock Name="txtTitle" Text="Download Records"
                           FontSize="16" FontWeight="Bold" Foreground="White" />
                <TextBlock Name="txtSubtitle" Text=""
                           FontSize="11" Foreground="#BBBBBB" Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource MutedBg}" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Records per file:" FontSize="13"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox Name="cmbChunkSize" Width="120" Height="28"
                              FontSize="13"
                              SelectionChanged="cmbChunkSize_SelectionChanged" />
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Text="Total: " FontSize="13" Foreground="{StaticResource MutedFg}" />
                    <TextBlock Name="txtTotal" Text="—" FontSize="13" FontWeight="SemiBold" />
                    <TextBlock Text="  •  Files: " FontSize="13" Foreground="{StaticResource MutedFg}" Margin="6,0,0,0" />
                    <TextBlock Name="txtFileCount" Text="—" FontSize="13" FontWeight="SemiBold" />
                </StackPanel>

                <Button Grid.Column="2" Name="btnFolder" Content="Folder..."
                        Width="90" Height="28" Click="btnFolder_Click"
                        FontSize="12" />
            </Grid>
        </Border>

        <ListView Grid.Row="2" Name="lvFiles"
                  Margin="20,12,20,4"
                  BorderBrush="#E0E0E0" BorderThickness="1"
                  Background="White"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Include" Width="60">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding Selected, Mode=TwoWay}"
                                          HorizontalAlignment="Center" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="File Name" Width="280">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FileName}" FontFamily="Consolas" FontSize="12" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Records" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding RecordsDisplay}"
                                           HorizontalAlignment="Right" FontSize="12" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Status" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StatusText}"
                                           Foreground="{Binding StatusBrush}"
                                           FontWeight="SemiBold" FontSize="12" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="" Width="60">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Open" FontSize="11" Padding="6,2"
                                        IsEnabled="{Binding IsDone}"
                                        Click="btnOpenFile_Click"
                                        Tag="{Binding}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="3" Margin="20,8,20,4">
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Name="txtStatus" Text=""
                           FontSize="12" Foreground="{StaticResource MutedFg}" />
                <TextBlock Grid.Column="1" Name="txtPct" Text=""
                           FontSize="12" Foreground="{StaticResource MutedFg}" FontWeight="SemiBold" />
            </Grid>
            <ProgressBar Name="pb" Height="6" Minimum="0" Maximum="100"
                         Foreground="{StaticResource Accent}" />
        </StackPanel>

        <Border Grid.Row="4" Background="{StaticResource MutedBg}" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Name="txtFolderPath" Text=""
                           FontSize="11" Foreground="{StaticResource MutedFg}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <Button Grid.Column="1" Name="btnClose" Content="Close"
                        Width="90" Height="32" Margin="0,0,8,0"
                        Click="btnClose_Click" />

                <Button Grid.Column="2" Name="btnDownload" Content="Download Selected"
                        Width="160" Height="32"
                        Background="{StaticResource Accent}" Foreground="White"
                        FontWeight="SemiBold" BorderThickness="0"
                        Click="btnDownload_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
