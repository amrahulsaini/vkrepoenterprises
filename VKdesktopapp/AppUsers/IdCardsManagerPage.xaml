<Page
    x:Class="CRMRSDesktopApp.AppUsers.IdCardsManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource Gray50}"
    FontFamily="{StaticResource FontBody}"
    Loaded="Page_Loaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="ID Card Requests" FontSize="22" FontWeight="Bold" Foreground="{StaticResource Gray900}" />
                <TextBlock Text="Review submitted documents, then approve with a validity or decline with a reason."
                           FontSize="12" Foreground="{StaticResource Gray600}" Margin="0,2,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <ComboBox x:Name="cmbFilter" Width="140" SelectedIndex="0" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Pending" Tag="pending" />
                    <ComboBoxItem Content="Approved" Tag="approved" />
                    <ComboBoxItem Content="Declined" Tag="declined" />
                    <ComboBoxItem Content="All" Tag="all" />
                </ComboBox>
                <Button Content="Refresh" Margin="10,0,0,0" Padding="14,6" Click="Refresh_Click" Cursor="Hand" />
            </StackPanel>
        </Grid>

        <!-- List -->
        <Grid Grid.Row="1">
            <TextBlock x:Name="txtEmpty" Text="No requests." HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{StaticResource Gray600}" Visibility="Collapsed" />
            <TextBlock x:Name="txtLoading" Text="Loading…" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{StaticResource Gray600}" Visibility="Collapsed" />
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="listCards">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="10" Margin="0,0,0,12" Padding="16"
                                    BorderBrush="{StaticResource Gray200}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Photo -->
                                    <Border Grid.Column="0" Width="96" Height="96" CornerRadius="8"
                                            Background="{StaticResource Gray100}" VerticalAlignment="Top" ClipToBounds="True">
                                        <Image Source="{Binding PhotoImage}" Stretch="UniformToFill" />
                                    </Border>

                                    <!-- Details -->
                                    <StackPanel Grid.Column="1" Margin="16,0,16,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource Gray900}" />
                                            <Border Margin="10,0,0,0" Padding="8,2" CornerRadius="10" Background="{StaticResource Gray100}" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Status}" FontSize="11" Foreground="{StaticResource Gray700}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Mobile}" FontSize="12" Foreground="{StaticResource Gray600}" Margin="0,2,0,0" />
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="Blood: " FontSize="12" Foreground="{StaticResource Gray600}" />
                                            <TextBlock Text="{Binding BloodGroup}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" />
                                            <TextBlock Text="   DOB: " FontSize="12" Foreground="{StaticResource Gray600}" />
                                            <TextBlock Text="{Binding Dob}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <TextBlock Text="Valid until: " FontSize="12" Foreground="{StaticResource Gray600}" />
                                            <TextBlock Text="{Binding ValidUntil}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Gray900}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding DeclineReason}" FontSize="12" Foreground="#DC2626" Margin="0,6,0,0" TextWrapping="Wrap" />

                                        <!-- Document thumbnails -->
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Button Tag="{Binding PhotoImage}" Click="ViewImage_Click" Cursor="Hand" Margin="0,0,8,0" Padding="0" BorderThickness="1" BorderBrush="{StaticResource Gray200}">
                                                <Image Source="{Binding PhotoImage}" Width="70" Height="52" Stretch="UniformToFill" />
                                            </Button>
                                            <Button Tag="{Binding PccImage}" Click="ViewImage_Click" Cursor="Hand" Margin="0,0,8,0" Padding="0" BorderThickness="1" BorderBrush="{StaticResource Gray200}">
                                                <Image Source="{Binding PccImage}" Width="70" Height="52" Stretch="UniformToFill" />
                                            </Button>
                                            <Button Tag="{Binding DraImage}" Click="ViewImage_Click" Cursor="Hand" Padding="0" BorderThickness="1" BorderBrush="{StaticResource Gray200}">
                                                <Image Source="{Binding DraImage}" Width="70" Height="52" Stretch="UniformToFill" />
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Text="Photo · PCC · DRA (click to enlarge)" FontSize="10" Foreground="{StaticResource Gray600}" Margin="0,4,0,0" />
                                    </StackPanel>

                                    <!-- Actions -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Width="180">
                                        <TextBlock Text="Validity (days)" FontSize="11" Foreground="{StaticResource Gray600}" />
                                        <TextBox Tag="{Binding UserId}" Text="1" Height="30" Margin="0,2,0,8"
                                                 x:Name="txtDays" TextChanged="Days_Changed" />
                                        <Button Content="✓ Approve" Tag="{Binding UserId}" Click="Approve_Click"
                                                Background="#16A34A" Foreground="White" BorderThickness="0" Padding="10,8" Cursor="Hand" />
                                        <Button Content="✕ Decline" Tag="{Binding UserId}" Click="Decline_Click"
                                                Background="#DC2626" Foreground="White" BorderThickness="0" Padding="10,8" Margin="0,8,0,0" Cursor="Hand" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
