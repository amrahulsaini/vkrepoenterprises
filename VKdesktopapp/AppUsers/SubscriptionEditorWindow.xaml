<Window
    x:Class="VRASDesktopApp.AppUsers.SubscriptionEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add Subscription Plan"
    Width="380" SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    FontFamily="Segoe UI"
    Background="{StaticResource Gray50}">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Gray600}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="Field" TargetType="TextBox">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource Gray200}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="38" />
        </Style>
        <Style x:Key="DateField" TargetType="DatePicker">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource Gray200}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="38" />
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Orange500}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="13" /><Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="0,10" /><Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="6" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Orange600}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CancelBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="{StaticResource Gray200}" />
            <Setter Property="Foreground" Value="{StaticResource Gray700}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="6" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource Gray300}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="28,24,28,24" >

        <!-- Title -->
        <TextBlock Text="Add Subscription Plan"
                   FontSize="17" FontWeight="Bold"
                   Foreground="{StaticResource Gray900}"
                   Margin="0,0,0,20" />

        <!-- Start Date -->
        <TextBlock Text="START DATE *" Style="{StaticResource FieldLabel}" />
        <DatePicker Name="dpStart" Style="{StaticResource DateField}"
                    Margin="0,0,0,14"
                    SelectedDateChanged="dpStart_SelectedDateChanged" />

        <!-- End Date -->
        <TextBlock Text="END DATE *" Style="{StaticResource FieldLabel}" />
        <DatePicker Name="dpEnd" Style="{StaticResource DateField}"
                    Margin="0,0,0,14" />

        <!-- Amount -->
        <TextBlock Text="AMOUNT (₹)" Style="{StaticResource FieldLabel}" />
        <TextBox Name="txtAmount" Style="{StaticResource Field}"
                 Margin="0,0,0,14"
                 PreviewTextInput="NumericOnly" />

        <!-- Notes -->
        <TextBlock Text="NOTES" Style="{StaticResource FieldLabel}" />
        <TextBox Name="txtNotes"
                 FontSize="14" Padding="10,8"
                 Background="White"
                 BorderBrush="{StaticResource Gray200}"
                 BorderThickness="1"
                 Height="70"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 Margin="0,0,0,20" />

        <!-- Error message -->
        <Border Name="brdError" Visibility="Collapsed"
                Background="#FFEEE" BorderBrush="#FFCCC"
                BorderThickness="1" CornerRadius="6"
                Padding="10,8" Margin="0,0,0,14">
            <TextBlock Name="txtError" FontSize="12"
                       Foreground="#C0392B" TextWrapping="Wrap" />
        </Border>

        <!-- Buttons -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Cancel" Style="{StaticResource CancelBtn}"
                    Click="btnCancel_Click" />
            <Button Grid.Column="2" Content="Add Plan" Style="{StaticResource PrimaryBtn}"
                    Click="btnSave_Click" />
        </Grid>

    </StackPanel>
</Window>
