<Page
    x:Class="VRASDesktopApp.Records.FindVehiclePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource Gray50}"
    FontFamily="Segoe UI"
    Loaded="Page_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DashboardCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="140" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="FIND VEHICLES" Style="{StaticResource Heading4}" />
                    <TextBlock Text="Search live records by RC number or chassis number."
                               Margin="0,6,0,0"
                               Style="{StaticResource Caption}" />
                </StackPanel>
                <!-- Search box — large, bold, monospace, with a big placeholder -->
                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <TextBox Name="txtSearch"
                             Style="{StaticResource MaterialTextBox}"
                             FontSize="22" FontWeight="Bold"
                             FontFamily="Consolas"
                             Padding="10,4"
                             Height="48"
                             VerticalContentAlignment="Center"
                             TextChanged="txtSearch_TextChanged" />
                    <TextBlock Name="lblSearchWatermark"
                               Text="Enter RC / Chassis…"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource Gray400}"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <ComboBox Name="cmbMode"
                          Grid.Column="2"
                          Margin="12,0,0,0"
                          Height="42"
                          VerticalAlignment="Center">
                    <ComboBoxItem Content="RC number" Tag="rc" IsSelected="True" />
                    <ComboBoxItem Content="Chassis number" Tag="chassis" />
                </ComboBox>
                <Grid Grid.Column="3" Margin="12,0,0,0">
                    <Button Name="btnSearch" Style="{StaticResource PrimaryButton}" Content="SEARCH" Click="btnSearch_Click" Height="42" VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </Border>

        <!-- Compact stat cards (smaller padding + value font) so the VEHICLE
             MATCHES grid below gets more height. -->
        <UniformGrid Grid.Row="1" Columns="3" Margin="0,8,0,8">
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0" Padding="14,9">
                <StackPanel>
                    <TextBlock Text="RESULTS" Style="{StaticResource FormHeading}" />
                    <TextBlock Name="lblResults" Style="{StaticResource StatValue}" FontSize="24" Text="0" />
                    <TextBlock Text="Matching rows shown in the desktop grid"
                               Style="{StaticResource Caption}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0" Padding="14,9">
                <StackPanel>
                    <TextBlock Text="BRANCHES" Style="{StaticResource FormHeading}" />
                    <TextBlock Name="lblBranchCount" Style="{StaticResource StatValue}" FontSize="24" Text="0" />
                    <TextBlock Text="Unique branches found in the current result"
                               Style="{StaticResource Caption}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DashboardCard}" Padding="14,9">
                <StackPanel>
                    <TextBlock Text="SEARCH MODE" Style="{StaticResource FormHeading}" />
                    <TextBlock Name="lblMode" Style="{StaticResource StatValue}" FontSize="24" Text="RC" />
                    <TextBlock Name="lblSearchHint"
                               Text="Recent records are shown when the search box is empty."
                               Style="{StaticResource Caption}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>

            <!-- Column 1: Unique Vehicles -->
            <Border Grid.Column="0" Style="{StaticResource DashboardCard}" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="VEHICLE MATCHES" Style="{StaticResource Heading5}" Margin="0,0,0,12" VerticalAlignment="Center" />

                    <DataGrid Name="dgResults"
                              Grid.Row="1"
                              SelectionChanged="dgResults_SelectionChanged"
                              SelectionMode="Extended"
                              ClipboardCopyMode="IncludeHeader"
                              IsReadOnly="True"
                              RowHeight="36"
                              HorizontalScrollBarVisibility="Auto"
                              Style="{StaticResource MaterialDataGrid}">
                        <DataGrid.Resources>
                            <!-- Big, bold, monospace cells for RC / Chassis so the
                                 numbers are easy to read at a glance. -->
                            <Style x:Key="BigBoldCell" TargetType="TextBlock">
                                <Setter Property="FontSize" Value="16" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="FontFamily" Value="Consolas" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                            <Style x:Key="BoldCell" TargetType="TextBlock">
                                <Setter Property="FontSize" Value="15" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="colRc" Header="Vehicle no" Binding="{Binding VehicleNo}" Width="170"
                                                ElementStyle="{StaticResource BigBoldCell}" />
                            <DataGridTextColumn x:Name="colChassis" Header="Chassis no" Binding="{Binding ChassisNo}" Width="170" Visibility="Collapsed"
                                                ElementStyle="{StaticResource BigBoldCell}" />
                            <!-- Auto width + a sensible minimum so long model names
                                 push past the panel edge and the horizontal
                                 scrollbar lets you read them in full. -->
                            <DataGridTextColumn x:Name="colModel" Header="Model" Binding="{Binding Model}" Width="Auto" MinWidth="220"
                                                ElementStyle="{StaticResource BoldCell}" />
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <ProgressBar Name="prgSearching" Grid.Row="2" Height="4" IsIndeterminate="True" Visibility="Collapsed" Margin="0,16,0,0" />
                </Grid>
            </Border>

            <!-- Column 2: Branches/Finances -->
            <Border Name="brdBranches" Grid.Column="1" Style="{StaticResource DashboardCard}" Margin="0,0,12,0" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Branches/Finances" Style="{StaticResource Heading5}" Margin="0,0,0,12" VerticalAlignment="Center" />

                    <ListBox Name="lstBranches" 
                             Grid.Row="1" 
                             SelectionChanged="lstBranches_SelectionChanged"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource Gray200}" BorderThickness="0,0,0,1" Padding="0,12,0,12" Background="Transparent">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Copy"      Click="BranchItem_Copy_Click"      Tag="{Binding}" />
                                            <MenuItem Header="Copy Finance"  Click="BranchItem_CopyFinance_Click"  Tag="{Binding Financer}" />
                                            <MenuItem Header="Copy Branch"   Click="BranchItem_CopyBranch_Click"   Tag="{Binding BranchName}" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Financer}" FontWeight="Medium" FontSize="14" TextWrapping="Wrap" />
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding BranchName}" Style="{StaticResource Caption}" FontWeight="Bold" TextWrapping="Wrap" />
                                            <TextBlock Grid.Column="1" Text="{Binding UpdatedOn}" Style="{StaticResource Caption}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Column 3: Full Details Panel -->
            <Border Name="brdDetails" Grid.Column="2" Style="{StaticResource DashboardCard}" Visibility="Collapsed" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="{StaticResource Gray100}" BorderBrush="{StaticResource Gray200}" BorderThickness="0,0,0,1" Padding="12,8">
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Name="btnCopy" Content="Copy Info" Padding="12,4" Margin="0,4,8,4" Click="btnCopy_Click" Background="{StaticResource Gray700}" Foreground="White" BorderThickness="0" Cursor="Hand" />
                            <Button Name="btnDelete" Content="Delete" Padding="12,4" Margin="0,4,0,4" Click="btnDelete_Click" Background="{StaticResource Red500}" Foreground="White" BorderThickness="0" Cursor="Hand" />
                        </WrapPanel>
                    </Border>
                    
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  PanningMode="HorizontalFirst">
                        <StackPanel>
                            <StackPanel.Resources>
                                <Style x:Key="LabelBorder" TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{StaticResource Gray200}" />
                                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                                    <Setter Property="Padding" Value="10,6" />
                                    <Setter Property="Background" Value="{StaticResource Gray50}" />
                                </Style>
                                <Style x:Key="ValueBorder" TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{StaticResource Gray200}" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                    <Setter Property="Padding" Value="10,6" />
                                </Style>
                                <!-- TextBox styled as a TextBlock so labels are drag-selectable too. -->
                                <Style x:Key="LabelText" TargetType="TextBox">
                                    <Setter Property="Foreground"      Value="{StaticResource Gray700}" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontSize"        Value="13" />
                                    <Setter Property="FontWeight"      Value="Bold" />
                                    <Setter Property="IsReadOnly"      Value="True" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding"         Value="0" />
                                    <Setter Property="Background"      Value="Transparent" />
                                    <Setter Property="IsReadOnlyCaretVisible" Value="False" />
                                    <Setter Property="Cursor"          Value="IBeam" />
                                </Style>
                                <!-- TextBox styled to look like a TextBlock â€” so the user can
                                     drag-select text from each value cell and Ctrl+C copy it. -->
                                <Style x:Key="ValueText" TargetType="TextBox">
                                    <Setter Property="Foreground"      Value="{StaticResource Gray900}" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="TextWrapping"    Value="Wrap" />
                                    <Setter Property="FontSize"        Value="15" />
                                    <Setter Property="FontWeight"      Value="Bold" />
                                    <Setter Property="IsReadOnly"      Value="True" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding"         Value="0" />
                                    <Setter Property="Background"      Value="Transparent" />
                                    <Setter Property="IsReadOnlyCaretVisible" Value="False" />
                                    <!-- Standard mouse caret instead of the I-beam-only one. -->
                                    <Setter Property="Cursor"          Value="IBeam" />
                                </Style>
                                <Style x:Key="SectionDivider" TargetType="Border">
                                    <Setter Property="Height" Value="8" />
                                    <Setter Property="Background" Value="{StaticResource Gray100}" />
                                </Style>
                                <Style x:Key="RowBorder" TargetType="Border">
                                    <Setter Property="BorderBrush"      Value="{StaticResource Gray200}" />
                                    <Setter Property="BorderThickness"  Value="0,0,0,1" />
                                    <Setter Property="Padding"          Value="14,9" />
                                </Style>
                                <Style x:Key="RowText" TargetType="TextBox">
                                    <Setter Property="IsReadOnly"       Value="True" />
                                    <Setter Property="BorderThickness"  Value="0" />
                                    <Setter Property="Padding"          Value="0" />
                                    <Setter Property="Background"       Value="Transparent" />
                                    <Setter Property="Foreground"       Value="{StaticResource Gray900}" />
                                    <Setter Property="FontFamily"       Value="Consolas" />
                                    <Setter Property="FontSize"         Value="13" />
                                    <Setter Property="FontWeight"       Value="SemiBold" />
                                    <Setter Property="TextWrapping"     Value="Wrap" />
                                    <Setter Property="Cursor"           Value="IBeam" />
                                    <Setter Property="IsReadOnlyCaretVisible" Value="False" />
                                </Style>
                            </StackPanel.Resources>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding VehicleNo, StringFormat=&apos;Vehicle No :      {0}&apos;}"/></Border>
                                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding ChassisNo, StringFormat=&apos;Chassis No :      {0}&apos;}"/></Border>
                                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding Model, StringFormat=&apos;Model/Make :      {0}&apos;}"/></Border>
                                <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding EngineNo, StringFormat=&apos;Engine No :       {0}&apos;}"/></Border>
                                <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding AgreementNo, StringFormat=&apos;Agreement No :    {0}&apos;}"/></Border>
                                <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding CustomerName, StringFormat=&apos;Cust. Name :      {0}&apos;}"/></Border>
                                <Border Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding CustomerAddress, StringFormat=&apos;Cust. Address :   {0}&apos;}"/></Border>
                                <Border Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding CustomerContactNos, StringFormat=&apos;Cust. Contact :   {0}&apos;}"/></Border>
                            </Grid>
                            <Border Style="{StaticResource SectionDivider}" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding Bucket, StringFormat=&apos;Bucket :          {0}&apos;}"/></Border>
                                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding OD, StringFormat=&apos;OD :              {0}&apos;}"/></Border>
                                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding POS, StringFormat=&apos;POS :             {0}&apos;}"/></Border>
                                <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding TOSS, StringFormat=&apos;TOSS :            {0}&apos;}"/></Border>
                                <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding TBRFlag, StringFormat=&apos;TBR Flag :        {0}&apos;}"/></Border>
                            </Grid>
                            <Border Style="{StaticResource SectionDivider}" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding BranchFromExcel, StringFormat=&apos;Branch (xlsx) :   {0}&apos;}"/></Border>
                                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding Area, StringFormat=&apos;Area :            {0}&apos;}"/></Border>
                                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding Region, StringFormat=&apos;Region :          {0}&apos;}"/></Border>
                            </Grid>
                            <Border Style="{StaticResource SectionDivider}" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding Level1, StringFormat=&apos;Level 1 :         {0}&apos;}"/></Border>
                                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding Level1ContactNos, StringFormat=&apos;Level 1 Contact : {0}&apos;}"/></Border>
                                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding Level2, StringFormat=&apos;Level 2 :         {0}&apos;}"/></Border>
                                <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding Level2ContactNos, StringFormat=&apos;Level 2 Contact : {0}&apos;}"/></Border>
                                <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding Level3, StringFormat=&apos;Level 3 :         {0}&apos;}"/></Border>
                                <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding Level3ContactNos, StringFormat=&apos;Level 3 Contact : {0}&apos;}"/></Border>
                                <Border Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding Level4, StringFormat=&apos;Level 4 :         {0}&apos;}"/></Border>
                                <Border Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding Level4ContactNos, StringFormat=&apos;Level 4 Contact : {0}&apos;}"/></Border>
                            </Grid>
                            <Border Style="{StaticResource SectionDivider}" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding BranchName, StringFormat=&apos;Finance :         {0}&apos;}"/></Border>
                                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding Financer, StringFormat=&apos;Head Office :     {0}&apos;}"/></Border>
                                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding FirstContactDetails, StringFormat=&apos;Contact 1 :       {0}&apos;}"/></Border>
                                <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding SecondContactDetails, StringFormat=&apos;Contact 2 :       {0}&apos;}"/></Border>
                                <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding ThirdContactDetails, StringFormat=&apos;Contact 3 :       {0}&apos;}"/></Border>
                                <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding SenderMailId1, StringFormat=&apos;Mail Id 1 :       {0}&apos;}"/></Border>
                                <Border Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding SenderMailId2, StringFormat=&apos;Mail Id 2 :       {0}&apos;}"/></Border>
                                <Border Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding Address, StringFormat=&apos;Address :         {0}&apos;}"/></Border>
                                <Border Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding ExecutiveName, StringFormat=&apos;Executive Name :  {0}&apos;}"/></Border>
                            </Grid>
                            <Border Style="{StaticResource SectionDivider}" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource RowBorder}"><TextBox Style="{StaticResource RowText}" Text="{Binding CreatedOn, StringFormat=&apos;Uploaded On :     {0}&apos;}"/></Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
