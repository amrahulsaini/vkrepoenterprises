<Page
    x:Class="VRASDesktopApp.Records.FindVehiclePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource Gray50}"
    FontFamily="Segoe UI"
    Loaded="Page_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DashboardCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="140" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="FIND VEHICLES" Style="{StaticResource Heading4}" />
                    <TextBlock Text="Search live records by RC number or chassis number."
                               Margin="0,6,0,0"
                               Style="{StaticResource Caption}" />
                </StackPanel>
                <!-- Search box is now larger with FontSize 20 and padded for easy tapping -->
                <TextBox Name="txtSearch"
                         Grid.Column="1"
                         Style="{StaticResource MaterialTextBox}"
                         VerticalAlignment="Center"
                         FontSize="20"
                         Padding="8,4"
                         Height="42"
                         TextChanged="txtSearch_TextChanged" />
                <ComboBox Name="cmbMode"
                          Grid.Column="2"
                          Margin="12,0,0,0"
                          Height="42"
                          VerticalAlignment="Center">
                    <ComboBoxItem Content="RC number" Tag="rc" IsSelected="True" />
                    <ComboBoxItem Content="Chassis number" Tag="chassis" />
                </ComboBox>
                <Grid Grid.Column="3" Margin="12,0,0,0">
                    <Button Name="btnSearch" Style="{StaticResource PrimaryButton}" Content="SEARCH" Click="btnSearch_Click" Height="42" VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,18,0,18">
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="RESULTS" Style="{StaticResource FormHeading}" />
                    <TextBlock Name="lblResults" Style="{StaticResource StatValue}" Text="0" />
                    <TextBlock Text="Matching rows shown in the desktop grid"
                               Style="{StaticResource Caption}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="BRANCHES" Style="{StaticResource FormHeading}" />
                    <TextBlock Name="lblBranchCount" Style="{StaticResource StatValue}" Text="0" />
                    <TextBlock Text="Unique branches found in the current result"
                               Style="{StaticResource Caption}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Text="SEARCH MODE" Style="{StaticResource FormHeading}" />
                    <TextBlock Name="lblMode" Style="{StaticResource StatValue}" Text="RC" />
                    <TextBlock Name="lblSearchHint"
                               Text="Recent records are shown when the search box is empty."
                               Style="{StaticResource Caption}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- Column 1: Unique Vehicles -->
            <Border Grid.Column="0" Style="{StaticResource DashboardCard}" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="VEHICLE MATCHES" Style="{StaticResource Heading5}" Margin="0,0,0,12" VerticalAlignment="Center" />

                    <DataGrid Name="dgResults"
                              Grid.Row="1"
                              SelectionChanged="dgResults_SelectionChanged"
                              Style="{StaticResource MaterialDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="colRc" Header="Vehicle no" Binding="{Binding VehicleNo}" Width="160" />
                            <DataGridTextColumn x:Name="colChassis" Header="Chassis no" Binding="{Binding ChassisNo}" Width="160" Visibility="Collapsed" />
                            <DataGridTextColumn x:Name="colModel" Header="Model" Binding="{Binding Model}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <ProgressBar Name="prgSearching" Grid.Row="2" Height="4" IsIndeterminate="True" Visibility="Collapsed" Margin="0,16,0,0" />
                </Grid>
            </Border>

            <!-- Column 2: Branches/Finances -->
            <Border Name="brdBranches" Grid.Column="1" Style="{StaticResource DashboardCard}" Margin="0,0,12,0" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Branches/Finances" Style="{StaticResource Heading5}" Margin="0,0,0,12" VerticalAlignment="Center" />

                    <ListBox Name="lstBranches" 
                             Grid.Row="1" 
                             SelectionChanged="lstBranches_SelectionChanged"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource Gray200}" BorderThickness="0,0,0,1" Padding="0,12,0,12" Background="Transparent">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Financer}" FontWeight="Medium" FontSize="14" TextWrapping="Wrap" />
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding BranchName}" Style="{StaticResource Caption}" FontWeight="Bold" TextWrapping="Wrap" />
                                            <TextBlock Grid.Column="1" Text="{Binding UpdatedOn}" Style="{StaticResource Caption}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Column 3: Full Details Panel -->
            <Border Name="brdDetails" Grid.Column="2" Style="{StaticResource DashboardCard}" Visibility="Collapsed" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="{StaticResource Gray100}" BorderBrush="{StaticResource Gray200}" BorderThickness="0,0,0,1" Padding="12,8">
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Name="btnCopy" Content="Copy Info" Padding="12,4" Margin="0,4,8,4" Click="btnCopy_Click" Background="{StaticResource Gray700}" Foreground="White" BorderThickness="0" Cursor="Hand" />
                            <Button Name="btnRelease" Content="Mark/Unmark Release" Padding="12,4" Margin="0,4,8,4" Click="btnRelease_Click" Background="{StaticResource Green500}" Foreground="White" BorderThickness="0" Cursor="Hand" />
                            <Button Name="btnConfirmNow" Content="Confirm Now" Padding="12,4" Margin="0,4,8,4" Click="btnConfirmNow_Click" Background="{StaticResource Orange600}" Foreground="White" BorderThickness="0" Cursor="Hand" />
                            <Button Name="btnDelete" Content="Delete" Padding="12,4" Margin="0,4,0,4" Click="btnDelete_Click" Background="{StaticResource Red500}" Foreground="White" BorderThickness="0" Cursor="Hand" />
                        </WrapPanel>
                    </Border>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Grid.IsSharedSizeScope="True">
                        <StackPanel.Resources>
                            <Style TargetType="Expander">
                                <Setter Property="IsExpanded" Value="True" />
                                <Setter Property="Background" Value="{StaticResource Gray100}" />
                                <Setter Property="BorderBrush" Value="{StaticResource Gray200}" />
                                <Setter Property="BorderThickness" Value="1,1,1,0" />
                                <Setter Property="Foreground" Value="{StaticResource Gray800}" />
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Padding" Value="4,6" />
                            </Style>
                            <Style x:Key="LabelBorder" TargetType="Border">
                                <Setter Property="BorderBrush" Value="{StaticResource Gray200}" />
                                <Setter Property="BorderThickness" Value="1,0,1,1" />
                                <Setter Property="Padding" Value="8,5" />
                                <Setter Property="Background" Value="{StaticResource Gray50}" />
                            </Style>
                            <Style x:Key="ValueBorder" TargetType="Border">
                                <Setter Property="BorderBrush" Value="{StaticResource Gray200}" />
                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                                <Setter Property="Padding" Value="8,5" />
                            </Style>
                            <Style x:Key="LabelText" TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource Orange700}" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="FontSize" Value="12" />
                                <Setter Property="FontWeight" Value="Medium" />
                            </Style>
                            <Style x:Key="ValueText" TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource Gray800}" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="TextWrapping" Value="Wrap" />
                                <Setter Property="FontSize" Value="13" />
                            </Style>
                        </StackPanel.Resources>

                        <!-- Vehicle Group -->
                        <Expander Header="Vehicle">
                            <Grid Background="White">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition SharedSizeGroup="LabelCol" Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Status" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueBorder}" Background="{StaticResource Orange500}"><TextBlock Text="{Binding ReleaseStatus}" Style="{StaticResource ValueText}" Foreground="White" /></Border>
                                
                                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="VehicleNo" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding VehicleNo}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="ChasisNo" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding ChassisNo}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Model" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding Model}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="EngineNo" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding EngineNo}" Style="{StaticResource ValueText}"/></Border>
                            </Grid>
                        </Expander>

                        <!-- Customer Group -->
                        <Expander Header="Customer">
                            <Grid Background="White">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition SharedSizeGroup="LabelCol" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="CustomerName" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding CustomerName}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="CustomerContactNos" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding CustomerContactNos}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="CustomerAddress" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding CustomerAddress}" Style="{StaticResource ValueText}"/></Border>
                            </Grid>
                        </Expander>

                        <!-- Finance Group -->
                        <Expander Header="Finance">
                            <Grid Background="White">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition SharedSizeGroup="LabelCol" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="FinanceName" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding Financer}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="BranchName" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding BranchName}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="FirstContactDetails" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding FirstContactDetails}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="SecondContactDetails" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding SecondContactDetails}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="ThirdContactDetails" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding ThirdContactDetails}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="5" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Address" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="5" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding Address}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="6" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Branch from excel" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="6" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding BranchFromExcel}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="7" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="ExecutiveName" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="7" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding ExecutiveName}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="8" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Level1" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="8" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding Level1}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="9" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Level1ContactNos" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="9" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding Level1ContactNos}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="10" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Level2" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="10" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding Level2}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="11" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Level2ContactNos" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="11" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding Level2ContactNos}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="12" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Level3" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="12" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding Level3}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="13" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Level3ContactNos" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="13" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding Level3ContactNos}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="14" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Level4" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="14" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding Level4}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="15" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Level4ContactNos" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="15" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding Level4ContactNos}" Style="{StaticResource ValueText}"/></Border>
                            </Grid>
                        </Expander>

                        <!-- Loan Group -->
                        <Expander Header="Loan">
                            <Grid Background="White">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition SharedSizeGroup="LabelCol" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="AgreementNo" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding AgreementNo}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Region" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding Region}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Area" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding Area}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Bucket" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding Bucket}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="GV" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding GV}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="5" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="OD" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="5" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding OD}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="6" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Sec9Available" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="6" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding Sec9Available}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="7" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Sec17Available" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="7" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding Sec17Available}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="8" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="TBRFlag" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="8" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding TBRFlag}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="9" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Seasoning" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="9" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding Seasoning}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="10" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="SenderMailId1" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="10" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding SenderMailId1}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="11" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="SenderMailId2" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="11" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding SenderMailId2}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="12" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="POS" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="12" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding POS}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="13" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="TOSS" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="13" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding TOSS}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="14" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Remark" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="14" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding Remark}" Style="{StaticResource ValueText}"/></Border>
                            </Grid>
                        </Expander>

                        <!-- Other Group -->
                        <Expander Header="Other">
                            <Grid Background="White">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition SharedSizeGroup="LabelCol" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Created on" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding CreatedOn}" Style="{StaticResource ValueText}"/></Border>
                                
                                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelBorder}"><TextBlock Text="Modified on" Style="{StaticResource LabelText}"/></Border>
                                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueBorder}"><TextBlock Text="{Binding UpdatedOn}" Style="{StaticResource ValueText}"/></Border>
                            </Grid>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
