<Page
    x:Class="VRASDesktopApp.Records.DetailsViewsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource Gray50}"
    FontFamily="Segoe UI"
    Loaded="Page_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource DashboardCard}" Margin="0,0,0,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="SEARCH LOGS" Style="{StaticResource Heading4}" />
                    <TextBlock Text="Every vehicle detail view from mobile agents — with GPS, timestamp and user info."
                               Margin="0,4,0,0" Style="{StaticResource Caption}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="btnShowMap" Content="&#x1F5FA; Show on Map"
                            Margin="0,0,8,0" Padding="12,7"
                            IsEnabled="False"
                            Click="btnShowMap_Click"
                            Style="{StaticResource PrimaryButton}" />
                    <Button x:Name="btnExportExcel" Content="&#x1F4C4; Export Excel"
                            Margin="0,0,8,0" Padding="12,7"
                            Click="btnExportExcel_Click"
                            Style="{StaticResource PrimaryButton}" />
                    <Button x:Name="btnExportPdf" Content="&#x1F4CB; Export PDF"
                            Padding="12,7"
                            Click="btnExportPdf_Click"
                            Style="{StaticResource PrimaryButton}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Filter bar -->
        <Border Grid.Row="1" Style="{StaticResource DashboardCard}" Margin="0,0,0,12">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                <StackPanel Orientation="Vertical" Margin="0,0,16,0">
                    <TextBlock Text="FROM" Style="{StaticResource FormHeading}" Margin="0,0,0,3" />
                    <DatePicker x:Name="dpFrom" Width="130" SelectedDateFormat="Short"
                                SelectedDateChanged="Filter_Changed" />
                </StackPanel>

                <StackPanel Orientation="Vertical" Margin="0,0,16,0">
                    <TextBlock Text="TO" Style="{StaticResource FormHeading}" Margin="0,0,0,3" />
                    <DatePicker x:Name="dpTo" Width="130" SelectedDateFormat="Short"
                                SelectedDateChanged="Filter_Changed" />
                </StackPanel>

                <StackPanel Orientation="Vertical" Margin="0,0,16,0">
                    <TextBlock Text="USER" Style="{StaticResource FormHeading}" Margin="0,0,0,3" />
                    <ComboBox x:Name="cbUser" Width="180" SelectionChanged="Filter_Changed"
                              DisplayMemberPath="Display" SelectedValuePath="UserId" />
                </StackPanel>

                <StackPanel Orientation="Vertical" Margin="0,0,16,0">
                    <TextBlock Text="SEARCH VRN / CHASSIS" Style="{StaticResource FormHeading}" Margin="0,0,0,3" />
                    <TextBox x:Name="txtSearch" Width="180"
                             TextChanged="txtSearch_TextChanged"
                             Padding="6,4" />
                </StackPanel>

                <Button Content="&#x21BA; Refresh"
                        VerticalAlignment="Bottom" Padding="12,7"
                        Click="btnRefresh_Click"
                        Style="{StaticResource PrimaryButton}" />

                <TextBlock x:Name="lblCount" Text=""
                           VerticalAlignment="Bottom" Margin="12,0,0,6"
                           Style="{StaticResource Caption}" />
            </WrapPanel>
        </Border>

        <!-- Loading indicator -->
        <TextBlock x:Name="lblLoading" Grid.Row="2"
                   Text="Loading…" Visibility="Collapsed"
                   Style="{StaticResource Caption}" Margin="0,0,0,8" />

        <!-- Log grid -->
        <Border Grid.Row="3" Style="{StaticResource DashboardCard}">
            <DataGrid x:Name="dgLogs"
                      Style="{StaticResource MaterialDataGrid}"
                      AutoGenerateColumns="False"
                      SelectionMode="Single"
                      SelectionChanged="dgLogs_SelectionChanged"
                      MouseDoubleClick="dgLogs_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="VRN"         Binding="{Binding VehicleNo}"  Width="120" />
                    <DataGridTextColumn Header="Chassis"     Binding="{Binding ChassisNo}"  Width="130" />
                    <DataGridTextColumn Header="Model"       Binding="{Binding Model}"      Width="140" />
                    <DataGridTextColumn Header="Agent"       Binding="{Binding UserName}"   Width="130" />
                    <DataGridTextColumn Header="Mobile"      Binding="{Binding UserMobile}" Width="110" />
                    <DataGridTextColumn Header="Address"     Binding="{Binding Address}"    Width="180" />
                    <DataGridTextColumn Header="Latitude"    Binding="{Binding Lat,StringFormat=N5}"  Width="90" />
                    <DataGridTextColumn Header="Longitude"   Binding="{Binding Lng,StringFormat=N5}"  Width="90" />
                    <DataGridTextColumn Header="Device Time" Binding="{Binding DeviceTime}" Width="140" />
                    <DataGridTextColumn Header="Server Time" Binding="{Binding ServerTime}" Width="140" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
