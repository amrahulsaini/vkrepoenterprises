<Page
    x:Class="VRASDesktopApp.Records.DetailsViewsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fa="http://schemas.fontawesome.com/icons/"
    Background="{StaticResource Gray100}"
    FontFamily="Segoe UI"
    Loaded="Page_Loaded">

    <Page.Resources>
        <!-- Icon+text action button -->
        <Style x:Key="ActionBtn" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Padding"    Value="14,8" />
            <Setter Property="FontSize"   Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- Outline / secondary action -->
        <Style x:Key="OutlineBtn" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Padding"  Value="14,8" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <!-- Filter label -->
        <Style x:Key="FilterLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Gray600}" />
            <Setter Property="Margin"     Value="0,0,0,4" />
        </Style>

        <!-- Filter input border -->
        <Style x:Key="FilterInput" TargetType="Border">
            <Setter Property="Background"      Value="White" />
            <Setter Property="BorderBrush"     Value="{StaticResource Gray200}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"    Value="6" />
            <Setter Property="Padding"         Value="8,6" />
        </Style>
    </Page.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
        </Grid.RowDefinitions>

        <!-- ── HEADER ─────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Style="{StaticResource DashboardCard}" Margin="0,0,0,14">
            <DockPanel VerticalAlignment="Center">

                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <fa:FontAwesome Icon="Solid_MagnifyingGlassLocation"
                                        FontSize="18" Foreground="{StaticResource Orange500}"
                                        VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock Text="SEARCH LOGS" Style="{StaticResource Heading4}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="Every vehicle detail view from mobile agents — GPS location, timestamps and agent info."
                               Style="{StaticResource Caption}" Margin="28,4,0,0" />
                </StackPanel>

                <!-- Action buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">

                    <Button x:Name="btnShowMap" IsEnabled="False"
                            Margin="0,0,8,0" Style="{StaticResource ActionBtn}"
                            Click="btnShowMap_Click" ToolTip="Show seizer location on map">
                        <StackPanel Orientation="Horizontal">
                            <fa:FontAwesome Icon="Solid_MapLocationDot"
                                            FontSize="13" Margin="0,0,6,0"
                                            VerticalAlignment="Center" />
                            <TextBlock Text="Show on Map" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnExportExcel" Margin="0,0,8,0"
                            Style="{StaticResource OutlineBtn}"
                            Click="btnExportExcel_Click" ToolTip="Export to Excel">
                        <StackPanel Orientation="Horizontal">
                            <fa:FontAwesome Icon="Regular_FileExcel"
                                            FontSize="13" Margin="0,0,6,0"
                                            VerticalAlignment="Center" />
                            <TextBlock Text="Excel" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnExportPdf"
                            Style="{StaticResource OutlineBtn}"
                            Click="btnExportPdf_Click" ToolTip="Export to PDF">
                        <StackPanel Orientation="Horizontal">
                            <fa:FontAwesome Icon="Regular_FilePdf"
                                            FontSize="13" Margin="0,0,6,0"
                                            VerticalAlignment="Center" />
                            <TextBlock Text="PDF" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── FILTER BAR ─────────────────────────────────────────────── -->
        <Border Grid.Row="1" Style="{StaticResource DashboardCard}" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12"   />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12"   />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12"   />
                    <ColumnDefinition Width="200"  />
                    <ColumnDefinition Width="12"   />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- From date -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="FROM" Style="{StaticResource FilterLabel}" />
                    <Border Style="{StaticResource FilterInput}">
                        <DatePicker x:Name="dpFrom" Width="120" SelectedDateFormat="Short"
                                    BorderThickness="0" Background="Transparent"
                                    SelectedDateChanged="Filter_Changed" />
                    </Border>
                </StackPanel>

                <!-- To date -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="TO" Style="{StaticResource FilterLabel}" />
                    <Border Style="{StaticResource FilterInput}">
                        <DatePicker x:Name="dpTo" Width="120" SelectedDateFormat="Short"
                                    BorderThickness="0" Background="Transparent"
                                    SelectedDateChanged="Filter_Changed" />
                    </Border>
                </StackPanel>

                <!-- User picker button -->
                <StackPanel Grid.Column="4">
                    <TextBlock Text="AGENT" Style="{StaticResource FilterLabel}" />
                    <Button x:Name="btnPickUser"
                            MinWidth="160" Height="34"
                            Style="{StaticResource OutlineBtn}"
                            Click="btnPickUser_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:FontAwesome Icon="Solid_UserGroup"
                                            FontSize="11" Margin="0,0,6,0"
                                            VerticalAlignment="Center" />
                            <TextBlock x:Name="txtPickedUser" Text="All Agents"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- VRN search -->
                <StackPanel Grid.Column="6">
                    <TextBlock Text="SEARCH VRN / CHASSIS / NAME" Style="{StaticResource FilterLabel}" />
                    <Border Style="{StaticResource FilterInput}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <fa:FontAwesome Grid.Column="0" Icon="Solid_MagnifyingGlass"
                                            FontSize="11" Foreground="{StaticResource Gray400}"
                                            VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBox Grid.Column="1" x:Name="txtSearch" Width="160"
                                     BorderThickness="0" Background="Transparent"
                                     FontSize="12" VerticalContentAlignment="Center"
                                     TextChanged="txtSearch_TextChanged" />
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Refresh button -->
                <Button Grid.Column="8" VerticalAlignment="Bottom"
                        Style="{StaticResource ActionBtn}"
                        Click="btnRefresh_Click" ToolTip="Reload from server">
                    <StackPanel Orientation="Horizontal">
                        <fa:FontAwesome Icon="Solid_ArrowsRotate"
                                        FontSize="12" Margin="0,0,6,0"
                                        VerticalAlignment="Center" />
                        <TextBlock Text="Refresh" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Record count + loading -->
                <StackPanel Grid.Column="10" VerticalAlignment="Bottom"
                            Orientation="Horizontal" Margin="10,0,0,2">
                    <fa:FontAwesome x:Name="icnLoading" Icon="Solid_CircleNotch"
                                    FontSize="12" Foreground="{StaticResource Orange500}"
                                    VerticalAlignment="Center" Margin="0,0,6,0"
                                    Visibility="Collapsed" />
                    <TextBlock x:Name="lblCount" Text=""
                               Style="{StaticResource Caption}" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── LOG GRID ───────────────────────────────────────────────── -->
        <Border Grid.Row="2" Style="{StaticResource DashboardCard}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*"    />
                </Grid.RowDefinitions>

                <!-- Column header row (custom) handled by DataGrid -->
                <DataGrid x:Name="dgLogs"
                          Grid.Row="0" Grid.RowSpan="2"
                          Style="{StaticResource MaterialDataGrid}"
                          AutoGenerateColumns="False"
                          SelectionMode="Single"
                          SelectionChanged="dgLogs_SelectionChanged"
                          MouseDoubleClick="dgLogs_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="VRN"         Binding="{Binding VehicleNo}"  Width="115" />
                        <DataGridTextColumn Header="Chassis"     Binding="{Binding ChassisNo}"  Width="130" />
                        <DataGridTextColumn Header="Model"       Binding="{Binding Model}"      Width="130" />
                        <DataGridTextColumn Header="Agent"       Binding="{Binding UserName}"   Width="120" />
                        <DataGridTextColumn Header="Mobile"      Binding="{Binding UserMobile}" Width="110" />
                        <DataGridTextColumn Header="Address"     Binding="{Binding Address}"    Width="220" />
                        <DataGridTextColumn Header="Lat"         Binding="{Binding Lat,StringFormat=N5}"  Width="85" />
                        <DataGridTextColumn Header="Lng"         Binding="{Binding Lng,StringFormat=N5}"  Width="85" />
                        <DataGridTextColumn Header="Device Time" Binding="{Binding DeviceTime}" Width="140" />
                        <DataGridTextColumn Header="Server Time" Binding="{Binding ServerTime}" Width="140" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

    </Grid>
</Page>
