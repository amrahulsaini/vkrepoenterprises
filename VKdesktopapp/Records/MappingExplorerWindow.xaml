<Window
    x:Class="VRASDesktopApp.Records.MappingExplorerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="clr-namespace:VRASDesktopApp.Material"
    Style="{StaticResource ChromeWindow}"
    FontFamily="Segoe UI"
    Title="Mapping Explorer"
    Height="640"
    Width="640"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Text="MAPPING EXPLORER"
                Style="{StaticResource Heading5}"
                VerticalAlignment="Center"
                Padding="16,0,16,0" />
            <Button
                x:Name="btnClose"
                Click="btnClose_Click"
                Grid.Column="1"
                Height="36"
                Width="36"
                Background="#FFD3D3D3"
                BorderBrush="#FF808080"
                BorderThickness="1"
                Foreground="#FF000000"
                FontFamily="Segoe UI"
                FontSize="18"
                Cursor="Hand"
                Content="✕"
                WindowChrome.IsHitTestVisibleInChrome="True" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFF" BorderThickness="1" BorderBrush="{StaticResource Gray200}" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock
                    x:Name="lblTitle"
                    Text="Columns"
                    Style="{StaticResource Heading4}"
                    Margin="16,8,16,8" />
                <DataGrid
                    x:Name="gvColumns"
                    Grid.Row="1"
                    Margin="0,8,0,0"
                    Background="#FFF"
                    BorderBrush="#00FFFFFF"
                    IsReadOnly="True"
                    CanUserAddRows="False"
                    HeadersVisibility="Column"
                    AutoGenerateColumns="False"
                    GridLinesVisibility="Horizontal"
                    HorizontalGridLinesBrush="{StaticResource Gray200}"
                    SelectionChanged="gvColumns_SelectionChanged">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="{x:Type DataGridColumnHeader}">
                            <Setter Property="Padding" Value="16,8" />
                            <Setter Property="FontWeight" Value="Medium" />
                            <Setter Property="Foreground" Value="{StaticResource Gray800}" />
                            <Setter Property="Background" Value="#00FFFFFF" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="{x:Type DataGridCell}">
                            <Setter Property="Height" Value="48" />
                            <Style.Triggers>
                                <Trigger Property="DataGridCell.IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource HighlightBackgroundBrush}" />
                                    <Setter Property="Foreground" Value="#FF000000" />
                                    <Setter Property="BorderBrush" Value="{StaticResource HighlightBackgroundBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="*" Header="Name" Binding="{Binding ColumnTypeName}">
                            <DataGridBoundColumn.ElementStyle>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="TextBlock.Padding" Value="16,0,8,0" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontWeight" Value="Medium" />
                                    <Setter Property="FontSize" Value="15" />
                                    <Setter Property="TextWrapping" Value="Wrap" />
                                </Style>
                            </DataGridBoundColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Border Grid.Column="1" Background="{StaticResource Gray200}" BorderThickness="1" BorderBrush="{StaticResource Gray200}" />

            <Border Grid.Column="2" Background="#FFF" BorderThickness="1" BorderBrush="{StaticResource Gray200}" />
            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Margin="16,8,16,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Mappings" Style="{StaticResource Heading4}" />
                </Grid>
                <DataGrid
                    x:Name="gvMappings"
                    Grid.Row="2"
                    Margin="0,8,0,0"
                    Background="#FFF"
                    BorderBrush="#00FFFFFF"
                    IsReadOnly="True"
                    CanUserAddRows="False"
                    HeadersVisibility="Column"
                    AutoGenerateColumns="False"
                    GridLinesVisibility="Horizontal"
                    HorizontalGridLinesBrush="{StaticResource Gray200}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="{x:Type DataGridColumnHeader}">
                            <Setter Property="Padding" Value="16,8" />
                            <Setter Property="FontWeight" Value="Medium" />
                            <Setter Property="Foreground" Value="{StaticResource Gray800}" />
                            <Setter Property="Background" Value="#00FFFFFF" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="{x:Type DataGridCell}">
                            <Setter Property="Height" Value="48" />
                            <Style.Triggers>
                                <Trigger Property="DataGridCell.IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource HighlightBackgroundBrush}" />
                                    <Setter Property="Foreground" Value="#FF000000" />
                                    <Setter Property="BorderBrush" Value="{StaticResource HighlightBackgroundBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="2*" Header="Mappings" Binding="{Binding Name}">
                            <DataGridBoundColumn.ElementStyle>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="TextBlock.Padding" Value="16,0,4,0" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontWeight" Value="Medium" />
                                    <Setter Property="FontSize" Value="15" />
                                    <Setter Property="TextWrapping" Value="Wrap" />
                                </Style>
                            </DataGridBoundColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <md:MaterialButton
                    x:Name="btnDelete"
                    Grid.Row="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,32,32"
                    Content="DELETE"
                    Click="btnMappingDelete_Click" />
            </Grid>
        </Grid>
    </Grid>
</Window>
