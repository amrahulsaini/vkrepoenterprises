<Window
    x:Class="VRASDesktopApp.Records.MappingExplorerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="clr-namespace:VRASDesktopApp.Material"
    Style="{StaticResource ChromeWindow}"
    FontFamily="Segoe UI"
    Title="Mapping Explorer"
    Height="640"
    Width="640"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Text="MAPPING EXPLORER"
                Style="{StaticResource Heading5}"
                VerticalAlignment="Center"
                Padding="16,0,16,0" />
            <Button
                x:Name="btnClose"
                Click="btnClose_Click"
                Grid.Column="1"
                Height="36"
                Width="36"
                Background="#FFD3D3D3"
                BorderBrush="#FF808080"
                BorderThickness="1"
                Foreground="#FF000000"
                FontFamily="Segoe UI"
                FontSize="18"
                Cursor="Hand"
                Content="✕"
                WindowChrome.IsHitTestVisibleInChrome="True" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFF" BorderThickness="1" BorderBrush="{StaticResource Gray200}" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <!-- Column type header + Add button -->
                <Grid Margin="16,8,8,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="lblTitle" Text="Columns" Style="{StaticResource Heading4}" VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            x:Name="btnAddColumnType"
                            Width="28" Height="28"
                            FontSize="18" FontWeight="Light"
                            Content="+" Cursor="Hand"
                            Background="{StaticResource Orange500}"
                            Foreground="White" BorderThickness="0"
                            ToolTip="Add new column type"
                            Click="btnAddColumnType_Click" />
                </Grid>
                <!-- Inline: add new column type -->
                <Border x:Name="brdNewColumnType"
                        Grid.Row="1"
                        Visibility="Collapsed"
                        Margin="8,0,8,6"
                        Padding="8,6"
                        Background="#FFF9F3EC"
                        BorderBrush="{StaticResource Orange500}"
                        BorderThickness="1"
                        CornerRadius="5">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="✓" Width="28" Height="28"
                                Margin="4,0,0,0" Cursor="Hand" FontSize="14"
                                Background="{StaticResource Orange500}" Foreground="White" BorderThickness="0"
                                Click="btnSaveColumnType_Click" />
                        <Button DockPanel.Dock="Right" Content="✕" Width="28" Height="28"
                                Margin="4,0,0,0" Cursor="Hand" FontSize="14"
                                Background="#FFD3D3D3" Foreground="#FF333333" BorderThickness="0"
                                Click="btnCancelColumnType_Click" />
                        <TextBox x:Name="txtNewColumnType"
                                 FontSize="13" Padding="6,4"
                                 KeyDown="txtNewColumnType_KeyDown" />
                    </DockPanel>
                </Border>
                <DataGrid
                    x:Name="gvColumns"
                    Grid.Row="2"
                    Margin="0,8,0,0"
                    Background="#FFF"
                    BorderBrush="#00FFFFFF"
                    IsReadOnly="True"
                    CanUserAddRows="False"
                    HeadersVisibility="Column"
                    AutoGenerateColumns="False"
                    GridLinesVisibility="Horizontal"
                    HorizontalGridLinesBrush="{StaticResource Gray200}"
                    SelectionChanged="gvColumns_SelectionChanged">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="{x:Type DataGridColumnHeader}">
                            <Setter Property="Padding" Value="16,8" />
                            <Setter Property="FontWeight" Value="Medium" />
                            <Setter Property="Foreground" Value="{StaticResource Gray800}" />
                            <Setter Property="Background" Value="#00FFFFFF" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="{x:Type DataGridCell}">
                            <Setter Property="Height" Value="48" />
                            <Style.Triggers>
                                <Trigger Property="DataGridCell.IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource HighlightBackgroundBrush}" />
                                    <Setter Property="Foreground" Value="#FF000000" />
                                    <Setter Property="BorderBrush" Value="{StaticResource HighlightBackgroundBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="*" Header="Name" Binding="{Binding ColumnTypeName}">
                            <DataGridBoundColumn.ElementStyle>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="TextBlock.Padding" Value="16,0,8,0" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontWeight" Value="Medium" />
                                    <Setter Property="FontSize" Value="15" />
                                    <Setter Property="TextWrapping" Value="Wrap" />
                                </Style>
                            </DataGridBoundColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Border Grid.Column="1" Background="{StaticResource Gray200}" BorderThickness="1" BorderBrush="{StaticResource Gray200}" />

            <Border Grid.Column="2" Background="#FFF" BorderThickness="1" BorderBrush="{StaticResource Gray200}" />
            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <!-- Aliases header + Add button -->
                <Grid Margin="16,8,8,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Aliases" Style="{StaticResource Heading4}" VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            x:Name="btnAddAlias"
                            Width="28" Height="28"
                            FontSize="18" FontWeight="Light"
                            Content="+" Cursor="Hand"
                            Background="{StaticResource Orange500}"
                            Foreground="White" BorderThickness="0"
                            ToolTip="Add alias for selected column"
                            Click="btnAddAlias_Click" />
                </Grid>
                <!-- Inline: add new alias -->
                <Border x:Name="brdNewAlias"
                        Grid.Row="1"
                        Visibility="Collapsed"
                        Margin="8,0,8,6"
                        Padding="8,6"
                        Background="#FFF9F3EC"
                        BorderBrush="{StaticResource Orange500}"
                        BorderThickness="1"
                        CornerRadius="5">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="✓" Width="28" Height="28"
                                Margin="4,0,0,0" Cursor="Hand" FontSize="14"
                                Background="{StaticResource Orange500}" Foreground="White" BorderThickness="0"
                                Click="btnSaveAlias_Click" />
                        <Button DockPanel.Dock="Right" Content="✕" Width="28" Height="28"
                                Margin="4,0,0,0" Cursor="Hand" FontSize="14"
                                Background="#FFD3D3D3" Foreground="#FF333333" BorderThickness="0"
                                Click="btnCancelAlias_Click" />
                        <TextBox x:Name="txtNewAlias"
                                 FontSize="13" Padding="6,4"
                                 KeyDown="txtNewAlias_KeyDown" />
                    </DockPanel>
                </Border>
                <DataGrid
                    x:Name="gvMappings"
                    Grid.Row="2"
                    Margin="0,8,0,0"
                    Background="#FFF"
                    BorderBrush="#00FFFFFF"
                    IsReadOnly="True"
                    CanUserAddRows="False"
                    HeadersVisibility="Column"
                    AutoGenerateColumns="False"
                    GridLinesVisibility="Horizontal"
                    HorizontalGridLinesBrush="{StaticResource Gray200}">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="{x:Type DataGridColumnHeader}">
                            <Setter Property="Padding" Value="16,8" />
                            <Setter Property="FontWeight" Value="Medium" />
                            <Setter Property="Foreground" Value="{StaticResource Gray800}" />
                            <Setter Property="Background" Value="#00FFFFFF" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="{x:Type DataGridCell}">
                            <Setter Property="Height" Value="48" />
                            <Style.Triggers>
                                <Trigger Property="DataGridCell.IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource HighlightBackgroundBrush}" />
                                    <Setter Property="Foreground" Value="#FF000000" />
                                    <Setter Property="BorderBrush" Value="{StaticResource HighlightBackgroundBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="2*" Header="Mappings" Binding="{Binding Name}">
                            <DataGridBoundColumn.ElementStyle>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="TextBlock.Padding" Value="16,0,4,0" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="FontWeight" Value="Medium" />
                                    <Setter Property="FontSize" Value="15" />
                                    <Setter Property="TextWrapping" Value="Wrap" />
                                </Style>
                            </DataGridBoundColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <md:MaterialButton
                    x:Name="btnDelete"
                    Grid.Row="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,32,32"
                    Content="DELETE"
                    Click="btnMappingDelete_Click" />
            </Grid>
        </Grid>
    </Grid>
</Window>
