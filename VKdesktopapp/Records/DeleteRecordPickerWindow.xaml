<Window x:Class="VRASDesktopApp.Records.DeleteRecordPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Delete Vehicle Record"
        Height="460" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource ChromeWindow}"
        Background="{StaticResource AppBackground}"
        FontFamily="{StaticResource FontBody}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource BorderHairline}"
                BorderThickness="0,0,0,1">
            <DockPanel Margin="20,0">
                <Button DockPanel.Dock="Right"
                        Content="&#xE8BB;"
                        FontFamily="Segoe MDL2 Assets" FontSize="13"
                        Width="32" Height="32"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource Gray400}" Cursor="Hand"
                        Click="btnCancel_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True" />
                <TextBlock Text="Delete Vehicle Record"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource Gray900}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="20,16,20,8">
            <TextBlock x:Name="txtPrompt"
                       TextWrapping="Wrap" FontSize="13"
                       Foreground="{StaticResource Gray700}" />
            <CheckBox x:Name="chkAll"
                      Content="Select all finances"
                      Margin="0,12,0,0"
                      FontSize="12" FontWeight="SemiBold"
                      Foreground="{StaticResource Gray600}"
                      Checked="chkAll_Checked" Unchecked="chkAll_Unchecked" />
        </StackPanel>

        <Border Grid.Row="2" Margin="20,4,20,6"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource BorderSoft}"
                BorderThickness="1" CornerRadius="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="icFinances">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BorderHairline}"
                                    BorderThickness="0,0,0,1" Padding="14,11">
                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          VerticalContentAlignment="Center">
                                    <StackPanel Margin="6,0,0,0">
                                        <TextBlock Text="{Binding Financer}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Gray900}" />
                                        <TextBlock Text="{Binding BranchLine}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextMuted}"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </CheckBox>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="3"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource BorderHairline}"
                BorderThickness="0,1,0,0" Padding="20,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Style="{StaticResource SecondaryButton}"
                        Width="96" Height="38" Margin="0,0,10,0"
                        Click="btnCancel_Click" />
                <Button x:Name="btnDelete"
                        Content="Delete Selected"
                        Style="{StaticResource DangerButton}"
                        Width="160" Height="38"
                        Click="btnDelete_Click" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
