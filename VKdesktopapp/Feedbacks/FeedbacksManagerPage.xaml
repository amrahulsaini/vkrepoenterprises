<Page
    x:Class="VRASDesktopApp.Feedbacks.FeedbacksManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:VRASDesktopApp.Feedbacks"
    Title="Feedbacks Manager"
    Background="White"
    FontFamily="Roboto">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="16,8,8,8" VerticalAlignment="Center">
            <TextBlock Text="FEEDBACKS MANAGER"
                       Style="{StaticResource Heading4}" />
            <TextBlock Text=" • "
                       Foreground="{StaticResource Gray400}"
                       FontSize="14" VerticalAlignment="Center"
                       Margin="10,0" />
            <TextBlock x:Name="lblCount"
                       Text="0 feedbacks"
                       FontSize="14" FontWeight="Bold"
                       Foreground="{StaticResource Orange700}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <DataGrid Name="dgFeedbacks" Grid.Row="1"
                  AutoGenerateColumns="False"
                  Margin="16,0,16,16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding FeedbackId}" Width="60" />
                <DataGridTextColumn Header="App User ID" Binding="{Binding AppUserId}" Width="100" />
                <DataGridTextColumn Header="Subject" Binding="{Binding Subject}" Width="200" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                <DataGridTextColumn Header="Created On" Binding="{Binding CreatedOn}" Width="140" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
