<Page
    x:Class="VRASDesktopApp.ModuleStatusPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource Gray50}"
    FontFamily="Segoe UI"
    Loaded="Page_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DashboardCard}">
            <StackPanel>
                <TextBlock Name="txtTitle" Style="{StaticResource Heading4}" Text="MODULE" />
                <TextBlock Name="txtSubtitle" Margin="0,6,0,0" Style="{StaticResource Caption}" Text="Desktop showcase module" />
            </StackPanel>
        </Border>

        <UniformGrid Grid.Row="1" Columns="2" Margin="0,18,0,18">
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Name="txtPrimaryLabel" Style="{StaticResource FormHeading}" Text="PRIMARY" />
                    <TextBlock Name="txtPrimaryValue" Style="{StaticResource StatValue}" Text="0" />
                    <TextBlock Name="txtPrimaryDescription" Style="{StaticResource Caption}" Text="Primary status" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <TextBlock Name="txtSecondaryLabel" Style="{StaticResource FormHeading}" Text="SECONDARY" />
                    <TextBlock Name="txtSecondaryValue" Style="{StaticResource StatValue}" Text="0" />
                    <TextBlock Name="txtSecondaryDescription" Style="{StaticResource Caption}" Text="Secondary status" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2"
                Background="{StaticResource Primary50}"
                BorderBrush="{StaticResource Primary100}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,18">
            <TextBlock Name="txtBanner" Style="{StaticResource Body2}" TextWrapping="Wrap" />
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="16" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="16" /><RowDefinition Height="*" /></Grid.RowDefinitions>

            <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <TextBlock Text="ROLLOUT HIGHLIGHTS" Style="{StaticResource Heading5}" Margin="0,0,0,12" />
                    <DataGrid Name="dgHighlights" Grid.Row="1" Style="{StaticResource MaterialDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Highlight" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Value" Binding="{Binding Count}" Width="80" />
                            <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <TextBlock Text="RELATED COLLECTIONS" Style="{StaticResource Heading5}" Margin="0,0,0,12" />
                    <DataGrid Name="dgCollections" Grid.Row="1" Style="{StaticResource MaterialDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Collection" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Rows" Binding="{Binding Count}" Width="120" />
                            <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.ColumnSpan="3" Style="{StaticResource DashboardCard}">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <TextBlock Text="RECENT SUPPORTING SIGNALS" Style="{StaticResource Heading5}" Margin="0,0,0,12" />
                    <DataGrid Name="dgTimeline" Grid.Row="1" Style="{StaticResource MaterialDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                            <DataGridTextColumn Header="Subtitle" Binding="{Binding Subtitle}" Width="*" />
                            <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="*" />
                            <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
