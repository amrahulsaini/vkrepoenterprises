<Window
    x:Class="VRASDesktopApp.TicketThreadWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Ticket"
    Width="620" Height="640"
    WindowStartupLocation="CenterOwner"
    Background="{StaticResource Gray50}"
    FontFamily="Segoe UI"
    Style="{StaticResource ChromeWindow}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="{StaticResource Gray900}"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="TICKET CONVERSATION" VerticalAlignment="Center" Margin="14,0,0,0"
                       FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Orange500}"
                       IsHitTestVisible="False" />
            <Button Grid.Column="1" Click="btnClose_Click"
                    Background="Transparent" BorderThickness="0" Content="&#x2715;"
                    FontSize="14" Foreground="{StaticResource Gray400}" Cursor="Hand"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Name="b" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#FFE53935" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Header: subject + status -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource Gray100}"
                BorderThickness="0,0,0,1" Padding="16,12">
            <StackPanel>
                <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left" Name="txtSubject" Text="Subject"
                               FontWeight="Bold" FontSize="16" Foreground="{StaticResource Gray900}"
                               TextWrapping="Wrap" MaxWidth="430" />
                    <Border DockPanel.Dock="Right" Name="statusChip" CornerRadius="10"
                            Background="{StaticResource Gray400}" Padding="9,2" VerticalAlignment="Center">
                        <TextBlock Name="txtStatus" Text="OPEN" FontSize="10" FontWeight="Bold" Foreground="White" />
                    </Border>
                </DockPanel>
                <TextBlock Name="txtCreated" FontSize="11" Foreground="{StaticResource Gray500}" Margin="0,3,0,0" />
            </StackPanel>
        </Border>

        <!-- Conversation thread -->
        <ScrollViewer Grid.Row="2" Name="threadScroll" VerticalScrollBarVisibility="Auto" Padding="14">
            <StackPanel Name="threadPanel" />
        </ScrollViewer>

        <!-- Reply box -->
        <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource Gray200}"
                BorderThickness="0,1,0,0" Padding="14,12">
            <DockPanel>
                <Button DockPanel.Dock="Right" Name="btnSend" Content="Send"
                        Style="{StaticResource PrimaryButton}" Height="40" Width="90"
                        Margin="10,0,0,0" Click="btnSend_Click" />
                <TextBox Name="txtReply" Style="{StaticResource MaterialTextBox}"
                         Foreground="#0E1525" CaretBrush="#0E1525"
                         Height="40" VerticalContentAlignment="Center"
                         TextWrapping="Wrap" AcceptsReturn="False"
                         ToolTip="Type a message and press Send — you can reply any number of times." />
            </DockPanel>
        </Border>
    </Grid>
</Window>
