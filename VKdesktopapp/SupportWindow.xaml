<Window
    x:Class="VRASDesktopApp.SupportWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Support"
    Width="900" Height="640"
    WindowStartupLocation="CenterOwner"
    Background="{StaticResource Gray50}"
    FontFamily="Segoe UI"
    Style="{StaticResource ChromeWindow}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Grid.Row="0" Background="{StaticResource Gray900}"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="SUPPORT &amp; TICKETS" VerticalAlignment="Center" Margin="14,0,0,0"
                       FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Orange500}"
                       IsHitTestVisible="False" />
            <Button Grid.Column="1" Name="btnClose" Click="btnClose_Click"
                    Background="Transparent" BorderThickness="0" Content="&#x2715;"
                    FontSize="14" Foreground="{StaticResource Gray400}" Cursor="Hand"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Name="b" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#FFE53935" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.3*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: Report an issue -->
            <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Report an Issue"
                               Style="{StaticResource Heading5}" Margin="0,0,0,4" />
                    <TextBlock DockPanel.Dock="Top"
                               Text="Describe the problem you're facing. Attach a screenshot if it helps. Our team will reply here."
                               Style="{StaticResource Caption}" TextWrapping="Wrap" Margin="0,0,0,14" />

                    <TextBlock DockPanel.Dock="Top" Text="SUBJECT" Style="{StaticResource FormHeading}" />
                    <TextBox DockPanel.Dock="Top" Name="txtSubject"
                             Style="{StaticResource MaterialTextBox}" Margin="0,4,0,12" />

                    <TextBlock DockPanel.Dock="Top" Text="DESCRIPTION" Style="{StaticResource FormHeading}" />
                    <TextBox DockPanel.Dock="Top" Name="txtMessage"
                             Style="{StaticResource MaterialTextBox}" Margin="0,4,0,12"
                             Height="130" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top" />

                    <!-- Screenshot attach + preview -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Name="btnAttach" Content="📎  Attach Screenshot"
                                Style="{StaticResource SecondaryButton}" Height="34"
                                Padding="14,0" Click="btnAttach_Click" />
                        <Button Name="btnRemoveShot" Content="Remove"
                                Style="{StaticResource GhostButton}" Height="34"
                                Margin="8,0,0,0" Click="btnRemoveShot_Click"
                                Visibility="Collapsed" />
                    </StackPanel>
                    <Border DockPanel.Dock="Top" Name="shotPreviewBox"
                            Height="120" Background="White" Visibility="Collapsed"
                            BorderBrush="{StaticResource Gray200}" BorderThickness="1"
                            CornerRadius="6" Margin="0,0,0,12">
                        <Image Name="imgShot" Stretch="Uniform" Margin="4" />
                    </Border>

                    <Button DockPanel.Dock="Bottom" Name="btnSubmit" Content="SUBMIT TICKET"
                            Style="{StaticResource PrimaryButton}" Height="42"
                            Click="btnSubmit_Click" />
                    <Grid /> <!-- filler -->
                </DockPanel>
            </Border>

            <!-- RIGHT: My tickets -->
            <Border Grid.Column="2" Style="{StaticResource DashboardCard}" Padding="0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" BorderBrush="{StaticResource Gray100}"
                            BorderThickness="0,0,0,1" Padding="16,12">
                        <DockPanel LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left" Text="My Tickets"
                                       Style="{StaticResource Heading6}" VerticalAlignment="Center" />
                            <Button DockPanel.Dock="Right" Name="btnRefresh"
                                    Width="34" Height="34" Cursor="Hand"
                                    Background="Transparent" BorderThickness="0"
                                    ToolTip="Refresh" Click="btnRefresh_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Name="b" Background="{TemplateBinding Background}" CornerRadius="17">
                                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="16" FontWeight="Bold"
                                                       Foreground="{StaticResource Gray700}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="{StaticResource Gray200}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DockPanel>
                    </Border>

                    <TextBlock Name="txtEmpty" DockPanel.Dock="Top"
                               Text="No tickets yet. Report an issue on the left."
                               Foreground="{StaticResource Gray400}" FontSize="13"
                               Margin="16,16,0,0" Visibility="Collapsed" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl Name="icTickets" Margin="12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" BorderBrush="{StaticResource Gray200}"
                                            BorderThickness="1" CornerRadius="8"
                                            Padding="12" Margin="0,0,0,10">
                                        <StackPanel>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock DockPanel.Dock="Left" Text="{Binding Subject}"
                                                           FontWeight="Bold" FontSize="14"
                                                           Foreground="{StaticResource Gray900}"
                                                           TextWrapping="Wrap" MaxWidth="300" />
                                                <Border DockPanel.Dock="Right" CornerRadius="10"
                                                        Background="{Binding StatusBrush}" Padding="9,2">
                                                    <TextBlock Text="{Binding StatusText}" FontSize="10"
                                                               FontWeight="Bold" Foreground="White" />
                                                </Border>
                                            </DockPanel>
                                            <TextBlock Text="{Binding CreatedAt}" FontSize="10"
                                                       Foreground="{StaticResource Gray500}" Margin="0,3,0,6" />
                                            <TextBlock Text="{Binding Message}" FontSize="12"
                                                       Foreground="{StaticResource Gray700}"
                                                       TextWrapping="Wrap" />
                                            <Image Source="{Binding ShotSource}" Stretch="Uniform"
                                                   MaxHeight="120" HorizontalAlignment="Left" Margin="0,8,0,0"
                                                   Visibility="{Binding ShotVisibility}" />
                                            <!-- Admin reply -->
                                            <Border Background="{StaticResource Primary50}" CornerRadius="6"
                                                    Padding="10" Margin="0,8,0,0"
                                                    Visibility="{Binding ReplyVisibility}">
                                                <StackPanel>
                                                    <TextBlock Text="CRMRS SUPPORT REPLIED" FontSize="9"
                                                               FontWeight="Bold" Foreground="{StaticResource Orange700}" />
                                                    <TextBlock Text="{Binding AdminReply}" FontSize="12"
                                                               Foreground="{StaticResource Gray800}"
                                                               TextWrapping="Wrap" Margin="0,3,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
