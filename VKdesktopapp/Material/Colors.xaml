<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════════════════════════════
         CRMS — Design System: Colour Tokens
         Brand: Black / White / Orange.  Every key here is consumed across
         25+ XAML files — keys are STABLE, only values are tuned.
         ════════════════════════════════════════════════════════════════════ -->

    <!-- ── Orange accent ramp ── -->
    <Color x:Key="cOrange50">#FFFFF4E5</Color>
    <Color x:Key="cOrange100">#FFFFE3BF</Color>
    <Color x:Key="cOrange200">#FFFFCD8C</Color>
    <Color x:Key="cOrange300">#FFFFB74D</Color>
    <Color x:Key="cOrange400">#FFFFA422</Color>
    <Color x:Key="cOrange500">#FFFF9800</Color>
    <Color x:Key="cOrange600">#FFF57C00</Color>
    <Color x:Key="cOrange700">#FFE36C00</Color>
    <Color x:Key="cOrange800">#FFCE5E00</Color>
    <Color x:Key="cOrange900">#FFB04E00</Color>

    <!-- ── Neutral ramp (slightly cool grey for a cleaner, modern surface) ── -->
    <Color x:Key="cGray50">#FFF7F8FA</Color>
    <Color x:Key="cGray100">#FFEEF0F3</Color>
    <Color x:Key="cGray200">#FFE2E5EA</Color>
    <Color x:Key="cGray300">#FFCBD0D8</Color>
    <Color x:Key="cGray400">#FFA6ADB8</Color>
    <Color x:Key="cGray500">#FF818A97</Color>
    <Color x:Key="cGray600">#FF5C6470</Color>
    <Color x:Key="cGray700">#FF3D444E</Color>
    <Color x:Key="cGray800">#FF252A31</Color>
    <Color x:Key="cGray900">#FF161A1F</Color>
    <Color x:Key="cBlack">#FF0D0F12</Color>
    <Color x:Key="cWhite">#FFFFFFFF</Color>

    <!-- ── Status colours ── -->
    <Color x:Key="cRed500">#FFE5484D</Color>
    <Color x:Key="cGreen500">#FF30A46C</Color>
    <Color x:Key="cAmber500">#FFE5A50A</Color>
    <Color x:Key="cBlue500">#FF3B7DD8</Color>

    <!-- ═══════════════ Brushes ═══════════════ -->

    <!-- Primary / accent (orange) -->
    <SolidColorBrush x:Key="Primary50"  Color="{StaticResource cOrange50}" />
    <SolidColorBrush x:Key="Primary100" Color="{StaticResource cOrange100}" />
    <SolidColorBrush x:Key="Primary200" Color="{StaticResource cOrange200}" />
    <SolidColorBrush x:Key="Primary300" Color="{StaticResource cOrange300}" />
    <SolidColorBrush x:Key="Primary400" Color="{StaticResource cOrange400}" />
    <SolidColorBrush x:Key="Primary500" Color="{StaticResource cOrange500}" />
    <SolidColorBrush x:Key="Primary600" Color="{StaticResource cOrange600}" />
    <SolidColorBrush x:Key="Primary700" Color="{StaticResource cOrange700}" />
    <SolidColorBrush x:Key="Primary800" Color="{StaticResource cOrange800}" />
    <SolidColorBrush x:Key="Primary900" Color="{StaticResource cOrange900}" />

    <SolidColorBrush x:Key="Accent700" Color="{StaticResource cOrange700}" />
    <SolidColorBrush x:Key="Yellow700" Color="{StaticResource cOrange700}" />

    <SolidColorBrush x:Key="Orange500" Color="{StaticResource cOrange500}" />
    <SolidColorBrush x:Key="Orange600" Color="{StaticResource cOrange600}" />
    <SolidColorBrush x:Key="Orange700" Color="{StaticResource cOrange700}" />

    <!-- Neutrals -->
    <SolidColorBrush x:Key="Gray50"  Color="{StaticResource cGray50}" />
    <SolidColorBrush x:Key="Gray100" Color="{StaticResource cGray100}" />
    <SolidColorBrush x:Key="Gray200" Color="{StaticResource cGray200}" />
    <SolidColorBrush x:Key="Gray300" Color="{StaticResource cGray300}" />
    <SolidColorBrush x:Key="Gray400" Color="{StaticResource cGray400}" />
    <SolidColorBrush x:Key="Gray500" Color="{StaticResource cGray500}" />
    <SolidColorBrush x:Key="Gray600" Color="{StaticResource cGray600}" />
    <SolidColorBrush x:Key="Gray700" Color="{StaticResource cGray700}" />
    <SolidColorBrush x:Key="Gray800" Color="{StaticResource cGray800}" />
    <SolidColorBrush x:Key="Gray900" Color="{StaticResource cGray900}" />

    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource cBlack}" />
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource cWhite}" />

    <!-- Status -->
    <SolidColorBrush x:Key="Red500"   Color="{StaticResource cRed500}" />
    <SolidColorBrush x:Key="Green500" Color="{StaticResource cGreen500}" />
    <SolidColorBrush x:Key="Amber500" Color="{StaticResource cAmber500}" />
    <SolidColorBrush x:Key="Blue500"  Color="{StaticResource cBlue500}" />

    <!-- ═══════════════ Semantic tokens (new) ═══════════════ -->
    <!-- Use these in new/updated XAML for intent-based styling. -->

    <SolidColorBrush x:Key="Surface"        Color="{StaticResource cWhite}" />
    <SolidColorBrush x:Key="SurfaceAlt"     Color="{StaticResource cGray50}" />
    <SolidColorBrush x:Key="SurfaceSunken"  Color="{StaticResource cGray100}" />
    <SolidColorBrush x:Key="AppBackground"  Color="{StaticResource cGray50}" />

    <SolidColorBrush x:Key="BorderSoft"     Color="{StaticResource cGray200}" />
    <SolidColorBrush x:Key="BorderHairline" Color="{StaticResource cGray100}" />
    <SolidColorBrush x:Key="BorderStrong"   Color="{StaticResource cGray300}" />
    <SolidColorBrush x:Key="Divider"        Color="{StaticResource cGray100}" />

    <SolidColorBrush x:Key="TextPrimary"    Color="{StaticResource cGray900}" />
    <SolidColorBrush x:Key="TextSecondary"  Color="{StaticResource cGray600}" />
    <SolidColorBrush x:Key="TextMuted"      Color="{StaticResource cGray500}" />
    <SolidColorBrush x:Key="TextOnDark"     Color="{StaticResource cWhite}" />

    <SolidColorBrush x:Key="HoverOverlay"   Color="{StaticResource cGray50}" />
    <SolidColorBrush x:Key="SelectedTint"   Color="{StaticResource cOrange50}" />

    <!-- Soft status tints for chips / banners -->
    <SolidColorBrush x:Key="SuccessTint" Color="#FFE7F6EE" />
    <SolidColorBrush x:Key="SuccessText" Color="#FF1E7A4D" />
    <SolidColorBrush x:Key="WarningTint" Color="#FFFDF3D8" />
    <SolidColorBrush x:Key="WarningText" Color="#FF9A6B00" />
    <SolidColorBrush x:Key="DangerTint"  Color="#FFFCE9E9" />
    <SolidColorBrush x:Key="DangerText"  Color="#FFB42B30" />
    <SolidColorBrush x:Key="InfoTint"    Color="#FFE6EFFA" />
    <SolidColorBrush x:Key="InfoText"    Color="#FF2C5F9E" />

    <!-- Shadow colour used by drop-shadow effects -->
    <Color x:Key="cShadow">#FF161A1F</Color>

</ResourceDictionary>
