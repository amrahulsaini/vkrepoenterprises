<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════════════════════════════
         CRMS — Design System: Styles
         Every x:Key here is referenced across the app — keys are STABLE.
         This file upgrades the visual language: soft elevation, refined
         typography, focus-aware inputs, a full button family and polished
         data grids — applied app-wide through shared resource keys.
         ════════════════════════════════════════════════════════════════════ -->

    <!-- Legacy highlight brushes (kept for back-compat) -->
    <SolidColorBrush x:Key="HighlightBackgroundBrush" Color="#FFE6EFFA" />
    <SolidColorBrush x:Key="HighlightForegroundBrush" Color="#FF2C5F9E" />

    <!-- ─────────────────────────────────────────────────────────────────
         Elevation — reusable soft drop shadows
         ───────────────────────────────────────────────────────────────── -->
    <DropShadowEffect x:Key="ShadowXs" Color="{StaticResource cShadow}"
                      BlurRadius="6"  ShadowDepth="1" Direction="270" Opacity="0.08" />
    <DropShadowEffect x:Key="ShadowSm" Color="{StaticResource cShadow}"
                      BlurRadius="14" ShadowDepth="2" Direction="270" Opacity="0.10" />
    <DropShadowEffect x:Key="ShadowMd" Color="{StaticResource cShadow}"
                      BlurRadius="26" ShadowDepth="5" Direction="270" Opacity="0.14" />
    <DropShadowEffect x:Key="ShadowLg" Color="{StaticResource cShadow}"
                      BlurRadius="44" ShadowDepth="10" Direction="270" Opacity="0.20" />

    <!-- ─────────────────────────────────────────────────────────────────
         Window chrome (borderless; title bar drawn per-window)
         ───────────────────────────────────────────────────────────────── -->
    <Style x:Key="ChromeWindow" TargetType="Window">
        <Setter Property="MaxHeight" Value="{x:Static SystemParameters.MaximizedPrimaryScreenHeight}" />
        <Setter Property="MaxWidth"  Value="{x:Static SystemParameters.MaximizedPrimaryScreenWidth}" />
        <Setter Property="WindowStyle" Value="None" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        <Setter Property="WindowChrome.WindowChrome">
            <Setter.Value>
                <WindowChrome CaptionHeight="32" ResizeBorderThickness="4" GlassFrameThickness="0" />
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Window">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource Gray800}" BorderThickness="1">
                        <AdornerDecorator>
                            <ContentPresenter />
                        </AdornerDecorator>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────
         Typography
         ───────────────────────────────────────────────────────────────── -->
    <Style x:Key="Heading3" TargetType="TextBlock">
        <Setter Property="FontSize" Value="25" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Gray900}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <Style x:Key="Heading4" TargetType="TextBlock">
        <Setter Property="FontSize" Value="21" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Gray900}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <Style x:Key="Heading5" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Gray900}" />
    </Style>

    <Style x:Key="Heading6" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Gray800}" />
    </Style>

    <!-- Body / Caption sizes bumped one step so admin pages stay readable
         even on dense list rows and small laptop screens. -->
    <Style x:Key="Body1" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Gray800}" />
    </Style>

    <Style x:Key="Body2" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Gray700}" />
    </Style>

    <Style x:Key="Caption" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource Gray600}" />
    </Style>

    <!-- Uppercase tracking label used above stat values / form groups -->
    <Style x:Key="FormHeading" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Gray500}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="StatValue" TargetType="TextBlock">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Gray900}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <!-- New helpers (opt-in) -->
    <Style x:Key="PageTitle" TargetType="TextBlock" BasedOn="{StaticResource Heading4}" />
    <Style x:Key="PageSubtitle" TargetType="TextBlock" BasedOn="{StaticResource Caption}">
        <Setter Property="Margin" Value="0,3,0,0" />
    </Style>
    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Gray800}" />
    </Style>
    <Style x:Key="Overline" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Gray500}" />
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────
         Cards / surfaces
         ───────────────────────────────────────────────────────────────── -->
    <Style x:Key="DashboardCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderHairline}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Effect" Value="{StaticResource ShadowSm}" />
    </Style>

    <!-- More pronounced elevation (modals / hero cards) -->
    <Style x:Key="CardElevated" TargetType="Border" BasedOn="{StaticResource DashboardCard}">
        <Setter Property="Effect" Value="{StaticResource ShadowMd}" />
    </Style>

    <!-- Flat panel — no shadow, hairline border (nested sections) -->
    <Style x:Key="FlatPanel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderHairline}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <!-- Status chip / badge -->
    <Style x:Key="Chip" TargetType="Border">
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="9,3" />
        <Setter Property="Background" Value="{StaticResource SurfaceSunken}" />
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────
         Inputs — TextBox with focus highlight
         ───────────────────────────────────────────────────────────────── -->
    <Style x:Key="MaterialTextBox" TargetType="TextBox">
        <!-- Bumped one step (14 → 16) so the typed text and placeholder
             read easily on dense admin forms. Padding also widened so the
             input feels roomy rather than cramped. -->
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderStrong}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="{StaticResource Surface}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="CaretBrush" Value="{StaticResource Orange600}" />
        <Setter Property="SelectionBrush" Value="{StaticResource Primary200}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Gray400}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Orange500}" />
                            <Setter TargetName="bd" Property="BorderThickness" Value="1.6" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource SurfaceSunken}" />
                            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────
         Data grid — clean rows, sticky-looking header, orange selection
         ───────────────────────────────────────────────────────────────── -->
    <Style x:Key="MaterialColumnHeader" TargetType="DataGridColumnHeader">
        <Setter Property="Height" Value="48" />
        <Setter Property="Background" Value="{StaticResource SurfaceAlt}" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
        <!-- Bumped header to 13pt Bold so column names read clearly on
             dense data grids (Records, Reports, Confirmations, etc.). -->
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridColumnHeader">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource BorderSoft}"
                            BorderThickness="0,0,0,1.5"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MaterialRow" TargetType="DataGridRow">
        <Setter Property="Background" Value="{StaticResource Surface}" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource HoverOverlay}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource SelectedTint}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="MaterialCell" TargetType="DataGridCell">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Cell style WITHOUT a control template — used by the implicit DataGrid
         style below so bare grids keep cell editing intact (no custom template)
         while losing the default cell border + focus rectangle. -->
    <Style x:Key="MaterialCellSafe" TargetType="DataGridCell">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="MaterialDataGrid" TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderHairline}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="RowHeight" Value="46" />
        <Setter Property="ColumnHeaderHeight" Value="48" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderHairline}" />
        <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="SelectionMode" Value="Single" />
        <Setter Property="SelectionUnit" Value="FullRow" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="RowBackground" Value="{StaticResource Surface}" />
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource MaterialColumnHeader}" />
        <Setter Property="RowStyle" Value="{StaticResource MaterialRow}" />
        <Setter Property="CellStyle" Value="{StaticResource MaterialCell}" />
        <!-- Virtualization defaults: only the visible rows are realised as
             WPF visuals. Without these the grid spawns one visual tree per
             row regardless of viewport — pages with 50k+ records (vehicle
             search, confirmations, audit log) freeze the UI on first load
             and chew through hundreds of MB of RAM. Recycling reuses row
             visuals as the user scrolls. -->
        <Setter Property="EnableRowVirtualization" Value="True" />
        <Setter Property="EnableColumnVirtualization" Value="True" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────
         Implicit default for EVERY bare <DataGrid> (no explicit Style).
         The old default-WPF grid (heavy gridlines, baby-blue selection, harsh
         borders) was the "government website" look. This gives every grid the
         clean app style. Visual-ONLY: it does not set IsReadOnly /
         AutoGenerateColumns / SelectionMode and uses a template-less cell style,
         so grid behaviour — including the editable upload-validator grid — is
         unchanged. Grids that opt into {StaticResource MaterialDataGrid}
         keep that (explicit beats implicit).
         ───────────────────────────────────────────────────────────────── -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderHairline}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="RowHeight" Value="44" />
        <Setter Property="ColumnHeaderHeight" Value="46" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderHairline}" />
        <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
        <Setter Property="RowBackground" Value="{StaticResource Surface}" />
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource MaterialColumnHeader}" />
        <Setter Property="RowStyle" Value="{StaticResource MaterialRow}" />
        <Setter Property="CellStyle" Value="{StaticResource MaterialCellSafe}" />
        <Setter Property="EnableRowVirtualization" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel" />
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────
         Buttons — full family
         ───────────────────────────────────────────────────────────────── -->

    <!-- Primary (solid orange) -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{StaticResource Orange500}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Height" Value="42" />
        <Setter Property="Padding" Value="22,0" />
        <!-- Buttons across the app bumped one step (13 → 14, weight Bold)
             so primary actions read like primary actions on dense pages. -->
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Orange600}" />
                            <Setter TargetName="border" Property="Effect" Value="{StaticResource ShadowSm}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Orange700}" />
                            <Setter TargetName="border" Property="Effect" Value="{x:Null}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary (neutral fill) -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Gray800}" />
        <Setter Property="Background" Value="{StaticResource Gray100}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Height" Value="42" />
        <Setter Property="Padding" Value="22,0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray300}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Outline (white fill, orange border) -->
    <Style x:Key="OutlineButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Orange700}" />
        <Setter Property="Background" Value="{StaticResource Surface}" />
        <Setter Property="BorderThickness" Value="1.4" />
        <Setter Property="BorderBrush" Value="{StaticResource Orange500}" />
        <Setter Property="Height" Value="42" />
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Primary50}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Primary100}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Ghost (transparent until hover) -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Gray700}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Padding" Value="14,0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray100}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Danger (destructive actions) -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{StaticResource Red500}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.90" />
                            <Setter TargetName="border" Property="Effect" Value="{StaticResource ShadowSm}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Opacity" Value="0.80" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Icon button — square, transparent, hover tint -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Gray600}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray100}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Gray200}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────
         Dashboard tile (slide-out menu / quick actions)
         ───────────────────────────────────────────────────────────────── -->
    <Style x:Key="DashboardTileButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Gray900}" />
        <Setter Property="Background" Value="{StaticResource Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderHairline}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="90" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10" SnapsToDevicePixels="True">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource Orange500}" />
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Primary50}" />
                            <Setter TargetName="border" Property="Effect" Value="{StaticResource ShadowSm}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource Primary100}" />
                            <Setter TargetName="border" Property="Effect" Value="{x:Null}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────
         Scrollbars — slim, modern (applies app-wide)
         ───────────────────────────────────────────────────────────────── -->
    <Style x:Key="ScrollThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="t" CornerRadius="5" Background="{StaticResource Gray300}"
                            Margin="3" SnapsToDevicePixels="True" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="t" Property="Background" Value="{StaticResource Gray400}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="t" Property="Background" Value="{StaticResource Gray500}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Vertical scrollbar template -->
    <ControlTemplate x:Key="ScrollBarVerticalTemplate" TargetType="ScrollBar">
        <Grid Background="Transparent">
            <Track x:Name="PART_Track" IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ScrollThumb}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <!-- Horizontal scrollbar template -->
    <ControlTemplate x:Key="ScrollBarHorizontalTemplate" TargetType="ScrollBar">
        <Grid Background="Transparent">
            <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0" Focusable="False" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ScrollThumb}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0" Focusable="False" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <!-- Template is swapped per-orientation from Style.Triggers (NOT from
         ControlTemplate.Triggers — WPF forbids setting Template there). -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="12" />
        <Setter Property="Template" Value="{StaticResource ScrollBarVerticalTemplate}" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width"  Value="Auto" />
                <Setter Property="Height" Value="12" />
                <Setter Property="Template" Value="{StaticResource ScrollBarHorizontalTemplate}" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
