<Page x:Class="CRMRSDesktopApp.Couriers.CouriersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F5F5">
    <Page.Resources>
        <Style x:Key="CellText" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8,0,8,0" />
            <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
        </Style>
        <Style x:Key="GridHeader" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#1565C0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="BorderBrush" Value="#0D47A1" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style x:Key="Fld" TargetType="TextBox">
            <Setter Property="Height" Value="32" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </Page.Resources>

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Margin="0,0,14,0">
            <TextBlock DockPanel.Dock="Top" Text="Courier Department" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource Accent}" Margin="0,0,0,8" />

            <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                <TextBlock Text="From" VerticalAlignment="Center" Foreground="#666" Margin="0,0,6,0" />
                <DatePicker Name="dpFrom" Width="130" Margin="0,0,14,0" />
                <TextBlock Text="To" VerticalAlignment="Center" Foreground="#666" Margin="0,0,6,0" />
                <DatePicker Name="dpTo" Width="130" Margin="0,0,14,0" />
                <TextBlock Text="Billing" VerticalAlignment="Center" Foreground="#666" Margin="0,0,6,0" />
                <ComboBox Name="cmbAction" Width="150" Margin="0,0,14,0" SelectedIndex="0">
                    <ComboBoxItem Content="All" />
                    <ComboBoxItem Content="OK for billing" />
                    <ComboBoxItem Content="Hold for collection" />
                    <ComboBoxItem Content="Collection done" />
                    <ComboBoxItem Content="Cancel" />
                    <ComboBoxItem Content="Billing Done" />
                </ComboBox>
                <Button Name="btnLoad" Content="Load" Width="90" Height="30" FontWeight="Bold"
                        Background="#1565C0" Foreground="White" BorderThickness="0" Cursor="Hand" Click="btnLoad_Click" />
                <TextBlock Name="txtStatus" VerticalAlignment="Center" Foreground="#888" FontSize="12" Margin="14,0,0,0" />
            </WrapPanel>

            <DataGrid Name="grid" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="All"
                      RowHeaderWidth="0" SelectionMode="Single"
                      Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                      CanUserResizeColumns="True" CanUserSortColumns="True"
                      ColumnHeaderStyle="{StaticResource GridHeader}"
                      RowBackground="White" AlternatingRowBackground="#F3F7FB"
                      FontSize="12.5" RowHeight="32"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      SelectionChanged="grid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Repo Date" Binding="{Binding RepoDate}" Width="120" MinWidth="90" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Loan No" Binding="{Binding LoanNo}" Width="150" MinWidth="90" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Invoice No" Binding="{Binding InvoiceNo}" Width="90" MinWidth="70" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Customer Name" Binding="{Binding CustomerName}" Width="150" MinWidth="90" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Branch" Binding="{Binding BranchName}" Width="120" MinWidth="80" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Vehicle No" Binding="{Binding VehicleNo}" Width="110" MinWidth="80" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Model/Maker" Binding="{Binding Model}" Width="160" MinWidth="90" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Chassis No" Binding="{Binding ChassisNo}" Width="150" MinWidth="90" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Engine No" Binding="{Binding EngineNo}" Width="140" MinWidth="90" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Agent Name" Binding="{Binding AgentName}" Width="130" MinWidth="80" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Parking Yard Name" Binding="{Binding ParkingYardName}" Width="160" MinWidth="90" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Parking Yard Mobile" Binding="{Binding ParkingYardMobile}" Width="130" MinWidth="90" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Load Details" Binding="{Binding LoadDetails}" Width="120" MinWidth="80" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Additional Charges Notes, Amount" Binding="{Binding AddlCharges}" Width="200" MinWidth="110" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Confirmation By (Name, Mobile)" Binding="{Binding ConfirmationBy}" Width="190" MinWidth="110" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Executive Name" Binding="{Binding ExecutiveName}" Width="130" MinWidth="80" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Collection Update" Binding="{Binding CollectionUpdate}" Width="150" MinWidth="90" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Finance" Binding="{Binding FinanceName}" Width="130" MinWidth="80" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Billing" Binding="{Binding ActionText}" Width="120" MinWidth="80" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Repo Charges" Binding="{Binding RepoChargesText}" Width="100" MinWidth="70" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Advance" Binding="{Binding AdvanceText}" Width="90" MinWidth="70" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Courier" Binding="{Binding CourierYn}" Width="70" MinWidth="60" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="Banker Address" Binding="{Binding BankerAddress}" Width="150" MinWidth="90" ElementStyle="{StaticResource CellText}" />
                    <DataGridTextColumn Header="POD Number" Binding="{Binding PodNumber}" Width="110" MinWidth="70" ElementStyle="{StaticResource CellText}" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <Border Grid.Column="1" Background="White" CornerRadius="8" BorderBrush="#E0E0E0" BorderThickness="1" Padding="16">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Update Courier Details" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource Accent}" Margin="0,0,0,4" />
                <TextBlock DockPanel.Dock="Top" Name="txtSel" Text="Select a record from the list."
                           FontSize="12" Foreground="#888" TextWrapping="Wrap" Margin="0,0,0,8" />

                <Button DockPanel.Dock="Top" Name="btnDetails" Content="View all details" Height="30" IsEnabled="False"
                        Margin="0,0,0,10" Cursor="Hand" Click="btnDetails_Click" />

                <Border DockPanel.Dock="Top" Name="pnlBilled" Background="#EAF4EA" CornerRadius="6" Padding="10,8"
                        Margin="0,0,0,12" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Name="txtInvoice" Text="" FontSize="12.5" FontWeight="Bold" Foreground="#2E7D32" Margin="0,0,0,6" />
                        <Button Name="btnDownloadBill" Content="Download bill" Height="28" Padding="10,0"
                                HorizontalAlignment="Left" Background="#1565C0" Foreground="White" BorderThickness="0"
                                Cursor="Hand" Click="btnDownloadBill_Click" />
                    </StackPanel>
                </Border>

                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock Name="txtFormStatus" Foreground="#2E7D32" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8" />
                    <Button Name="btnSubmit" Content="Submit" Height="40" FontWeight="Bold" IsEnabled="False"
                            Background="{StaticResource Accent}" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="btnSubmit_Click" />
                    <Button Name="btnClear" Content="Clear this record's entries" Height="32" Margin="0,8,0,0" IsEnabled="False"
                            Background="White" Foreground="#C62828" BorderBrush="#E0A0A0" BorderThickness="1"
                            Cursor="Hand" Click="btnClear_Click" />
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Name="pnlForm" IsEnabled="False">
                        <TextBlock Text="Repo Charges" Foreground="#666" FontSize="12" Margin="0,0,0,3" />
                        <TextBox Name="txtRepoCharges" Style="{StaticResource Fld}" />

                        <TextBlock Text="Advance" Foreground="#666" FontSize="12" Margin="0,0,0,3" />
                        <TextBox Name="txtAdvance" Style="{StaticResource Fld}" />

                        <TextBlock Text="Courier" Foreground="#666" FontSize="12" Margin="0,0,0,3" />
                        <ComboBox Name="cmbCourier" Height="32" Margin="0,0,0,10" SelectedIndex="0">
                            <ComboBoxItem Content="No" />
                            <ComboBoxItem Content="Yes" />
                        </ComboBox>

                        <TextBlock Text="Banker Address" Foreground="#666" FontSize="12" Margin="0,0,0,3" />
                        <TextBox Name="txtBankerAddress" Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalContentAlignment="Top" Padding="8,4" Margin="0,0,0,10"
                                 VerticalScrollBarVisibility="Auto" />

                        <TextBlock Text="POD Number" Foreground="#666" FontSize="12" Margin="0,0,0,3" />
                        <TextBox Name="txtPod" Style="{StaticResource Fld}" />
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Page>
