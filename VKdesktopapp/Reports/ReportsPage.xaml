<Page
    x:Class="CRMRSDesktopApp.Reports.ReportsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource Gray50}"
    FontFamily="{StaticResource FontBody}"
    Loaded="Page_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DashboardCard}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="REPORTS &amp; EXPORT" Style="{StaticResource Heading4}" />
                <TextBlock Text="Export all data sets to Excel (.xlsx) or PDF. Large exports are fetched in pages and assembled locally."
                           Margin="0,6,0,0" Style="{StaticResource Caption}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="35*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="65*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <Border Style="{StaticResource DashboardCard}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Users" Style="{StaticResource Heading6}" />
                            <TextBlock Text="All app users and their account details"
                                       Style="{StaticResource Caption}" Margin="0,4,0,12" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Export Excel"
                                        Tag="Users_Excel"
                                        Click="btnExport_Click"
                                        Style="{StaticResource PrimaryButton}"
                                        x:Name="btnUsersExcel"
                                        MinWidth="110" Margin="0,0,8,0" />
                                <Button Content="Export PDF"
                                        Tag="Users_Pdf"
                                        Click="btnExport_Click"
                                        Style="{StaticResource SecondaryButton}"
                                        x:Name="btnUsersPdf"
                                        MinWidth="110" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource DashboardCard}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Subscriptions" Style="{StaticResource Heading6}" />
                            <TextBlock Text="All subscription records with user info"
                                       Style="{StaticResource Caption}" Margin="0,4,0,12" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Export Excel"
                                        Tag="Subscriptions_Excel"
                                        Click="btnExport_Click"
                                        Style="{StaticResource PrimaryButton}"
                                        x:Name="btnSubsExcel"
                                        MinWidth="110" Margin="0,0,8,0" />
                                <Button Content="Export PDF"
                                        Tag="Subscriptions_Pdf"
                                        Click="btnExport_Click"
                                        Style="{StaticResource SecondaryButton}"
                                        x:Name="btnSubsPdf"
                                        MinWidth="110" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource DashboardCard}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Vehicle Records" Style="{StaticResource Heading6}" />
                            <TextBlock Text="All vehicle records with finance and branch info"
                                       Style="{StaticResource Caption}" Margin="0,4,0,12" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Export Excel"
                                        Tag="VehicleRecords_Excel"
                                        Click="btnExport_Click"
                                        Style="{StaticResource PrimaryButton}"
                                        x:Name="btnVehicleExcel"
                                        MinWidth="110" Margin="0,0,8,0" />
                                <Button Content="Export PDF"
                                        Tag="VehicleRecords_Pdf"
                                        Click="btnExport_Click"
                                        Style="{StaticResource SecondaryButton}"
                                        x:Name="btnVehiclePdf"
                                        MinWidth="110" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource DashboardCard}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="RC Records" Style="{StaticResource Heading6}" />
                            <TextBlock Text="Vehicle records indexed by RC number"
                                       Style="{StaticResource Caption}" Margin="0,4,0,12" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Export Excel"
                                        Tag="RcRecords_Excel"
                                        Click="btnExport_Click"
                                        Style="{StaticResource PrimaryButton}"
                                        x:Name="btnRcExcel"
                                        MinWidth="110" Margin="0,0,8,0" />
                                <Button Content="Export PDF"
                                        Tag="RcRecords_Pdf"
                                        Click="btnExport_Click"
                                        Style="{StaticResource SecondaryButton}"
                                        x:Name="btnRcPdf"
                                        MinWidth="110" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource DashboardCard}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Chassis Records" Style="{StaticResource Heading6}" />
                            <TextBlock Text="Vehicle records indexed by chassis number"
                                       Style="{StaticResource Caption}" Margin="0,4,0,12" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Export Excel"
                                        Tag="ChassisRecords_Excel"
                                        Click="btnExport_Click"
                                        Style="{StaticResource PrimaryButton}"
                                        x:Name="btnChassisExcel"
                                        MinWidth="110" Margin="0,0,8,0" />
                                <Button Content="Export PDF"
                                        Tag="ChassisRecords_Pdf"
                                        Click="btnExport_Click"
                                        Style="{StaticResource SecondaryButton}"
                                        x:Name="btnChassisPdf"
                                        MinWidth="110" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Export Status" Style="{StaticResource Heading5}" Margin="0,0,0,16" />

                    <Border Grid.Row="1" x:Name="panelIdle"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Select a report to export"
                                       Style="{StaticResource Body1}"
                                       Foreground="{StaticResource Gray400}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="1" x:Name="panelActive" Visibility="Collapsed">

                        <TextBlock x:Name="lblExportName"
                                   Style="{StaticResource Heading6}"
                                   Margin="0,0,0,12" />

                        <ProgressBar x:Name="pbExport"
                                     Minimum="0" Maximum="100"
                                     Height="8"
                                     Margin="0,0,0,6">
                            <ProgressBar.Style>
                                <Style TargetType="ProgressBar">
                                    <Setter Property="Foreground" Value="{StaticResource Orange500}" />
                                    <Setter Property="Background" Value="{StaticResource Gray200}" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ProgressBar">
                                                <Border CornerRadius="4"
                                                        Background="{TemplateBinding Background}"
                                                        Height="{TemplateBinding Height}">
                                                    <Border x:Name="PART_Track">
                                                        <Border x:Name="PART_Indicator"
                                                                CornerRadius="4"
                                                                Background="{TemplateBinding Foreground}"
                                                                HorizontalAlignment="Left" />
                                                    </Border>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ProgressBar.Style>
                        </ProgressBar>

                        <TextBlock x:Name="lblProgress"
                                   Style="{StaticResource Caption}"
                                   Margin="0,0,0,12" />

                        <TextBox x:Name="txtLog"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="{StaticResource Gray50}"
                                 BorderBrush="{StaticResource Gray200}"
                                 BorderThickness="1"
                                 Padding="8"
                                 Height="220"
                                 FontSize="12"
                                 FontFamily="Consolas"
                                 Foreground="{StaticResource Gray700}" />

                        <StackPanel x:Name="panelComplete"
                                    Orientation="Horizontal"
                                    Margin="0,12,0,0"
                                    Visibility="Collapsed">
                            <TextBlock Text="Export complete"
                                       Style="{StaticResource Body1}"
                                       Foreground="#FF2E7D32"
                                       VerticalAlignment="Center"
                                       Margin="0,0,16,0" />
                            <Button x:Name="btnOpenFile"
                                    Content="Open File"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="btnOpenFile_Click"
                                    MinWidth="100" />
                        </StackPanel>

                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Page>
