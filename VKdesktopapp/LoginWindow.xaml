<Window
    x:Class="VRASDesktopApp.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:VRASDesktopApp"
    FontFamily="Segoe UI"
    Style="{StaticResource ChromeWindow}"
    Background="{StaticResource Gray50}"
    Title="VK Enterprises - Login"
    Height="640"
    Width="420"
    WindowStartupLocation="CenterScreen"
    KeyDown="Window_KeyDown"
    ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Draggable Title Bar -->
        <Grid Grid.Row="0" Background="{StaticResource Gray900}" Margin="1,0,1,0"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="VK Enterprises"
                       VerticalAlignment="Center" Margin="14,0,0,0"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource Orange500}"
                       IsHitTestVisible="False" />
            <Button Name="btnClose" Click="btnClose_Click"
                    Grid.Column="1" Width="40" Height="36"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x2715;" FontFamily="Segoe UI" FontSize="14"
                    Foreground="{StaticResource Gray400}"
                    Cursor="Hand"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFE53935" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Login Form -->
        <StackPanel Grid.Row="1">
            <!-- Logo (favicon.ico) -->
            <Grid Width="90" Height="90" Margin="0,24,0,4">
                <Rectangle RadiusX="90" RadiusY="90"
                           Stroke="{StaticResource Gray300}" StrokeThickness="1.5"
                           StrokeDashArray="3,2" />
                <Border CornerRadius="45" Height="72" Width="72"
                        Background="{StaticResource Gray900}" />
                <Image Source="/public/favicon.ico"
                       Width="48" Height="48"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>

            <!-- Firm Name -->
            <TextBlock Name="lblFirmName"
                       Text="VK Enterprises"
                       TextAlignment="Center"
                       FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource Gray900}"
                       Margin="16,0,16,4"
                       TextWrapping="Wrap" />

            <!-- Contact Info -->
            <StackPanel Margin="20,4">
                <TextBlock Padding="0,8,0,2" Text="CONTACT"
                           Foreground="{StaticResource Gray500}"
                           FontSize="10" FontWeight="SemiBold" />
                <TextBlock Name="lblFirmMobile"
                           Text="9850637363"
                           FontSize="14"
                           Foreground="{StaticResource Gray800}" />
                <TextBlock Padding="0,10,0,2" Text="ADDRESS"
                           Foreground="{StaticResource Gray500}"
                           FontSize="10" FontWeight="SemiBold" />
                <TextBlock Name="lblFirmAddress"
                           Text="VK Maharashtra"
                           FontSize="13"
                           Foreground="{StaticResource Gray700}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- Divider -->
            <Border Height="1" Background="{StaticResource Gray200}" Margin="20,8" />

            <!-- Mobile Input -->
            <StackPanel Margin="20,8">
                <TextBlock Text="MOBILE NUMBER"
                           Foreground="{StaticResource Gray600}"
                           FontSize="11" FontWeight="SemiBold" />
                <Border BorderBrush="{StaticResource Gray300}" BorderThickness="1"
                        CornerRadius="4" Margin="0,4,0,0" Background="White">
                    <TextBox Name="txtMobileNo"
                             Text="9850637363"
                             FontSize="16"
                             TextAlignment="Center"
                             BorderThickness="0"
                             Padding="12,10"
                             MaxLength="10"
                             Foreground="{StaticResource Gray900}"
                             CaretBrush="{StaticResource Orange500}" />
                </Border>
            </StackPanel>

            <!-- Password Input -->
            <StackPanel Margin="20,8">
                <TextBlock Text="PASSWORD"
                           Foreground="{StaticResource Gray600}"
                           FontSize="11" FontWeight="SemiBold" />
                <Border BorderBrush="{StaticResource Gray300}" BorderThickness="1"
                        CornerRadius="4" Margin="0,4,0,0" Background="White">
                    <PasswordBox Name="txtPassword"
                                 FontSize="16"
                                 Padding="12,10"
                                 Foreground="{StaticResource Gray900}"
                                 CaretBrush="{StaticResource Orange500}"
                                 BorderThickness="0" />
                </Border>
            </StackPanel>

            <!-- Login Button -->
            <Button Name="btnLogin" Click="btnLogin_Click"
                    Content="SIGN IN"
                    Margin="20,16,20,0"
                    Height="48"
                    FontSize="15" FontWeight="Bold"
                    Foreground="White"
                    Background="{StaticResource Orange500}"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Orange700}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Status -->
            <TextBlock Name="lblStatus"
                       TextAlignment="Center"
                       Margin="0,14,0,0"
                       Foreground="{StaticResource Gray500}"
                       FontSize="12" />
        </StackPanel>
    </Grid>
</Window>
