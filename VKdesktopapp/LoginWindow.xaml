<Window
    x:Class="VRASDesktopApp.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:VRASDesktopApp"
    FontFamily="Segoe UI"
    Style="{StaticResource ChromeWindow}"
    Background="{StaticResource Gray50}"
    Icon="public/favicon.ico"
    Title="CRMRS - Login"
    Height="560"
    Width="420"
    WindowStartupLocation="CenterScreen"
    KeyDown="Window_KeyDown"
    ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Draggable Title Bar -->
        <Grid Grid.Row="0" Background="{StaticResource Gray900}" Margin="1,0,1,0"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="CRMRS"
                       VerticalAlignment="Center" Margin="14,0,0,0"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource Orange500}"
                       IsHitTestVisible="False" />
            <Button Name="btnClose" Click="btnClose_Click"
                    Grid.Column="1" Width="40" Height="36"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x2715;" FontFamily="Segoe UI" FontSize="14"
                    Foreground="{StaticResource Gray400}"
                    Cursor="Hand"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFE53935" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Login Form -->
        <StackPanel Grid.Row="1">
            <!-- Logo (favicon.ico) -->
            <Grid Width="96" Height="96" Margin="0,32,0,8">
                <Rectangle RadiusX="96" RadiusY="96"
                           Stroke="{StaticResource Gray300}" StrokeThickness="1.5"
                           StrokeDashArray="3,2" />
                <Border CornerRadius="48" Height="76" Width="76"
                        Background="{StaticResource Gray900}" />
                <Image Source="/public/favicon.ico"
                       Width="52" Height="52"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>

            <!-- Product Name -->
            <TextBlock Text="CRMRS"
                       TextAlignment="Center"
                       FontSize="26" FontWeight="Bold"
                       Foreground="{StaticResource Gray900}"
                       Margin="16,4,16,0" />
            <TextBlock Text="Customer Relationship Management Recovery Software"
                       TextAlignment="Center"
                       FontSize="11"
                       Foreground="{StaticResource Gray500}"
                       Margin="28,2,28,0"
                       TextWrapping="Wrap" />

            <!-- Divider -->
            <Border Height="1" Background="{StaticResource Gray200}" Margin="28,18,28,4" />

            <TextBlock Text="Sign in to your agency account"
                       TextAlignment="Center"
                       FontSize="12"
                       Foreground="{StaticResource Gray600}"
                       Margin="16,6,16,0" />

            <!-- Email Input -->
            <StackPanel Margin="28,10,28,0">
                <TextBlock Text="EMAIL ADDRESS"
                           Foreground="{StaticResource Gray600}"
                           FontSize="11" FontWeight="SemiBold" />
                <Border BorderBrush="{StaticResource Gray300}" BorderThickness="1"
                        CornerRadius="4" Margin="0,4,0,0" Background="White">
                    <TextBox Name="txtEmail"
                             FontSize="15"
                             BorderThickness="0"
                             Padding="12,10"
                             Foreground="{StaticResource Gray900}"
                             CaretBrush="{StaticResource Orange500}" />
                </Border>
            </StackPanel>

            <!-- Password Input -->
            <StackPanel Margin="28,12,28,0">
                <TextBlock Text="PASSWORD"
                           Foreground="{StaticResource Gray600}"
                           FontSize="11" FontWeight="SemiBold" />
                <Border BorderBrush="{StaticResource Gray300}" BorderThickness="1"
                        CornerRadius="4" Margin="0,4,0,0" Background="White">
                    <PasswordBox Name="txtPassword"
                                 FontSize="15"
                                 Padding="12,10"
                                 Foreground="{StaticResource Gray900}"
                                 CaretBrush="{StaticResource Orange500}"
                                 BorderThickness="0" />
                </Border>
            </StackPanel>

            <!-- Login Button -->
            <Button Name="btnLogin" Click="btnLogin_Click"
                    Content="SIGN IN"
                    Margin="28,20,28,0"
                    Height="46"
                    FontSize="14" FontWeight="Bold"
                    Foreground="White"
                    Background="{StaticResource Orange500}"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource Orange700}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Status -->
            <TextBlock Name="lblStatus"
                       TextAlignment="Center"
                       Margin="20,14,20,0"
                       Foreground="{StaticResource Gray500}"
                       FontSize="12"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Window>
