<Window x:Class="CRMRSDesktopApp.CourierShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        FontFamily="{StaticResource FontBody}"
        Title="Couriers" Height="760" Width="1200"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        Background="{StaticResource Gray200}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Gray900}" />
        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
            <Image Name="imgLogo" Height="24" Margin="0,0,10,0" VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <TextBlock Name="lblTitle" Text="" Foreground="White" FontSize="14" FontWeight="Bold"
                       VerticalAlignment="Center" />
        </StackPanel>

        <Frame Grid.Row="1" Name="PageContainer" NavigationUIVisibility="Hidden"
               Background="White" Padding="0" Margin="0" />
    </Grid>
</Window>
