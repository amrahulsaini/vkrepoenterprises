<Page
    x:Class="VRASDesktopApp.AppUsers.AppUsersManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:VRASDesktopApp.AppUsers"
    Title="App Users Manager"
    Background="White"
    FontFamily="Roboto">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="APP USERS MANAGER"
                   Style="{StaticResource Heading4}"
                   Margin="16,8,8,8" />

        <DataGrid Name="dgUsers" Grid.Row="1"
                  AutoGenerateColumns="False"
                  Margin="16,0,16,16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding AppUserId}" Width="60" />
                <DataGridTextColumn Header="Mobile No" Binding="{Binding MobileNo}" Width="140" />
                <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="200" />
                <DataGridTextColumn Header="Active" Binding="{Binding IsActive}" Width="80" />
                <DataGridTextColumn Header="Admin" Binding="{Binding IsAdmin}" Width="80" />
                <DataGridTextColumn Header="Created On" Binding="{Binding CreatedOn}" Width="140" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
