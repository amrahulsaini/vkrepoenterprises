<Page
    x:Class="VRASDesktopApp.AppUsers.AppUsersManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource Gray50}"
    FontFamily="Segoe UI"
    Loaded="Page_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DashboardCard}">
            <StackPanel>
                <TextBlock Text="APP USERS" Style="{StaticResource Heading4}" />
                <TextBlock Text="Live users, device assignments and subscription plan visibility."
                           Margin="0,6,0,0"
                           Style="{StaticResource Caption}" />
            </StackPanel>
        </Border>

        <UniformGrid Grid.Row="1" Columns="5" Margin="0,18,0,18">
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="USERS" Style="{StaticResource FormHeading}" /><TextBlock Name="lblUsers" Style="{StaticResource StatValue}" Text="0" /></StackPanel></Border>
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="ACTIVE" Style="{StaticResource FormHeading}" /><TextBlock Name="lblActive" Style="{StaticResource StatValue}" Text="0" /></StackPanel></Border>
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="ADMIN" Style="{StaticResource FormHeading}" /><TextBlock Name="lblAdmin" Style="{StaticResource StatValue}" Text="0" /></StackPanel></Border>
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="PLANS" Style="{StaticResource FormHeading}" /><TextBlock Name="lblPlans" Style="{StaticResource StatValue}" Text="0" /></StackPanel></Border>
            <Border Style="{StaticResource DashboardCard}"><StackPanel><TextBlock Text="DEVICES" Style="{StaticResource FormHeading}" /><TextBlock Name="lblDevices" Style="{StaticResource StatValue}" Text="0" /></StackPanel></Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="USER LIST" Style="{StaticResource Heading5}" Margin="0,0,0,12" />
                    <DataGrid Name="dgUsers" Grid.Row="1" Style="{StaticResource MaterialDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*" />
                            <DataGridTextColumn Header="Mobile" Binding="{Binding MobileNo}" Width="120" />
                            <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="80" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" />
                            <DataGridTextColumn Header="Branches" Binding="{Binding BranchCount}" Width="90" />
                            <DataGridTextColumn Header="Plan End" Binding="{Binding PlanEndDate}" Width="140" />
                            <DataGridTextColumn Header="Created" Binding="{Binding CreatedOn}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource DashboardCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="PLAN ALERTS" Style="{StaticResource Heading5}" Margin="0,0,0,12" />
                        <DataGrid Name="dgPlans" Grid.Row="1" Style="{StaticResource MaterialDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="User" Binding="{Binding UserName}" Width="*" />
                                <DataGridTextColumn Header="Mobile" Binding="{Binding MobileNo}" Width="120" />
                                <DataGridTextColumn Header="Start" Binding="{Binding StartDate}" Width="140" />
                                <DataGridTextColumn Header="End" Binding="{Binding EndDate}" Width="140" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource DashboardCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="DEVICE STATE" Style="{StaticResource Heading5}" Margin="0,0,0,12" />
                        <DataGrid Name="dgDevices" Grid.Row="1" Style="{StaticResource MaterialDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="User" Binding="{Binding FullName}" Width="*" />
                                <DataGridTextColumn Header="Device ID" Binding="{Binding DeviceId}" Width="*" />
                                <DataGridTextColumn Header="Requested" Binding="{Binding RequestDeviceId}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
