<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary Colors -->
    <Color x:Key="Primary50">#FFE3F2FD</Color>
    <Color x:Key="Primary100">#FFBBDEFB</Color>
    <Color x:Key="Primary200">#FF90CAF9</Color>
    <Color x:Key="Primary300">#FF64B5F6</Color>
    <Color x:Key="Primary400">#FF42A5F5</Color>
    <Color x:Key="Primary500">#FF2196F3</Color>
    <Color x:Key="Primary600">#FF1E88E5</Color>
    <Color x:Key="Primary700">#FF1976D2</Color>
    <Color x:Key="Primary800">#FF1565C0</Color>
    <Color x:Key="Primary900">#FF0D47A1</Color>

    <!-- Accent / Yellow -->
    <Color x:Key="Yellow50">#FFFFFDE7</Color>
    <Color x:Key="Yellow100">#FFFFF9C4</Color>
    <Color x:Key="Yellow200">#FFFFF59D</Color>
    <Color x:Key="Yellow300">#FFFFF176</Color>
    <Color x:Key="Yellow400">#FFFFEE58</Color>
    <Color x:Key="Yellow500">#FFFFEB3B</Color>
    <Color x:Key="Yellow600">#FFFDD835</Color>
    <Color x:Key="Yellow700">#FFFBC02D</Color>
    <Color x:Key="Yellow800">#FFF9A825</Color>
    <Color x:Key="Yellow900">#FFF57F17</Color>

    <!-- Grays -->
    <Color x:Key="Gray50">#FFFAFAFA</Color>
    <Color x:Key="Gray100">#FFF5F5F5</Color>
    <Color x:Key="Gray200">#FFEEEEEE</Color>
    <Color x:Key="Gray300">#FFE0E0E0</Color>
    <Color x:Key="Gray400">#FFBDBDBD</Color>
    <Color x:Key="Gray500">#FF9E9E9E</Color>
    <Color x:Key="Gray600">#FF757575</Color>
    <Color x:Key="Gray700">#FF616161</Color>
    <Color x:Key="Gray800">#FF424242</Color>
    <Color x:Key="Gray900">#FF212121</Color>

    <!-- Status Colors -->
    <Color x:Key="Red500">#FFF44336</Color>
    <Color x:Key="Green500">#FF4CAF50</Color>
    <Color x:Key="Orange500">#FFFF9800</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="Primary50Brush" Color="{StaticResource Primary50}" />
    <SolidColorBrush x:Key="Primary100Brush" Color="{StaticResource Primary100}" />
    <SolidColorBrush x:Key="Primary200Brush" Color="{StaticResource Primary200}" />
    <SolidColorBrush x:Key="Primary300Brush" Color="{StaticResource Primary300}" />
    <SolidColorBrush x:Key="Primary400Brush" Color="{StaticResource Primary400}" />
    <SolidColorBrush x:Key="Primary500Brush" Color="{StaticResource Primary500}" />
    <SolidColorBrush x:Key="Primary600Brush" Color="{StaticResource Primary600}" />
    <SolidColorBrush x:Key="Primary700Brush" Color="{StaticResource Primary700}" />
    <SolidColorBrush x:Key="Primary800Brush" Color="{StaticResource Primary800}" />
    <SolidColorBrush x:Key="Primary900Brush" Color="{StaticResource Primary900}" />

    <SolidColorBrush x:Key="Yellow700Brush" Color="{StaticResource Yellow700}" />

    <SolidColorBrush x:Key="Gray50Brush" Color="{StaticResource Gray50}" />
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}" />
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}" />
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}" />
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}" />
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}" />
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}" />
    <SolidColorBrush x:Key="Gray700Brush" Color="{StaticResource Gray700}" />
    <SolidColorBrush x:Key="Gray800Brush" Color="{StaticResource Gray800}" />
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}" />

    <SolidColorBrush x:Key="Red500Brush" Color="{StaticResource Red500}" />
    <SolidColorBrush x:Key="Green500Brush" Color="{StaticResource Green500}" />
    <SolidColorBrush x:Key="Orange500Brush" Color="{StaticResource Orange500}" />

    <!-- Alias Brushes matching old names -->
    <SolidColorBrush x:Key="Yellow700" Color="{StaticResource Yellow700}" />
    <SolidColorBrush x:Key="Gray50" Color="{StaticResource Gray50}" />
    <SolidColorBrush x:Key="Gray100" Color="{StaticResource Gray100}" />
    <SolidColorBrush x:Key="Gray200" Color="{StaticResource Gray200}" />
    <SolidColorBrush x:Key="Gray300" Color="{StaticResource Gray300}" />
    <SolidColorBrush x:Key="Gray400" Color="{StaticResource Gray400}" />
    <SolidColorBrush x:Key="Gray500" Color="{StaticResource Gray500}" />
    <SolidColorBrush x:Key="Gray600" Color="{StaticResource Gray600}" />
    <SolidColorBrush x:Key="Gray700" Color="{StaticResource Gray700}" />
    <SolidColorBrush x:Key="Gray800" Color="{StaticResource Gray800}" />
    <SolidColorBrush x:Key="Gray900" Color="{StaticResource Gray900}" />

    <!-- Primary -->
    <SolidColorBrush x:Key="Primary100" Color="{StaticResource Primary100}" />
    <SolidColorBrush x:Key="Primary200" Color="{StaticResource Primary200}" />
    <SolidColorBrush x:Key="Primary300" Color="{StaticResource Primary300}" />
    <SolidColorBrush x:Key="Primary500" Color="{StaticResource Primary500}" />
    <SolidColorBrush x:Key="Primary700" Color="{StaticResource Primary700}" />

    <!-- Accent -->
    <SolidColorBrush x:Key="Accent700" Color="{StaticResource Yellow700}" />

</ResourceDictionary>
