<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── VK Enterprises Color Scheme: Black / White / Orange ── -->

    <!-- Orange Accent -->
    <Color x:Key="cOrange50">#FFFFF3E0</Color>
    <Color x:Key="cOrange100">#FFFFE0B2</Color>
    <Color x:Key="cOrange200">#FFFFCC80</Color>
    <Color x:Key="cOrange300">#FFFFB74D</Color>
    <Color x:Key="cOrange400">#FFFFA726</Color>
    <Color x:Key="cOrange500">#FFFF9800</Color>
    <Color x:Key="cOrange600">#FFFB8C00</Color>
    <Color x:Key="cOrange700">#FFF57C00</Color>
    <Color x:Key="cOrange800">#FFEF6C00</Color>
    <Color x:Key="cOrange900">#FFE65100</Color>

    <!-- Grays / Blacks / Whites -->
    <Color x:Key="cGray50">#FFFAFAFA</Color>
    <Color x:Key="cGray100">#FFF0F0F0</Color>
    <Color x:Key="cGray200">#FFE0E0E0</Color>
    <Color x:Key="cGray300">#FFCCCCCC</Color>
    <Color x:Key="cGray400">#FFAAAAAA</Color>
    <Color x:Key="cGray500">#FF888888</Color>
    <Color x:Key="cGray600">#FF666666</Color>
    <Color x:Key="cGray700">#FF444444</Color>
    <Color x:Key="cGray800">#FF2A2A2A</Color>
    <Color x:Key="cGray900">#FF1A1A1A</Color>
    <Color x:Key="cBlack">#FF0D0D0D</Color>
    <Color x:Key="cWhite">#FFFFFFFF</Color>

    <!-- Status Colors -->
    <Color x:Key="cRed500">#FFE53935</Color>
    <Color x:Key="cGreen500">#FF43A047</Color>

    <!-- ── Brushes ── -->

    <!-- Primary / Accent (Orange) -->
    <SolidColorBrush x:Key="Primary50" Color="{StaticResource cOrange50}" />
    <SolidColorBrush x:Key="Primary100" Color="{StaticResource cOrange100}" />
    <SolidColorBrush x:Key="Primary200" Color="{StaticResource cOrange200}" />
    <SolidColorBrush x:Key="Primary300" Color="{StaticResource cOrange300}" />
    <SolidColorBrush x:Key="Primary400" Color="{StaticResource cOrange400}" />
    <SolidColorBrush x:Key="Primary500" Color="{StaticResource cOrange500}" />
    <SolidColorBrush x:Key="Primary600" Color="{StaticResource cOrange600}" />
    <SolidColorBrush x:Key="Primary700" Color="{StaticResource cOrange700}" />
    <SolidColorBrush x:Key="Primary800" Color="{StaticResource cOrange800}" />
    <SolidColorBrush x:Key="Primary900" Color="{StaticResource cOrange900}" />

    <!-- Accent alias (used as sidebar top bar etc.) -->
    <SolidColorBrush x:Key="Accent700" Color="{StaticResource cOrange700}" />
    <SolidColorBrush x:Key="Yellow700" Color="{StaticResource cOrange700}" />

    <!-- Named Orange brushes -->
    <SolidColorBrush x:Key="Orange500" Color="{StaticResource cOrange500}" />
    <SolidColorBrush x:Key="Orange700" Color="{StaticResource cOrange700}" />

    <!-- Grays -->
    <SolidColorBrush x:Key="Gray50" Color="{StaticResource cGray50}" />
    <SolidColorBrush x:Key="Gray100" Color="{StaticResource cGray100}" />
    <SolidColorBrush x:Key="Gray200" Color="{StaticResource cGray200}" />
    <SolidColorBrush x:Key="Gray300" Color="{StaticResource cGray300}" />
    <SolidColorBrush x:Key="Gray400" Color="{StaticResource cGray400}" />
    <SolidColorBrush x:Key="Gray500" Color="{StaticResource cGray500}" />
    <SolidColorBrush x:Key="Gray600" Color="{StaticResource cGray600}" />
    <SolidColorBrush x:Key="Gray700" Color="{StaticResource cGray700}" />
    <SolidColorBrush x:Key="Gray800" Color="{StaticResource cGray800}" />
    <SolidColorBrush x:Key="Gray900" Color="{StaticResource cGray900}" />

    <!-- Pure Black & White -->
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource cBlack}" />
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource cWhite}" />

    <!-- Status -->
    <SolidColorBrush x:Key="Red500" Color="{StaticResource cRed500}" />
    <SolidColorBrush x:Key="Green500" Color="{StaticResource cGreen500}" />

</ResourceDictionary>
