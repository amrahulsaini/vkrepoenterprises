<Page
    x:Class="VRASDesktopApp.Records.UploadRecordsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="clr-namespace:VRASDesktopApp.Material"
    Background="{StaticResource Gray50}"
    FontFamily="Segoe UI"
    Loaded="Page_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{StaticResource DashboardCard}">
            <StackPanel>
                <TextBlock Text="UPLOAD RECORDS" Style="{StaticResource Heading4}" />
                <TextBlock Text="Recent file uploads, bank channels and header-template readiness."
                           Margin="0,6,0,0"
                           Style="{StaticResource Caption}" />
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,12">
            <md:MaterialCardButton x:Name="btnUploadUsingExcel" Click="btnUploadUsingExcel_Click" Width="260" Height="120" Margin="4" FontSize="14" Content="Upload Records (Excel)" />
            <md:MaterialCardButton x:Name="btnAddMergeManually" Click="btnAddMergeManually_Click" Width="260" Height="120" Margin="4" FontSize="14" Content="Add / Merge Records (Manual)" />
        </StackPanel>
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,18,0,18">
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="FILES" Style="{StaticResource FormHeading}" /><TextBlock Name="lblFiles" Style="{StaticResource StatValue}" Text="0" /></StackPanel></Border>
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="BANKS" Style="{StaticResource FormHeading}" /><TextBlock Name="lblBanks" Style="{StaticResource StatValue}" Text="0" /></StackPanel></Border>
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="HEADERS" Style="{StaticResource FormHeading}" /><TextBlock Name="lblHeaders" Style="{StaticResource StatValue}" Text="0" /></StackPanel></Border>
            <Border Style="{StaticResource DashboardCard}"><StackPanel><TextBlock Text="LATEST" Style="{StaticResource FormHeading}" /><TextBlock Name="lblLatestUpload" Style="{StaticResource Heading5}" Text="-" /></StackPanel></Border>
        </UniformGrid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <TextBlock Text="UPLOADED FILES" Style="{StaticResource Heading5}" Margin="0,0,0,12" />
                    <DataGrid Name="dgFiles" Grid.Row="1" Style="{StaticResource MaterialDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="*" />
                            <DataGridTextColumn Header="Bank" Binding="{Binding BankName}" Width="*" />
                            <DataGridTextColumn Header="Vehicle Type" Binding="{Binding VehicleType}" Width="120" />
                            <DataGridTextColumn Header="Uploaded By" Binding="{Binding UploadedBy}" Width="*" />
                            <DataGridTextColumn Header="Created" Binding="{Binding CreatedOn}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
            <Grid Grid.Column="2">
                <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="16" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <Border Style="{StaticResource DashboardCard}">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <TextBlock Text="BANK CHANNELS" Style="{StaticResource Heading5}" Margin="0,0,0,12" />
                        <DataGrid Name="dgBanks" Grid.Row="1" Style="{StaticResource MaterialDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Bank" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Detail}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
                <Border Grid.Row="2" Style="{StaticResource DashboardCard}">
                    <StackPanel>
                        <TextBlock Text="DESKTOP ROLLOUT STATUS" Style="{StaticResource Heading5}" Margin="0,0,0,12" />
                        <TextBlock Text="• Mongo upload history is live" Style="{StaticResource Body2}" Margin="0,0,0,8" />
                        <TextBlock Text="• Header templates are connected" Style="{StaticResource Body2}" Margin="0,0,0,8" />
                        <TextBlock Text="• Bulk desktop upload workflow can be plugged in next" Style="{StaticResource Body2}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
