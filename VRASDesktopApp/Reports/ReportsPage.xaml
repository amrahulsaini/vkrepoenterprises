<Page
    x:Class="VRASDesktopApp.Reports.ReportsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource Gray50}"
    FontFamily="Segoe UI"
    Loaded="Page_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DashboardCard}">
            <StackPanel>
                <TextBlock Text="REPORTS AND OPERATIONS" Style="{StaticResource Heading4}" />
                <TextBlock Text="Collection coverage, highest-volume branches and bank upload distribution."
                           Margin="0,6,0,0"
                           Style="{StaticResource Caption}" />
            </StackPanel>
        </Border>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,18,0,18">
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="VEHICLES" Style="{StaticResource FormHeading}" /><TextBlock Name="lblVehicles" Style="{StaticResource StatValue}" Text="0" /></StackPanel></Border>
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="UPLOADS" Style="{StaticResource FormHeading}" /><TextBlock Name="lblUploads" Style="{StaticResource StatValue}" Text="0" /></StackPanel></Border>
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0"><StackPanel><TextBlock Text="BRANCHES" Style="{StaticResource FormHeading}" /><TextBlock Name="lblBranches" Style="{StaticResource StatValue}" Text="0" /></StackPanel></Border>
            <Border Style="{StaticResource DashboardCard}"><StackPanel><TextBlock Text="USERS" Style="{StaticResource FormHeading}" /><TextBlock Name="lblUsers" Style="{StaticResource StatValue}" Text="0" /></StackPanel></Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="COLLECTION COVERAGE" Style="{StaticResource Heading5}" Margin="0,0,0,12" />
                    <DataGrid Name="dgCollections" Grid.Row="1" Style="{StaticResource MaterialDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Collection" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Rows" Binding="{Binding Count}" Width="120" />
                            <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource DashboardCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="TOP BRANCHES" Style="{StaticResource Heading5}" Margin="0,0,0,12" />
                        <DataGrid Name="dgBranches" Grid.Row="1" Style="{StaticResource MaterialDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Branch" Binding="{Binding BranchName}" Width="*" />
                                <DataGridTextColumn Header="Head Office" Binding="{Binding HeadOfficeName}" Width="*" />
                                <DataGridTextColumn Header="Records" Binding="{Binding Records}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource DashboardCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="TOP BANKS" Style="{StaticResource Heading5}" Margin="0,0,0,12" />
                        <DataGrid Name="dgBanks" Grid.Row="1" Style="{StaticResource MaterialDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Bank" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Files" Binding="{Binding Count}" Width="120" />
                                <DataGridTextColumn Header="Summary" Binding="{Binding Detail}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
