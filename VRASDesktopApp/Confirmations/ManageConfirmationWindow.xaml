<Window x:Class="VRASDesktopApp.Confirmations.ManageConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Confirmation" Height="700" Width="900"
        WindowStartupLocation="CenterOwner" Background="White" FontFamily="Segoe UI"
        Loaded="Window_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="MANAGE CONFIRMATION" FontSize="20" FontWeight="Bold" Margin="0,0,0,16" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Vehicle Details -->
            <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="1" Background="#F9F9F9">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="pnlVehicleDetails" Margin="10">
                        <!-- Vehicle Details DataGrid-like view -->
                        <!-- Group Header Style -->
                        <StackPanel.Resources>
                            <Style TargetType="TextBlock" x:Key="HeaderStyle">
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Foreground" Value="#1A237E" />
                                <Setter Property="Margin" Value="0,8,0,4" />
                            </Style>
                            <Style TargetType="Border" x:Key="RowStyle">
                                <Setter Property="BorderBrush" Value="#E0E0E0" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="Padding" Value="4,6" />
                            </Style>
                            <Style TargetType="TextBlock" x:Key="LabelStyle">
                                <Setter Property="Foreground" Value="#2E5C99" />
                                <Setter Property="Width" Value="150" />
                            </Style>
                        </StackPanel.Resources>

                        <TextBlock Text="Vehicle" Style="{StaticResource HeaderStyle}" />
                        
                        <Border Style="{StaticResource RowStyle}">
                            <DockPanel>
                                <TextBlock Text="VehicleNo" Style="{StaticResource LabelStyle}" />
                                <TextBox x:Name="txtVehicleNo" Text="" BorderThickness="1" BorderBrush="#CCC" Padding="2" />
                            </DockPanel>
                        </Border>
                        <Border Style="{StaticResource RowStyle}">
                            <DockPanel>
                                <TextBlock Text="ChasisNo" Style="{StaticResource LabelStyle}" />
                                <TextBox x:Name="txtChassisNo" Text="" BorderThickness="1" BorderBrush="#CCC" Padding="2" />
                            </DockPanel>
                        </Border>
                        <Border Style="{StaticResource RowStyle}">
                            <DockPanel>
                                <TextBlock Text="Model" Style="{StaticResource LabelStyle}" />
                                <TextBox x:Name="txtModel" Text="" BorderThickness="1" BorderBrush="#CCC" Padding="2" />
                            </DockPanel>
                        </Border>
                        <Border Style="{StaticResource RowStyle}">
                            <DockPanel>
                                <TextBlock Text="EngineNo" Style="{StaticResource LabelStyle}" />
                                <TextBox x:Name="txtEngineNo" Text="" BorderThickness="1" BorderBrush="#CCC" Padding="2" />
                            </DockPanel>
                        </Border>

                        <TextBlock Text="Other" Style="{StaticResource HeaderStyle}" Margin="0,16,0,4" />
                        <Border Style="{StaticResource RowStyle}">
                            <DockPanel>
                                <TextBlock Text="Created on" Style="{StaticResource LabelStyle}" />
                                <TextBox x:Name="txtCreatedOn" Text="" BorderThickness="1" BorderBrush="#CCC" Padding="2" IsReadOnly="True" Background="#EEE" />
                            </DockPanel>
                        </Border>
                        <Border Style="{StaticResource RowStyle}">
                            <DockPanel>
                                <TextBlock Text="Modified on" Style="{StaticResource LabelStyle}" />
                                <TextBox x:Name="txtUpdatedOn" Text="" BorderThickness="1" BorderBrush="#CCC" Padding="2" IsReadOnly="True" Background="#EEE" />
                            </DockPanel>
                        </Border>

                        <TextBlock Text="Customer" Style="{StaticResource HeaderStyle}" Margin="0,16,0,4" />
                        <Border Style="{StaticResource RowStyle}">
                            <DockPanel>
                                <TextBlock Text="CustomerName" Style="{StaticResource LabelStyle}" />
                                <TextBox x:Name="txtCustomerName" Text="" BorderThickness="1" BorderBrush="#CCC" Padding="2" />
                            </DockPanel>
                        </Border>
                        <Border Style="{StaticResource RowStyle}">
                            <DockPanel>
                                <TextBlock Text="CustomerContactNos" Style="{StaticResource LabelStyle}" />
                                <TextBox x:Name="txtCustomerContactNos" Text="" BorderThickness="1" BorderBrush="#CCC" Padding="2" />
                            </DockPanel>
                        </Border>
                        <Border Style="{StaticResource RowStyle}">
                            <DockPanel>
                                <TextBlock Text="CustomerAddress" Style="{StaticResource LabelStyle}" />
                                <TextBox x:Name="txtCustomerAddress" Text="" BorderThickness="1" BorderBrush="#CCC" Padding="2" />
                            </DockPanel>
                        </Border>

                        <TextBlock Text="Finance" Style="{StaticResource HeaderStyle}" Margin="0,16,0,4" />
                        <Border Style="{StaticResource RowStyle}">
                            <DockPanel>
                                <TextBlock Text="FinanceName" Style="{StaticResource LabelStyle}" />
                                <TextBox x:Name="txtFinanceName" Text="" BorderThickness="1" BorderBrush="#CCC" Padding="2" />
                            </DockPanel>
                        </Border>
                        <Border Style="{StaticResource RowStyle}">
                            <DockPanel>
                                <TextBlock Text="BranchName" Style="{StaticResource LabelStyle}" />
                                <TextBox x:Name="txtBranchName" Text="" BorderThickness="1" BorderBrush="#CCC" Padding="2" />
                            </DockPanel>
                        </Border>
                        <Border Style="{StaticResource RowStyle}">
                            <DockPanel>
                                <TextBlock Text="BranchFirstContactDetails" Style="{StaticResource LabelStyle}" />
                                <TextBox x:Name="txtBranchFirstContactDetails" Text="" BorderThickness="1" BorderBrush="#CCC" Padding="2" />
                            </DockPanel>
                        </Border>
                        <Border Style="{StaticResource RowStyle}">
                            <DockPanel>
                                <TextBlock Text="BranchSecondContactDetails" Style="{StaticResource LabelStyle}" />
                                <TextBox x:Name="txtBranchSecondContactDetails" Text="" BorderThickness="1" BorderBrush="#CCC" Padding="2" />
                            </DockPanel>
                        </Border>
                        <Border Style="{StaticResource RowStyle}">
                            <DockPanel>
                                <TextBlock Text="BranchThirdContactDetails" Style="{StaticResource LabelStyle}" />
                                <TextBox x:Name="txtBranchThirdContactDetails" Text="" BorderThickness="1" BorderBrush="#CCC" Padding="2" />
                            </DockPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Right Panel: Form -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Select Seizer" Margin="0,0,0,4" Foreground="#666" />
                <ComboBox x:Name="cmbSeizer" Height="36" DisplayMemberPath="Display" SelectedValuePath="UserId" Margin="0,0,0,16" IsEditable="True" IsTextSearchEnabled="True" TextSearch.TextPath="Display" />

                <CheckBox x:Name="chkContainsLoad" Content="Vehicle contains load" Margin="0,0,0,16" />

                <TextBlock Text="Load description" Margin="0,0,0,4" Foreground="#666" />
                <TextBox x:Name="txtLoadDescription" Height="36" Padding="4" Margin="0,0,0,16" />

                <TextBlock Text="Confirm by" Margin="0,0,0,4" Foreground="#666" />
                <TextBox x:Name="txtConfirmBy" Height="36" Padding="4" Margin="0,0,0,16" />

                <TextBlock Text="Status: Pending/Released/Repo" Margin="0,0,0,4" Foreground="#666" />
                <ComboBox x:Name="cmbStatus" Height="36" Margin="0,0,0,16">
                    <ComboBoxItem Content="Pending" />
                    <ComboBoxItem Content="Released" />
                    <ComboBoxItem Content="Repo" />
                </ComboBox>

                <TextBlock Text="Yard" Margin="0,0,0,4" Foreground="#666" />
                <TextBox x:Name="txtYard" Height="36" Padding="4" Margin="0,0,0,16" />

                <CheckBox x:Name="chkApplyAmtCredited" Content="Apply Amt Credited on Seizer Account" Margin="0,0,0,16" />

                <TextBlock Text="Amount credited to seizer" Margin="0,0,0,4" Foreground="#666" />
                <DockPanel Margin="0,0,0,24">
                    <TextBlock Text="Rs. " VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0" />
                    <TextBox x:Name="txtAmountCredited" Height="36" Padding="4" />
                </DockPanel>

                <Button x:Name="btnSubmit" Content="✔ SUBMIT CONFIRMATION" Height="42" Background="#FFC107" FontWeight="Bold" Cursor="Hand" Click="btnSubmit_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>