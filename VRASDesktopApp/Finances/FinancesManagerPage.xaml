<Page
    x:Class="VRASDesktopApp.Finances.FinancesManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:VRASDesktopApp.Finances"
    Title="Finances Manager"
    Background="White"
    FontFamily="Roboto">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="FINANCES MANAGER"
                   Style="{StaticResource Heading4}"
                   Margin="16,8,8,8" />

        <DataGrid Name="dgFinances" Grid.Row="1"
                  AutoGenerateColumns="False"
                  Margin="16,0,16,16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding FinanceId}" Width="60" />
                <DataGridTextColumn Header="Vehicle No" Binding="{Binding VehicleNo}" Width="120" />
                <DataGridTextColumn Header="Type" Binding="{Binding FinanceType}" Width="120" />
                <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="120" />
                <DataGridTextColumn Header="Date" Binding="{Binding FinanceDate}" Width="140" />
                <DataGridTextColumn Header="Created On" Binding="{Binding CreatedOn}" Width="140" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
