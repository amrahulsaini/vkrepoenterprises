<Page
    x:Class="VRASDesktopApp.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:VRASDesktopApp"
    Title="HomePage"
    Background="White"
    FontFamily="Roboto"
    Loaded="Page_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MaxWidth="480" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Left Panel - Overview -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="HOME"
                       Style="{StaticResource Heading4}"
                       Margin="16,8,8,8" />

            <Grid Grid.Row="1" Margin="16,8,8,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Overview Card -->
                <Border
                    BorderBrush="{StaticResource Gray100}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Background="{StaticResource Gray50}">
                    <Grid Margin="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="RECORDS AND FINANCES"
                                   Grid.ColumnSpan="3"
                                   Style="{StaticResource FormHeading}"
                                   Margin="0,0,0,16"
                                   TextAlignment="Center" />

                        <StackPanel Grid.Row="1">
                            <TextBlock Name="lblRecords" Text="0"
                                       TextAlignment="Center"
                                       Style="{StaticResource Heading4}" />
                            <TextBlock Text="Records"
                                       TextAlignment="Center"
                                       Style="{StaticResource Caption}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1">
                            <TextBlock Name="lblFinances" Text="0"
                                       TextAlignment="Center"
                                       Style="{StaticResource Heading4}" />
                            <TextBlock Text="Finances"
                                       TextAlignment="Center"
                                       Style="{StaticResource Caption}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2">
                            <TextBlock Name="lblUsers" Text="0"
                                       TextAlignment="Center"
                                       Style="{StaticResource Heading4}" />
                            <TextBlock Text="App Users"
                                       TextAlignment="Center"
                                       Style="{StaticResource Caption}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Quick Stats -->
                <Border Grid.Row="2"
                        BorderBrush="{StaticResource Gray100}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="{StaticResource Gray50}">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="QUICK STATS"
                                   Style="{StaticResource FormHeading}"
                                   Margin="0,0,0,12" />

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="Confirmations:" Style="{StaticResource Body2}" Width="140" />
                            <TextBlock Name="lblConfirmations" Text="0" Style="{StaticResource Body1}" FontWeight="SemiBold" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4">
                            <TextBlock Text="Feedbacks:" Style="{StaticResource Body2}" Width="140" />
                            <TextBlock Name="lblFeedbacks" Text="0" Style="{StaticResource Body1}" FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Recent Activity -->
                <Border Grid.Row="4"
                        BorderBrush="{StaticResource Gray100}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="{StaticResource Gray50}">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="RECENT ACTIVITY"
                                   Style="{StaticResource FormHeading}"
                                   Margin="0,0,0,12" />
                        <TextBlock Grid.Row="1"
                                   Text="No recent activity to display."
                                   Style="{StaticResource Caption}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Right Panel - WebView / Map -->
        <Border Grid.Column="1" Background="{StaticResource Gray100}" Margin="16,8,8,8" CornerRadius="4">
            <Grid>
                <TextBlock Text="Dashboard"
                           Style="{StaticResource Heading5}"
                           Margin="16"
                           VerticalAlignment="Top" />
                <TextBlock Text="Welcome to VRAS Desktop App"
                           Style="{StaticResource Body1}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Gray400}" />
            </Grid>
        </Border>
    </Grid>
</Page>
