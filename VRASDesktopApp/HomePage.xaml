<Page
    x:Class="VRASDesktopApp.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:VRASDesktopApp"
    Background="{StaticResource Gray50}"
    FontFamily="Segoe UI"
    Loaded="Page_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource Gray900}"
                BorderBrush="{StaticResource Gray900}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="22">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="OPERATIONS HOME"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock Text="Live desktop snapshot backed by the MongoDB cluster."
                               Margin="0,6,0,0"
                               Foreground="{StaticResource Gray300}" />
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#26FFFFFF"
                        CornerRadius="8"
                        Padding="14,10">
                    <StackPanel>
                        <TextBlock Text="API ENDPOINT"
                                   Style="{StaticResource FormHeading}"
                                   Foreground="{StaticResource Gray300}" />
                        <TextBlock Text="{x:Static local:App.ApiBaseUrl}"
                                   Foreground="White"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="1"
                     Columns="3"
                     Margin="0,18,0,18">
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                        <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource Primary500}" Margin="0,0,8,0">
                            <TextBlock Text="R" Foreground="{StaticResource WhiteBrush}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="RECORDS" Style="{StaticResource FormHeading}" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Name="lblRecords" Style="{StaticResource StatValue}" Text="0" />
                    <TextBlock Text="Vehicles available for desktop search"
                               Style="{StaticResource Caption}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                        <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource Orange600}" Margin="0,0,8,0">
                            <TextBlock Text="BR" Foreground="{StaticResource WhiteBrush}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="BRANCHES" Style="{StaticResource FormHeading}" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Name="lblBranches" Style="{StaticResource StatValue}" Text="0" />
                    <TextBlock Name="lblHeadOffices" Text="0 head offices"
                               Style="{StaticResource Caption}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                        <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource Primary700}" Margin="0,0,8,0">
                            <TextBlock Text="U" Foreground="{StaticResource WhiteBrush}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="USERS" Style="{StaticResource FormHeading}" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Name="lblUsers" Style="{StaticResource StatValue}" Text="0" />
                    <TextBlock Name="lblUserStatus" Text="0 active • 0 admin"
                               Style="{StaticResource Caption}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                        <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource Orange700}" Margin="0,0,8,0">
                            <TextBlock Text="D" Foreground="{StaticResource WhiteBrush}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="DETAIL VIEWS" Style="{StaticResource FormHeading}" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Name="lblDetailViews" Style="{StaticResource StatValue}" Text="0" />
                    <TextBlock Name="lblFoundDetails" Text="0 marked FOUND"
                               Style="{StaticResource Caption}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DashboardCard}" Margin="0,0,12,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                        <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource Primary600}" Margin="0,0,8,0">
                            <TextBlock Text="UP" Foreground="{StaticResource WhiteBrush}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="UPLOADS" Style="{StaticResource FormHeading}" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Name="lblUploads" Style="{StaticResource StatValue}" Text="0" />
                    <TextBlock Name="lblOtps" Text="0 OTP records"
                               Style="{StaticResource Caption}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource DashboardCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                        <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource Orange600}" Margin="0,0,8,0">
                            <TextBlock Text="₹" Foreground="{StaticResource WhiteBrush}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="BILLINGS" Style="{StaticResource FormHeading}" VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Name="lblBillings" Style="{StaticResource StatValue}" Text="0" />
                    <TextBlock Text="Shell is ready for payment rollout"
                               Style="{StaticResource Caption}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="RECENT UPLOADS"
                               Style="{StaticResource Heading5}"
                               Margin="0,0,0,12" />
                    <DataGrid Name="dgUploads"
                              Grid.Row="1"
                              Style="{StaticResource MaterialDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="2*" />
                            <DataGridTextColumn Header="Bank" Binding="{Binding BankName}" Width="*" />
                            <DataGridTextColumn Header="Uploaded By" Binding="{Binding UploadedBy}" Width="*" />
                            <DataGridTextColumn Header="Created" Binding="{Binding CreatedOn}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource DashboardCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="COLLECTION HEALTH"
                               Style="{StaticResource Heading5}"
                               Margin="0,0,0,12" />
                    <DataGrid Name="dgCollections"
                              Grid.Row="1"
                              Style="{StaticResource MaterialDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Collection" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Rows" Binding="{Binding Count}" Width="120" />
                            <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource DashboardCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="RECENT DETAIL VIEWS"
                               Style="{StaticResource Heading5}"
                               Margin="0,0,0,12" />
                    <DataGrid Name="dgDetails"
                              Grid.Row="1"
                              Style="{StaticResource MaterialDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Vehicle" Binding="{Binding VehicleNo}" Width="120" />
                            <DataGridTextColumn Header="User" Binding="{Binding UserName}" Width="*" />
                            <DataGridTextColumn Header="Status" Binding="{Binding VehicleStatus}" Width="110" />
                            <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="1.3*" />
                            <DataGridTextColumn Header="Viewed" Binding="{Binding CreatedOn}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource DashboardCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="TOP BRANCHES"
                               Style="{StaticResource Heading5}"
                               Margin="0,0,0,12" />
                    <DataGrid Name="dgBranches"
                              Grid.Row="1"
                              Style="{StaticResource MaterialDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Branch" Binding="{Binding BranchName}" Width="*" />
                            <DataGridTextColumn Header="Head Office" Binding="{Binding HeadOfficeName}" Width="*" />
                            <DataGridTextColumn Header="Records" Binding="{Binding Records}" Width="100" />
                            <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedOn}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
