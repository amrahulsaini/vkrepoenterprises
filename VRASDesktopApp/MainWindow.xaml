<Window
    x:Class="VRASDesktopApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:VRASDesktopApp"
    FontFamily="Segoe UI"
    Style="{StaticResource ChromeWindow}"
    Background="{StaticResource Gray200}"
    Title="VK Enterprises"
    Width="1366" Height="768"
    WindowState="Maximized"
    Loaded="Window_Loaded">
    <Grid Margin="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="64" />
            <ColumnDefinition Name="clmMenuContainer" Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Custom Title Bar (Black) ── -->
        <Border Grid.ColumnSpan="3" Background="{StaticResource Gray900}" />
        <Grid Grid.ColumnSpan="3" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="40" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0"
                        IsHitTestVisible="False">
                <TextBlock Text="VK" FontSize="14" FontWeight="Bold"
                           Foreground="{StaticResource Orange500}" Margin="0,0,4,0" />
                <TextBlock Text="ENTERPRISES" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource Gray400}" VerticalAlignment="Center" />
            </StackPanel>
            <Button Name="btnMinimize" Click="btnMinimize_Click"
                    Grid.Column="1" Width="40" Height="40"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x2014;" FontFamily="Segoe UI" FontSize="14"
                    Foreground="{StaticResource Gray400}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Name="b" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#FF3A3A3A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Name="btnRestore" Click="btnRestore_Click"
                    Grid.Column="2" Width="40" Height="40"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x2750;" FontFamily="Segoe UI" FontSize="12"
                    Foreground="{StaticResource Gray400}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Name="b" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#FF3A3A3A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Name="btnClose" Click="btnClose_Click"
                    Grid.Column="3" Width="40" Height="40"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x2715;" FontFamily="Segoe UI" FontSize="14"
                    Foreground="{StaticResource Gray400}" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Name="b" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#FFE53935" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- ── Left Sidebar (Dark) ── -->
        <Border Grid.Column="0" Grid.Row="1" Background="{StaticResource Gray900}" />
        <Grid Grid.Column="0" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="56" />
                <RowDefinition Height="56" />
                <RowDefinition Height="56" />
                <RowDefinition Height="56" />
                <RowDefinition Height="56" />
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
                <RowDefinition Height="56" />
            </Grid.RowDefinitions>

            <Button Name="btnHome" Click="btnNav_Click"
                    Grid.Row="1" Width="64" Height="56"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x1F3E0;" FontFamily="Segoe UI" FontSize="20"
                    Foreground="{StaticResource Gray400}" Cursor="Hand"
                    Tag="Home" />
            <Button Name="btnSearch" Click="btnNav_Click"
                    Grid.Row="2" Width="64" Height="56"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x1F50D;" FontFamily="Segoe UI" FontSize="20"
                    Foreground="{StaticResource Orange500}" Cursor="Hand"
                    Tag="Search" />
            <Button Name="btnFinances" Click="btnNav_Click"
                    Grid.Row="3" Width="64" Height="56"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x1F4B0;" FontFamily="Segoe UI" FontSize="20"
                    Foreground="{StaticResource Gray400}" Cursor="Hand"
                    Tag="Finances" />
            <Button Name="btnUsers" Click="btnNav_Click"
                    Grid.Row="4" Width="64" Height="56"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x1F465;" FontFamily="Segoe UI" FontSize="20"
                    Foreground="{StaticResource Gray400}" Cursor="Hand"
                    Tag="Users" />
            <Button Name="btnConfirmations" Click="btnNav_Click"
                    Grid.Row="5" Width="64" Height="56"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x2705;" FontFamily="Segoe UI" FontSize="20"
                    Foreground="{StaticResource Gray400}" Cursor="Hand"
                    Tag="Confirmations" />
            <Button Name="btnReports" Click="btnNav_Click"
                    Grid.Row="6" Width="64" Height="56"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x1F4CA;" FontFamily="Segoe UI" FontSize="20"
                    Foreground="{StaticResource Gray400}" Cursor="Hand"
                    Tag="Reports" />
            <Button Name="btnSettings" Click="btnSettings_Click"
                    Grid.Row="8" Width="64" Height="56"
                    Background="Transparent" BorderThickness="0"
                    Content="&#x2699;" FontFamily="Segoe UI" FontSize="22"
                    Foreground="{StaticResource Gray400}" Cursor="Hand" />
        </Grid>

        <!-- ── Slide-out Menu ── -->
        <Border Name="MenuContainer" Grid.Column="1" Grid.Row="1"
                Background="{StaticResource Gray50}" Visibility="Collapsed"
                BorderBrush="{StaticResource Gray200}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Margin="20,16">
                    <TextBlock Text="VK ENTERPRISES" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource Gray900}" />
                    <TextBlock Name="lblFirmName" Text="VK Enterprises"
                               FontSize="13" Foreground="{StaticResource Orange600}"
                               FontWeight="SemiBold" Margin="0,6,0,0" />
                    <TextBlock Name="lblFirmMobile" Text="9850637363"
                               FontSize="12" Foreground="{StaticResource Gray600}" Margin="0,4,0,0" />
                    <TextBlock Name="lblFirmAddress" Text="VK Maharashtra"
                               FontSize="11" Foreground="{StaticResource Gray500}"
                               Margin="0,6,0,0" TextWrapping="Wrap" />
                </StackPanel>
                <ListBox Grid.Row="1" BorderThickness="0" Background="Transparent"
                         Foreground="{StaticResource Gray800}" FontSize="13">
                    <ListBoxItem Padding="20,10">🔍  Search Records</ListBoxItem>
                    <ListBoxItem Padding="20,10">📤  Upload Records</ListBoxItem>
                    <ListBoxItem Padding="20,10">💰  Finances Manager</ListBoxItem>
                    <ListBoxItem Padding="20,10">👥  App Users</ListBoxItem>
                    <ListBoxItem Padding="20,10">✅  Confirmations</ListBoxItem>
                    <ListBoxItem Padding="20,10">📊  Reports</ListBoxItem>
                    <ListBoxItem Padding="20,10">💬  Feedbacks</ListBoxItem>
                    <ListBoxItem Padding="20,10">💳  Payments</ListBoxItem>
                </ListBox>
            </Grid>
        </Border>

        <!-- ── Content Area ── -->
        <Border Name="PageContainer" Grid.Column="2" Grid.Row="1" Background="White" />
        <Border Name="PageContainerWide" Grid.Column="1" Grid.ColumnSpan="2"
                Grid.Row="1" Background="White" Visibility="Collapsed" />
    </Grid>
</Window>
