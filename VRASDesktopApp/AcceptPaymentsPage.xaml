<Page
    x:Class="VRASDesktopApp.AcceptPaymentsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource Gray50}"
    FontFamily="Segoe UI"
    Loaded="Page_Loaded">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource DashboardCard}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="ACCEPT PAYMENTS" Style="{StaticResource Heading4}" />
                <TextBlock Grid.Row="1"
                           Text="The desktop payment shell is staged against the live Mongo environment."
                           Margin="0,6,0,18"
                           Style="{StaticResource Caption}" />

                <TextBlock Grid.Row="2" Text="Vehicle Number" Style="{StaticResource FormHeading}" />
                <TextBox Name="txtVehicleNo" Grid.Row="3" Style="{StaticResource MaterialTextBox}" Margin="0,4,0,12" Text="MH12AB1234" />

                <TextBlock Grid.Row="4" Text="Amount (Rs.)" Style="{StaticResource FormHeading}" />
                <TextBox Name="txtAmount" Grid.Row="5" Style="{StaticResource MaterialTextBox}" Margin="0,4,0,12" Text="2500" />

                <Grid Grid.Row="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Payment Method" Style="{StaticResource FormHeading}" />
                    <ComboBox Name="cmbPaymentMethod" Grid.Row="1" Margin="0,4,0,14" Height="42" DisplayMemberPath="MethodName" SelectedValuePath="PaymentMethodId" />
                    <TextBlock Grid.Row="2" Text="Status Note" Style="{StaticResource FormHeading}" />
                    <Border Grid.Row="3" Background="{StaticResource Primary50}" BorderBrush="{StaticResource Primary100}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,4,0,14">
                        <TextBlock Name="lblStatusNote" TextWrapping="Wrap" Style="{StaticResource Body2}" />
                    </Border>
                    <UniformGrid Grid.Row="4" Columns="3" Margin="0,0,0,14">
                        <Border Style="{StaticResource DashboardCard}" Margin="0,0,8,0"><StackPanel><TextBlock Text="BANKS" Style="{StaticResource FormHeading}" /><TextBlock Name="lblBanks" Style="{StaticResource Heading4}" Text="0" /></StackPanel></Border>
                        <Border Style="{StaticResource DashboardCard}" Margin="0,0,8,0"><StackPanel><TextBlock Text="BILLINGS" Style="{StaticResource FormHeading}" /><TextBlock Name="lblBillings" Style="{StaticResource Heading4}" Text="0" /></StackPanel></Border>
                        <Border Style="{StaticResource DashboardCard}"><StackPanel><TextBlock Text="UPLOADS" Style="{StaticResource FormHeading}" /><TextBlock Name="lblUploads" Style="{StaticResource Heading4}" Text="0" /></StackPanel></Border>
                    </UniformGrid>
                    <Button Grid.Row="5"
                            Content="PAYMENT POSTING COMING SOON"
                            Style="{StaticResource SecondaryButton}"
                            IsEnabled="False" />
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource DashboardCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="PAYMENT METHODS" Style="{StaticResource Heading5}" Margin="0,0,0,12" />
                    <DataGrid Name="dgMethods" Grid.Row="1" Style="{StaticResource MaterialDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Method" Binding="{Binding MethodName}" Width="*" />
                            <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*" />
                            <DataGridTextColumn Header="Active" Binding="{Binding IsActive}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource DashboardCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="RECENT SUPPORTING UPLOADS" Style="{StaticResource Heading5}" Margin="0,0,0,12" />
                    <DataGrid Name="dgUploads" Grid.Row="1" Style="{StaticResource MaterialDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="*" />
                            <DataGridTextColumn Header="Bank" Binding="{Binding BankName}" Width="*" />
                            <DataGridTextColumn Header="Created" Binding="{Binding CreatedOn}" Width="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
