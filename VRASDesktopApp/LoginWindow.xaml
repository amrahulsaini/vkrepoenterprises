<Window
    x:Class="VRASDesktopApp.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:VRASDesktopApp"
    FontFamily="Roboto"
    Style="{StaticResource ChromeWindow}"
    Background="{StaticResource Gray50}"
    Title="Login - VRAS"
    Height="580"
    Width="420"
    WindowStartupLocation="CenterScreen"
    KeyDown="Window_KeyDown">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid Margin="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="36" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
            </Grid.RowDefinitions>
            <TextBlock
                Text="ASRDC VRAS"
                Style="{StaticResource Heading5}"
                Margin="16,8,16,8"
                Visibility="Hidden" />
            <Button
                Name="btnClose"
                Click="btnClose_Click"
                Grid.Column="1"
                Height="36" Width="36"
                Background="{StaticResource Gray100}"
                BorderBrush="{StaticResource Gray100}"
                Content="&#xE5CD;"
                FontFamily="Material Icons"
                FontSize="16"
                Foreground="{StaticResource Gray600}"
                Cursor="Hand"
                WindowChrome.IsHitTestVisibleInChrome="True" />
        </Grid>

        <!-- Login Form -->
        <StackPanel Grid.Row="1">
            <Grid Width="96" Height="96" Margin="0,16,0,4">
                <Rectangle
                    RadiusX="96" RadiusY="96"
                    Stroke="{StaticResource Gray500}"
                    StrokeDashArray="2,2" />
                <Border
                    CornerRadius="36"
                    Height="72" Width="72"
                    Background="{StaticResource Gray300}" />
                <Image
                    Source="/Resources/Images/windows.png"
                    Width="32" Height="32"
                    Opacity="0.3" />
            </Grid>
            <StackPanel>
                <TextBlock
                    Name="lblFirmName"
                    Text="Default Company Name"
                    TextAlignment="Center"
                    FontSize="18"
                    Margin="0,0,0,8"
                    FontWeight="SemiBold"
                    TextWrapping="Wrap" />
                <StackPanel Margin="0,4">
                    <TextBlock Padding="16,0" Text="CONTACTS"
                               Style="{StaticResource FormHeading}"
                               FontSize="10" FontWeight="SemiBold" />
                    <TextBlock Name="lblFirmMobile" Padding="16,0"
                               Text="0876543210, 0123456780"
                               FontSize="15" />
                    <TextBlock Padding="16,0" Text="ADDRESS"
                               Style="{StaticResource FormHeading}"
                               FontSize="10" FontWeight="SemiBold"
                               Margin="0,8,0,0" />
                    <TextBlock Name="lblFirmAddress" Padding="16,0"
                               Text="Dummy Address"
                               FontSize="13"
                               TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>

            <!-- Mobile No Input -->
            <StackPanel Margin="16,24,16,0">
                <TextBlock Text="MOBILE NUMBER"
                           Style="{StaticResource FormHeading}" />
                <TextBox Name="txtMobileNo"
                         Style="{StaticResource MaterialTextBox}"
                         Margin="0,4,0,0"
                         FontSize="18"
                         TextAlignment="Center"
                         MaxLength="10" />
            </StackPanel>

            <!-- Login Button -->
            <Button
                Name="btnLogin"
                Click="btnLogin_Click"
                Content="LOGIN"
                Margin="16,24,16,0"
                Height="48"
                FontSize="16"
                FontWeight="SemiBold"
                Background="{StaticResource Primary500}"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand" />

            <!-- Loading indicator -->
            <TextBlock Name="lblStatus"
                       TextAlignment="Center"
                       Margin="0,16,0,0"
                       Foreground="{StaticResource Gray600}"
                       FontSize="12" />
        </StackPanel>

        <!-- Bottom bar -->
        <Border Grid.Row="2" Background="{StaticResource Gray100}" Height="36">
            <TextBlock Text="Vehicle Registration &amp; Administration System"
                       FontSize="11" Foreground="{StaticResource Gray500}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
    </Grid>
</Window>
