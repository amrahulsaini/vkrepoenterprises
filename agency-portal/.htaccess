# Clean URLs for the CRMRS agency portal — no .html extensions anywhere.
# OpenLiteSpeed autoloads this (rewrite + autoLoadHtaccess are on for the vhost).
RewriteEngine On

# 1) Redirect any explicit *.html request to its clean URL (canonical 301).
RewriteCond %{THE_REQUEST} \s/+([^.\s?]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# 2) Serve the matching .html file for an extensionless URL (internal rewrite).
#    Skips real directories; only rewrites when <url>.html actually exists.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
