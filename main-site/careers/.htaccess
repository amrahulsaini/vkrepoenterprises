RewriteEngine On
RewriteBase /careers/
RewriteRule ^job/[A-Za-z0-9-]*-([0-9]+)/?$ job.php?id=$1 [L,QSA]

<FilesMatch "\.(sql|md|log)$">
  Require all denied
</FilesMatch>
<Files "config.php">
  Require all denied
</Files>
<Files "config.local.php">
  Require all denied
</Files>
<Files "config.local.example.php">
  Require all denied
</Files>
<Files "bootstrap.php">
  Require all denied
</Files>
<Files "helpers.php">
  Require all denied
</Files>
